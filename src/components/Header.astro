---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/friday-harbor/', label: 'Friday Harbor' },
  { href: '/research/', label: 'Research' },
  { href: '/projects/', label: 'Projects' },
  { href: '/publications/', label: 'Publications' },
  { href: '/people/', label: 'People' },
  { href: '/teaching/', label: 'Teaching' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Humanistic GIS Laboratory home">
      <svg
        class="brand-logo"
        viewBox="160 555 325 290"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="HGIS Lab logo"
      >
        <path class="brand-bar brand-bar-humanistic" pathLength="100" d="M299.2,565.6L175,791.6l22.8,41l103-186.7l57.5,105.9h45.5L299.2,565.6z" />
        <path class="brand-bar brand-bar-geoai"      pathLength="100" d="M300.8,645.9l22.7,41.8l-58.4,103.9l205.9,0.1l-21.7,42l-251.5-1.2L300.8,645.9z" />
        <path class="brand-bar brand-bar-fake"       pathLength="100" d="M299.2,565.6l104.5,186.1l-116.2,0.1l-22.3,39.8l205.8,0L345.5,565.5L299.2,565.6z" />
      </svg>
      <span class="brand-text">
        <strong>Humanistic GIS Laboratory</strong>
        <small>University of Washington · Department of Geography</small>
      </span>
    </a>
    <nav>
      <ul>
        {nav.map(item => (
          <li>
            <a
              href={item.href}
              class:list={[ 'nav-link', { active: path === item.href || (item.href !== '/' && path.startsWith(item.href)) } ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="gold-rule"></div>
</header>

<style>
  .site-header {
    background: var(--bg-card);
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .gold-rule {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--uw-gold) 20%, var(--uw-gold) 80%, transparent 100%);
    opacity: 0.55;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.75rem;
    gap: 2rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    border-bottom: 0;
  }
  .brand:hover { border-bottom: 0; }
  .brand-logo {
    width: 2.4rem;
    height: 2.4rem;
    display: block;
    overflow: visible;
    transform-origin: center center;
    transition: filter 0.25s ease;
    --c-humanistic: #4A2F82;
    --c-geoai: #B5A57B;
    --c-fake: #D9D9D9;
  }
  .brand-bar {
    transform-box: fill-box;
    transform-origin: center center;
  }
  .brand-bar-humanistic { fill: var(--c-humanistic); stroke: var(--c-humanistic); }
  .brand-bar-geoai      { fill: var(--c-geoai);      stroke: var(--c-geoai); }
  .brand-bar-fake       { fill: var(--c-fake);       stroke: #b3b3b3; }

  /* Entry animations — JS picks one of {spin, draw, assemble} on the first
     pageview of the session, then no entry on subsequent navigations.
     Idle = none (a header logo on every page should not loop). */

  /* (1) spin: whole logo rotates 360 once with a small overshoot */
  .brand-logo.entry-spin {
    animation: brand-spin 1.1s cubic-bezier(0.5, 0, 0.2, 1) both;
  }
  @keyframes brand-spin {
    0%   { transform: rotate(-15deg) scale(0.85); opacity: 0; }
    60%  { transform: rotate(370deg) scale(1.06); opacity: 1; }
    100% { transform: rotate(360deg) scale(1); opacity: 1; }
  }

  /* (2) draw: each bar's outline strokes in, then fill comes up */
  .brand-logo.entry-draw .brand-bar {
    fill-opacity: 0;
    stroke-width: 1.6;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: brand-draw 1.1s cubic-bezier(0.5, 0, 0.2, 1) forwards;
  }
  .brand-logo.entry-draw .brand-bar-geoai { animation-delay: 0.18s; }
  .brand-logo.entry-draw .brand-bar-fake  { animation-delay: 0.36s; }
  @keyframes brand-draw {
    0%   { stroke-dashoffset: 100; fill-opacity: 0; stroke-opacity: 1; }
    55%  { stroke-dashoffset: 0;   fill-opacity: 0; stroke-opacity: 1; }
    100% { stroke-dashoffset: 0;   fill-opacity: 1; stroke-opacity: 0; }
  }

  /* (3) assemble: three bars fly in from outside the corner of their bbox */
  .brand-logo.entry-assemble .brand-bar {
    opacity: 0;
    animation: brand-assemble 0.9s cubic-bezier(0.45, 0, 0.2, 1.2) forwards;
  }
  .brand-logo.entry-assemble .brand-bar-humanistic { transform-origin: 50% 0%;   animation-delay: 0.05s; }
  .brand-logo.entry-assemble .brand-bar-geoai      { transform-origin: 50% 100%; animation-delay: 0.20s; }
  .brand-logo.entry-assemble .brand-bar-fake       { transform-origin: 100% 50%; animation-delay: 0.35s; }
  @keyframes brand-assemble {
    0%   { opacity: 0; transform: scale(0.4) translate(-6px, -8px); }
    70%  { opacity: 1; transform: scale(1.06); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Idle — a barely-there sway + a low-intensity flow chase. Always on
     after entry has played (or immediately if entry was skipped). The
     wobble is ±1.5° / 14s and the chase brightens each bar by ~6% in
     turn — both calibrated so a passing reader registers "alive" but
     not "noisy". */
  .brand-logo.is-idle {
    animation: brand-idle-sway 14s ease-in-out infinite;
  }
  .brand-logo.is-idle .brand-bar {
    animation: brand-idle-flow 8s ease-in-out infinite;
  }
  .brand-logo.is-idle .brand-bar-humanistic { animation-delay: 0s; }
  .brand-logo.is-idle .brand-bar-geoai      { animation-delay: -2.667s; }
  .brand-logo.is-idle .brand-bar-fake       { animation-delay: -5.333s; }
  @keyframes brand-idle-sway {
    0%, 100% { transform: rotate(-1.5deg); }
    50%      { transform: rotate(1.5deg);  }
  }
  @keyframes brand-idle-flow {
    0%, 80%, 100% { filter: brightness(1) saturate(1); }
    20%           { filter: brightness(1.06) saturate(1.05); }
    40%           { filter: brightness(1) saturate(1); }
  }

  /* Hover: amplify everything. Wobble swaps for a continuous spin; the
     flow chase quadruples in pace and depth; soft shadow lifts it. */
  .brand:hover .brand-logo {
    animation: brand-hover-spin 6s linear infinite;
    filter: drop-shadow(0 1px 4px rgba(50, 42, 38, 0.15));
  }
  @keyframes brand-hover-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .brand:hover .brand-bar {
    animation: brand-flow 1.6s ease-in-out infinite;
  }
  .brand:hover .brand-bar-humanistic { animation-delay: 0s; }
  .brand:hover .brand-bar-geoai      { animation-delay: -1.066s; }
  .brand:hover .brand-bar-fake       { animation-delay: -0.533s; }
  @keyframes brand-flow {
    0%, 80%, 100% { filter: brightness(1) saturate(1); }
    20%           { filter: brightness(1.25) saturate(1.25); }
    40%           { filter: brightness(1) saturate(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-logo,
    .brand-logo .brand-bar,
    .brand:hover .brand-logo,
    .brand:hover .brand-bar { animation: none !important; }
    .brand-logo .brand-bar { fill-opacity: 1; stroke-opacity: 0; opacity: 1; }
  }
  .brand-text strong {
    display: block;
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.15;
    letter-spacing: -0.005em;
    font-weight: 600;
  }
  .brand-text small {
    display: block;
    font-size: 0.7rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  nav ul {
    display: flex;
    gap: 0.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }
  .nav-link {
    color: var(--ink);
    padding: 0.4rem 0.85rem;
    border-radius: 1px;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-bottom: 1px solid transparent;
  }
  .nav-link:hover {
    color: var(--uw-purple);
    border-bottom-color: var(--uw-gold);
  }
  .nav-link.active {
    color: var(--uw-purple);
    border-bottom-color: var(--uw-gold);
  }

  @media (max-width: 720px) {
    .header-inner { flex-direction: column; gap: 0.85rem; padding: 0.9rem 1.25rem; }
    nav ul { justify-content: center; }
  }
</style>

<script is:inline>
  (function () {
    const logo = document.querySelector('.brand-logo');
    if (!logo) return;
    // Only play an entry animation on the first pageview of the session;
    // subsequent navigations skip entry but still get the idle motion.
    let played = false;
    try { played = sessionStorage.getItem('hgis-logo-entry') === '1'; } catch (e) {}
    if (played) {
      logo.classList.add('is-idle');
      return;
    }
    const variants = ['entry-spin', 'entry-draw', 'entry-assemble'];
    const pick = variants[Math.floor(Math.random() * variants.length)];
    logo.classList.add(pick);
    try { sessionStorage.setItem('hgis-logo-entry', '1'); } catch (e) {}
    // After the entry animation settles, hand off to the idle loop so the
    // logo never sits dead-still but also never feels overactive.
    setTimeout(() => {
      logo.classList.remove(pick);
      logo.classList.add('is-idle');
    }, 1800);
  })();
</script>
