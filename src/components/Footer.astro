---
<footer class="site-footer">
  <div class="gold-rule"></div>
  <div class="container footer-grid">
    <div>
      <strong>Humanistic GIS Laboratory</strong>
      <p>
        Department of Geography<br/>
        University of Washington<br/>
        Smith Hall 405A · Box 353550<br/>
        Seattle, WA 98195-3550
      </p>
    </div>
    <div>
      <strong>Contact</strong>
      <p>
        <a href="mailto:hgis@uw.edu">hgis@uw.edu</a>
      </p>
    </div>
    <div>
      <strong>Affiliations</strong>
      <p>
        <a href="https://geography.washington.edu/">Department of Geography</a><br/>
        <a href="https://www.washington.edu/">University of Washington</a><br/>
        <a href="https://csde.washington.edu/" rel="noopener">Center for Studies in Demography and Ecology</a><br/>
        <a href="https://escience.washington.edu/" rel="noopener">eScience Institute</a><br/>
        <a href="https://jsis.washington.edu/china/" rel="noopener">China Studies Program</a><br/>
