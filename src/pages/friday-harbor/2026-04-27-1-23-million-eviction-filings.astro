    { name: { en: 'Los Angeles',     zh: '洛杉矶' },          st: 'CA', lon: -118.24, lat: 34.05, filings: 30000, rate: 2.8,                 side: 'left'  },
    { name: { en: 'Seattle',         zh: '西雅图' },          st: 'WA', lon: -122.33, lat: 47.61, filings: 6000,  rate: 2.5,                 side: 'right' },
  ];

  // FIPS codes for states with stronger tenant protections (RTC, just-cause,
  // and/or aggressive sealing). Categorisation is binary by design — the
  // visual story is already long.
  const STRONG_RTC_FIPS = new Set([
    '06', // California
    '09', // Connecticut
    '11', // District of Columbia
    '24', // Maryland
    '25', // Massachusetts
    '27', // Minnesota
    '34', // New Jersey
    '36', // New York
    '41', // Oregon
    '44', // Rhode Island
    '50', // Vermont
    '53', // Washington
  ]);

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    paper2:  css.getPropertyValue('--bg-deep').trim()   || '#ddd4c2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
    sage:    css.getPropertyValue('--sage').trim()      || '#8e9c8a',
    sageS:   css.getPropertyValue('--sage-soft').trim() || '#b4bdaf',
    rose:    css.getPropertyValue('--rose').trim()      || '#c2a094',
    mist:    css.getPropertyValue('--mist').trim()      || '#a8b1b3',
  };
  const EVENT_DEEP = '#8a3e2e';

  let _states = null;
  fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json')
    .then(r => r.json())
    .then(us => {
      _states = feature(us, us.objects.states);
      requestAnimationFrame(() => draw());
    });

  window.addEventListener('resize', () => { if (_states) draw(); });
  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => { if (_states) draw(); })
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  function currentLang() {
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  function draw() {
    const states = _states;
    if (!states) return;
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(() => draw()); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const padL = 14, padR = 14, padT = 16, padB = 60;
    const mapW = W - padL - padR;
    const mapH = H - padT - padB;

    const projection = d3.geoAlbersUsa()
      .fitSize([mapW, mapH], states)
      .translate([padL + mapW / 2, padT + mapH / 2]);
    const path = d3.geoPath(projection);

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block')
      .style('overflow', 'hidden');

    // Background paper
    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ----- State layer: paper2 base, sage tint on stronger-protection states -----
    svg.append('path').datum(states).attr('d', path)
      .attr('fill', c.paper2).attr('stroke', 'none');

    const strongStates = {
      type: 'FeatureCollection',
      features: states.features.filter(f => STRONG_RTC_FIPS.has(String(f.id).padStart(2, '0')))
    };
    svg.append('path').datum(strongStates).attr('d', path)
      .attr('fill', c.sageS).attr('fill-opacity', 0.62).attr('stroke', 'none');

    // State borders
    svg.append('path').datum(states).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.45)
      .attr('stroke-width', 0.5)
      .attr('stroke-linejoin', 'round');

    // ----- City symbols: size = filings, colour = rate -----
    const maxFilings = d3.max(CITIES, d => d.filings);
    const rScale = d3.scaleSqrt().domain([0, maxFilings]).range([2, 22]);
    // Filing-rate -> warm-fill ramp: pale putty (low) → deep terracotta (high)
    const fillScale = d3.scaleLinear()
      .domain([3, 8, 13, 20])
      .range(['#e3d1bd', '#c2a094', '#a06d5a', EVENT_DEEP])
      .clamp(true);

    // Soft halos drawn under everything so they don't block neighbours
    const haloG = svg.append('g').attr('class', 'fh-evic-halos');
    CITIES.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.filings);
      haloG.append('circle').attr('cx', p[0]).attr('cy', p[1])
        .attr('r', r + 3).attr('fill', c.rose).attr('fill-opacity', 0.22);
    });

    // Dots
    const dotG = svg.append('g').attr('class', 'fh-evic-dots');
    CITIES.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.filings);
      const g = dotG.append('g').attr('transform', `translate(${p[0]},${p[1]})`);
      g.append('circle').attr('r', r)
        .attr('fill', fillScale(d.rate)).attr('fill-opacity', 0.88)
        .attr('stroke', c.paper).attr('stroke-width', 1.1);
      // Anchor cities — slow pulsing outer ring, staggered phase
      if (d.anchor) {
        const idx = CITIES.filter(x => x.anchor).indexOf(d);
        const phase = (idx * 0.6).toFixed(1);
        const outer = g.append('circle').attr('r', r + 7).attr('fill', 'none')
          .attr('stroke', EVENT_DEEP).attr('stroke-opacity', 0.55).attr('stroke-width', 1.4);
        outer.append('animate').attr('attributeName', 'r')
          .attr('values', `${r + 5};${r + 14};${r + 5}`)
          .attr('dur', '3.2s').attr('begin', `-${phase}s`).attr('repeatCount', 'indefinite');
        outer.append('animate').attr('attributeName', 'stroke-opacity')
          .attr('values', '0.65;0.10;0.65')
          .attr('dur', '3.2s').attr('begin', `-${phase}s`).attr('repeatCount', 'indefinite');
      }
    });

    // City labels — name + rate %, halo so they read on any tint
    const labelG = svg.append('g').attr('class', 'fh-evic-labels');
    CITIES.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.filings);
      const isRight = d.side !== 'left';
      const x = p[0] + (isRight ? r + 6 : -r - 6);
      const y = p[1] + 3;
      const fontSize = d.anchor ? 12.5 : 10.5;
      const weight = d.anchor ? 700 : 600;
      const t = labelG.append('text')
        .attr('x', x).attr('y', y)
        .attr('text-anchor', isRight ? 'start' : 'end')
        .attr('fill', c.ink)
        .attr('font-size', fontSize).attr('font-weight', weight)
        .attr('font-family', 'Inter, "Noto Sans CJK", sans-serif')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3.5)
        .attr('stroke-linejoin', 'round');
      t.text(d.name[lang]);
      // Rate percentage as a smaller secondary line
      const t2 = labelG.append('text')
        .attr('x', x).attr('y', y + (d.anchor ? 14 : 12))
        .attr('text-anchor', isRight ? 'start' : 'end')
        .attr('fill', c.purpleD)
        .attr('font-size', d.anchor ? 11 : 9.5)
        .attr('font-weight', 600)
        .attr('font-family', 'Inter, "Noto Sans CJK", sans-serif')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round');
      t2.text(`${d.rate.toFixed(1)} %`);
    });

    // ----- Legend (bottom of map) -----
    const legSerif = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';

    // Capacity / volume scale (left)
    const legendCaps = [10000, 50000, 144000];
    const legX = padL + 24;
    const legY = padT + mapH - 8;
    const legG = svg.append('g').attr('transform', `translate(${legX},${legY})`);
    legG.append('text').attr('x', 0).attr('y', -54)
      .attr('font-size', 11).attr('fill', c.inkSoft)
      .attr('font-style', 'italic').attr('font-family', legSerif)
      .text(lang === 'zh' ? 'filing 总量' : 'filings (annual)');
    legendCaps.forEach((cap, i) => {
      const r = rScale(cap);
      const x = i * 70;
      legG.append('circle').attr('cx', x).attr('cy', -22).attr('r', r)
        .attr('fill', 'none').attr('stroke', c.inkSoft).attr('stroke-width', 0.9);
      legG.append('text').attr('x', x).attr('y', -22 + r + 14)
        .attr('text-anchor', 'middle').attr('font-size', 10)
        .attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
        .text(cap >= 1000 ? `${(cap / 1000) | 0}k` : `${cap}`);
    });

    // Filing-rate colour ramp (middle)
    const rampX = padL + mapW * 0.43;
    const rampY = padT + mapH - 28;
    const rampG = svg.append('g').attr('transform', `translate(${rampX},${rampY})`);
    rampG.append('text').attr('x', 0).attr('y', -8)
      .attr('font-size', 11).attr('fill', c.inkSoft)
      .attr('font-style', 'italic').attr('font-family', legSerif)
      .text(lang === 'zh' ? 'filing rate（颜色）' : 'filing rate (colour)');
    const rampStops = [3, 8, 13, 20];
    rampStops.forEach((rate, i) => {
      const x = i * 36;
      rampG.append('rect').attr('x', x).attr('y', 0)
        .attr('width', 36).attr('height', 12).attr('fill', fillScale(rate));
    });
    rampG.append('text').attr('x', 0).attr('y', 26)
      .attr('font-size', 9.5).attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
      .text('3 %');
    rampG.append('text').attr('x', 144).attr('y', 26).attr('text-anchor', 'end')
      .attr('font-size', 9.5).attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
      .text('20 %');

    // RTC swatch (right)
    const rtcX = padL + mapW - 240;
    const rtcY = padT + mapH - 28;
    const rtcG = svg.append('g').attr('transform', `translate(${rtcX},${rtcY})`);
    rtcG.append('rect').attr('x', 0).attr('y', 0).attr('width', 14).attr('height', 14)
      .attr('fill', c.sageS).attr('fill-opacity', 0.72)
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.4).attr('stroke-width', 0.5);
    rtcG.append('text').attr('x', 20).attr('y', 11)
      .attr('font-size', 10).attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
      .text(lang === 'zh' ? '较强租客保护' : 'stronger tenant protection');
  }
</script>
