<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';

  // ===== Paradigm bands =====
  // Each paradigm: a set of (year, strength) keypoints between 1925 and
  // 2026, plus 2–4 representative figures rendered as a sub-line inside
  // the band. Strengths are interpolated linearly between keypoints; the
  // streamgraph renormalises across bands. The numbers are editorial
  // weights, not bibliometrics — they're calibrated to read as Johnston &
  // Sidaway's chronicle does, with bands that thin without disappearing.
  const PARADIGMS = [
    {
      id: 'regional',
      label:   { en: 'Regional · areal differentiation',  zh: '区域 · 区位差异' },
      figures: { en: 'Hartshorne · Sauer · Vidal',        zh: 'Hartshorne · Sauer · Vidal' },
      color:   '#b9a577',
      peaks: [
        [1925, 0.55], [1939, 0.95], [1945, 1.00], [1955, 0.90],
        [1965, 0.45], [1975, 0.22], [1985, 0.14], [2000, 0.10], [2026, 0.08],
      ],
    },
    {
      id: 'quantitative',
      label:   { en: 'Quantitative · spatial science',    zh: '计量 · 空间科学' },
      figures: { en: 'Schaefer · Haggett · Berry · Bunge', zh: 'Schaefer · Haggett · Berry · Bunge' },
      color:   '#3a6e8c',
      peaks: [
        [1925, 0.02], [1953, 0.10], [1965, 0.85], [1972, 1.00],
        [1980, 0.65], [1990, 0.50], [2000, 0.55], [2010, 0.65], [2026, 0.70],
      ],
    },
    {
      id: 'behavioral',
      label:   { en: 'Behavioral',                         zh: '行为' },
      figures: { en: 'Golledge · Cox',                     zh: 'Golledge · Cox' },
      color:   '#8a8e57',
      peaks: [
        [1925, 0.0], [1965, 0.05], [1972, 0.55], [1978, 0.65],
        [1985, 0.40], [1995, 0.20], [2010, 0.12], [2026, 0.10],
      ],
    },
    {
      id: 'humanistic',
      label:   { en: 'Humanistic',                          zh: '人本' },
      figures: { en: 'Tuan · Buttimer · Relph',             zh: '段义孚 · Buttimer · Relph' },
      color:   '#6e8b75',
      peaks: [
        [1925, 0.0], [1972, 0.05], [1978, 0.55], [1985, 0.55],
        [1995, 0.45], [2005, 0.45], [2026, 0.50],
      ],
    },
    {
      id: 'marxist',
      label:   { en: 'Marxist · radical',                   zh: '马克思 · 激进' },
      figures: { en: 'Harvey · Massey · Peet · Smith',      zh: 'Harvey · Massey · Peet · Smith' },
      color:   '#a14a3e',
      peaks: [
        [1925, 0.0], [1969, 0.05], [1975, 0.45], [1985, 0.85],
        [1995, 0.70], [2005, 0.55], [2012, 0.75], [2020, 0.70], [2026, 0.65],
      ],
    },
    {
      id: 'cultural',
      label:   { en: 'Cultural · postmodern',               zh: '文化 · 后现代' },
      figures: { en: 'Cosgrove · Jackson · Soja',           zh: 'Cosgrove · Jackson · Soja' },
      color:   '#6e4e72',
      peaks: [
        [1925, 0.0], [1985, 0.05], [1992, 0.55], [2000, 0.85],
        [2010, 0.75], [2020, 0.60], [2026, 0.55],
      ],
    },
    {
      id: 'feminist',
      label:   { en: 'Feminist · queer',                    zh: '女性主义 · 酷儿' },
      figures: { en: 'McDowell · Rose · Gibson-Graham',     zh: 'McDowell · Rose · Gibson-Graham' },
      color:   '#b87a8a',
      peaks: [
        [1925, 0.0], [1982, 0.05], [1990, 0.30], [2000, 0.55],
        [2010, 0.70], [2020, 0.80], [2026, 0.85],
      ],
    },
    {
      id: 'gis',
      label:   { en: 'GIS · critical GIS',                  zh: 'GIS · 批判 GIS' },
      figures: { en: 'Goodchild · Pickles · Sheppard',      zh: 'Goodchild · Pickles · Sheppard' },
      color:   '#3e8a90',
      peaks: [
        [1925, 0.0], [1985, 0.05], [1993, 0.40], [2000, 0.75],
        [2010, 0.95], [2020, 1.05], [2026, 1.10],
      ],
    },
    {
      id: 'nonrep',
      label:   { en: 'Non-representational',                zh: '非表征' },
      figures: { en: 'Thrift · Whatmore',                   zh: 'Thrift · Whatmore' },
      color:   '#97863a',
      peaks: [
        [1925, 0.0], [1996, 0.05], [2005, 0.45], [2012, 0.65],
        [2020, 0.55], [2026, 0.50],
      ],
    },
    {
      id: 'planetary',
      label:   { en: 'More-than-human · planetary · decolonial', zh: '超越人 · 行星 · 解殖' },
      figures: { en: 'Jazeel · Brenner · Yusoff',                zh: 'Jazeel · Brenner · Yusoff' },
      color:   '#5a8a6e',
      peaks: [
        [1925, 0.0], [2008, 0.05], [2015, 0.40], [2020, 0.70], [2026, 0.95],
      ],
    },
  ];

  // ===== Editions of the book =====
  const EDITIONS = [
    { year: 1979, no: 1, note: { en: '1st',           zh: '第 1 版' } },
    { year: 1983, no: 2, note: { en: '2nd',           zh: '第 2 版' } },
    { year: 1987, no: 3, note: { en: '3rd',           zh: '第 3 版' } },
    { year: 1991, no: 4, note: { en: '4th',           zh: '第 4 版' } },
    { year: 1997, no: 5, note: { en: '5th',           zh: '第 5 版' } },
    { year: 2004, no: 6, note: { en: '6th · Sidaway', zh: '第 6 版 · Sidaway' } },
    { year: 2016, no: 7, note: { en: '7th',           zh: '第 7 版' } },
  ];

  // ===== Era events — the "pulse" of the world the discipline lived in =====
  // Eight world-historical hinges between 1925 and 2026. Rendered above
  // the streamgraph in two staggered rows so labels don't collide where
  // events cluster (1968 / 1973, 2001 / 2008).
  const ERA_EVENTS = [
    { year: 1929, label: { en: 'Great Depression',  zh: '大萧条' },   row: 0 },
    { year: 1945, label: { en: 'end of WWII',        zh: '二战结束' }, row: 1 },
    { year: 1968, label: { en: "'68",                zh: '六八' },     row: 0 },
    { year: 1973, label: { en: 'oil shock',          zh: '石油危机' }, row: 1 },
    { year: 1989, label: { en: 'Berlin Wall',        zh: '柏林墙' },   row: 0 },
    { year: 2001, label: { en: '9/11',               zh: '9·11' },    row: 1 },
    { year: 2008, label: { en: 'financial crisis',   zh: '金融危机' }, row: 0 },
    { year: 2020, label: { en: 'COVID',              zh: '新冠' },     row: 1 },
  ];

  // Linear interpolation across keypoints.
  function strengthAt(peaks, year) {
    if (year <= peaks[0][0]) return peaks[0][1];
    if (year >= peaks[peaks.length-1][0]) return peaks[peaks.length-1][1];
    for (let i = 0; i < peaks.length - 1; i++) {
      const [y0, v0] = peaks[i];
      const [y1, v1] = peaks[i+1];
      if (year >= y0 && year <= y1) {
        const t = (year - y0) / (y1 - y0);
        return v0 + t * (v1 - v0);
      }
    }
    return 0;
  }

  const YEAR_START = 1925;
  const YEAR_END   = 2026;
  const YEARS = d3.range(YEAR_START, YEAR_END + 1);
  const STACK_DATA = YEARS.map(y => {
    const row = { year: y };
    PARADIGMS.forEach(p => { row[p.id] = strengthAt(p.peaks, y); });
    return row;
  });

  const ACCENT    = '#b6604a';  // era-event accent (same brick as the Mackinder chokepoints)
  const ACCENT_DK = '#8a3e2e';

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:    css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    rule:     css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:      css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft:  css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint: css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purpleD:  css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
  };

  function currentLang() {
    const fhRoot = document.querySelector('.fh-root');
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  // Re-render on language toggle and resize.
  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => render())
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  window.addEventListener('resize', () => render());
  requestAnimationFrame(() => render());

  function render() {
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(render); return; }

    stage.innerHTML = '';

    const lang = currentLang();
    const isEn = lang === 'en';
    const serifFont = isEn
      ? '"Cormorant Garamond", Georgia, serif'
      : '"Noto Serif SC", "Songti SC", serif';
    const sansFont = 'Inter, "Noto Sans CJK", sans-serif';

    // ---- Font sizes (English bumped one step over Chinese) ----
    const fs = {
      title:        isEn ? 20 : 18,
      eraLabel:     isEn ? 12 : 11,
      editionLabel: isEn ? 13 : 11,
      yearAxis:     isEn ? 13 : 12,
      footer:       isEn ? 10 : 9,
      bandMin:      isEn ? 12 : 11,
      bandMax:      isEn ? 17 : 15,
      figuresMin:   isEn ? 10 :  9,
      figuresMax:   isEn ? 12 : 11,
    };

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block')
      .style('overflow', 'hidden');

    // Background
    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ---- Title strip ----
    svg.append('text')
      .attr('x', 24).attr('y', 28)
      .attr('font-family', serifFont).attr('font-size', fs.title).attr('font-style', 'italic')
      .attr('fill', c.purpleD).attr('letter-spacing', '0.16em')
      .text(isEn
        ? 'A century of Anglo-American human geography · 1925 → 2026'
        : '英美人文地理学的百年演变 · 1925 → 2026');

    // ---- Layout budget ----
    // Two thin rows above the streamgraph carry the era-event labels
    // (row 0 and row 1, staggered to avoid collisions). Below them sits
    // the edition-label strip. Edition guide lines were removed so the
    // only vertical temporal guides are the red era-event dashes.
    const padLeft   = 28;
    const padRight  = 28;
    const eraRow0Y  = 56;                  // upper era-label baseline
    const eraRow1Y  = 78;                  // lower era-label baseline
    const eraDotY   = 96;                  // dot row, both era rows tie down to this y
    const editionY  = 116;                 // edition label baseline
    const plotTop   = 128;                 // streamgraph top (edition lines start here)
    const plotBot   = H - 56;              // streamgraph bottom
    const axisY     = H - 40;              // year axis baseline
    const plotLeft  = padLeft;
    const plotRight = W - padRight;

    const x = d3.scaleLinear()
      .domain([YEAR_START, YEAR_END])
      .range([plotLeft, plotRight]);

    // ---- Stack / streamgraph ----
    const stack = d3.stack()
      .keys(PARADIGMS.map(p => p.id))
      .offset(d3.stackOffsetWiggle)
      .order(d3.stackOrderInsideOut);
    const layers = stack(STACK_DATA);

    const yMin = d3.min(layers, l => d3.min(l, d => d[0]));
    const yMax = d3.max(layers, l => d3.max(l, d => d[1]));
    const y = d3.scaleLinear()
      .domain([yMin, yMax])
      .range([plotBot, plotTop]);

    const area = d3.area()
      .x(d => x(d.data.year))
      .y0(d => y(d[0]))
      .y1(d => y(d[1]))
      .curve(d3.curveBasis);

    function clampTextX(textSelection, preferredX, inset = 8) {
      const node = textSelection.node();
      if (!node) return preferredX;
      let width = 0;
      try {
        width = node.getBBox().width;
      } catch {
        width = 0;
      }
      if (!width || width >= W - inset * 2) return Math.max(inset, Math.min(W - inset, preferredX));
      const half = width / 2;
      return Math.max(inset + half, Math.min(W - inset - half, preferredX));
    }

    function tokeniseLabel(text) {
      const spaced = text.replace(/\s+·\s+/g, ' · ');
      const parts = spaced.split(/\s+/).filter(Boolean);
      return parts.length > 1 ? parts : Array.from(text);
    }

    function wrapText(textSelection, text, maxWidth, lineHeightEm = 1.05) {
      const words = tokeniseLabel(text);
      textSelection.text(null);
      let line = [];
      let lineNumber = 0;
      let tspan = textSelection.append('tspan')
        .attr('x', textSelection.attr('x'))
        .attr('dy', '0em');

      words.forEach(word => {
        line.push(word);
        tspan.text(line.join(' '));
        const node = tspan.node();
        const tooWide = node && node.getComputedTextLength() > maxWidth;
        if (tooWide && line.length > 1) {
          line.pop();
          tspan.text(line.join(' '));
          line = [word];
          lineNumber += 1;
          tspan = textSelection.append('tspan')
            .attr('x', textSelection.attr('x'))
            .attr('dy', `${lineHeightEm}em`)
            .text(word);
        }
      });

      if (lineNumber > 0) {
        const tspans = textSelection.selectAll('tspan');
        tspans.attr('dy', (_, i) => i === 0 ? `${-lineNumber * lineHeightEm / 2}em` : `${lineHeightEm}em`);
      }
    }

    // ---- Era events (drawn first, so streamgraph sits over the guide lines) ----
    const eraG = svg.append('g').attr('class', 'gg-era');
    ERA_EVENTS.forEach(ev => {
      const xp = x(ev.year);
      const labelY = ev.row === 0 ? eraRow0Y : eraRow1Y;

      // Thin connector line from label to the dot row.
      eraG.append('line')
        .attr('x1', xp).attr('x2', xp)
        .attr('y1', labelY + 4).attr('y2', eraDotY - 4)
        .attr('stroke', ACCENT_DK)
        .attr('stroke-opacity', 0.45)
        .attr('stroke-width', 0.8);

      // Red dashed guide from the era-event dot to the bottom of the plot.
      eraG.append('line')
        .attr('x1', xp).attr('x2', xp)
        .attr('y1', eraDotY).attr('y2', plotBot)
        .attr('stroke', ACCENT_DK)
        .attr('stroke-opacity', 0.22)
        .attr('stroke-width', 0.9)
        .attr('stroke-dasharray', '3 5');

      // Brick dot at the dot row.
      eraG.append('circle')
        .attr('cx', xp).attr('cy', eraDotY)
        .attr('r', 4)
        .attr('fill', ACCENT)
        .attr('stroke', ACCENT_DK).attr('stroke-width', 1.2);

      // Year + label, stacked compactly above the dot.
      const eventLabel = eraG.append('text')
        .attr('x', xp).attr('y', labelY)
        .attr('text-anchor', 'middle')
        .attr('font-family', serifFont)
        .attr('font-size', fs.eraLabel)
        .attr('font-style', 'italic')
        .attr('fill', ACCENT_DK)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(`${ev.year}  ${ev.label[lang]}`);
      eventLabel.attr('x', clampTextX(eventLabel, xp, 8));
    });

    // ---- Edition labels (no guide lines) ----
    const editionG = svg.append('g').attr('class', 'gg-editions');
    EDITIONS.forEach(ed => {
      const xp = x(ed.year);
      const editionLabel = editionG.append('text')
        .attr('x', xp).attr('y', editionY)
        .attr('text-anchor', 'middle')
        .attr('font-family', serifFont)
        .attr('font-style', 'italic')
        .attr('font-size', fs.editionLabel)
        .attr('fill', c.purpleD)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(ed.note[lang]);
      editionLabel.attr('x', clampTextX(editionLabel, xp, 8));
    });

    // ---- Streamgraph layers ----
    const layerG = svg.append('g').attr('class', 'gg-layers');
    layers.forEach((layer, i) => {
      const p = PARADIGMS[i];
      layerG.append('path')
        .datum(layer)
        .attr('d', area)
        .attr('fill', p.color)
        .attr('fill-opacity', 0.86)
        .attr('stroke', '#fff8e5')
        .attr('stroke-opacity', 0.40)
        .attr('stroke-width', 0.6);
    });

    // ---- Inline band labels — every band gets one, even thin ones ----
    // Place the label at the year where the band is widest, vertically
    // centred in the band at that year. Where the band is thick enough,
    // also render a sans-serif sub-line with the representative figures.
    const labelG = svg.append('g').attr('class', 'gg-labels');
    const figuresThreshold = (yMax - yMin) * 0.045;
    layers.forEach((layer, i) => {
      const p = PARADIGMS[i];
      let bestYear = null;
      let bestThickness = 0;
      for (let j = 0; j < layer.length; j++) {
        const t = layer[j][1] - layer[j][0];
        if (t > bestThickness) {
          bestThickness = t;
          bestYear = layer[j].data.year;
        }
      }
      if (bestYear === null) return;
      const j = bestYear - YEAR_START;
      const cxp = x(bestYear);
      const cyp = y((layer[j][0] + layer[j][1]) / 2);
      const bandPx = Math.abs(y(layer[j][0]) - y(layer[j][1]));

      const showFigures = bandPx > 34;
      const labelSize   = Math.max(fs.bandMin, Math.min(fs.bandMax, bandPx * 0.22));
      const figuresSize = Math.max(fs.figuresMin, Math.min(fs.figuresMax, bandPx * 0.13));

      const labelDy   = showFigures ? -2 : 0;
      const figuresDy = labelSize * 0.65 + figuresSize * 0.55;

      const maxLabelWidth = Math.min(W - 18, Math.max(84, W * 0.48));
      const labelText = labelG.append('text')
        .attr('x', cxp).attr('y', cyp + labelDy)
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'middle')
        .attr('font-family', serifFont)
        .attr('font-style', 'italic')
        .attr('font-size', labelSize)
        .attr('font-weight', 500)
        .attr('fill', '#1d1a16')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(255,248,229,0.92)')
        .attr('stroke-width', 3.2)
        .attr('stroke-linejoin', 'round');
      wrapText(labelText, p.label[lang], maxLabelWidth, 1.02);
      const fittedX = clampTextX(labelText, cxp, 8);
      labelText.attr('x', fittedX);
      labelText.selectAll('tspan').attr('x', fittedX);

      if (showFigures) {
        const figuresText = labelG.append('text')
          .attr('x', fittedX).attr('y', cyp + labelDy + figuresDy)
          .attr('text-anchor', 'middle')
          .attr('dominant-baseline', 'middle')
          .attr('font-family', sansFont)
          .attr('font-size', figuresSize)
          .attr('font-weight', 400)
          .attr('fill', 'rgba(15,12,8,0.78)')
          .attr('paint-order', 'stroke')
          .attr('stroke', 'rgba(255,248,229,0.85)')
          .attr('stroke-width', 2.4)
          .attr('stroke-linejoin', 'round');
        wrapText(figuresText, p.figures[lang], maxLabelWidth, 1.05);
        const fittedFiguresX = clampTextX(figuresText, fittedX, 8);
        figuresText.attr('x', fittedFiguresX);
        figuresText.selectAll('tspan').attr('x', fittedFiguresX);
      }
    });

    // ---- Year axis ----
    const yearTicks = [1925, 1945, 1965, 1985, 2005, 2026];
    const axisG = svg.append('g').attr('class', 'gg-axis');
    axisG.append('line')
      .attr('x1', plotLeft).attr('x2', plotRight)
      .attr('y1', plotBot + 2).attr('y2', plotBot + 2)
      .attr('stroke', c.rule).attr('stroke-width', 1);
    yearTicks.forEach(yr => {
      const xp = x(yr);
      axisG.append('line')
        .attr('x1', xp).attr('x2', xp)
        .attr('y1', plotBot + 2).attr('y2', plotBot + 8)
        .attr('stroke', c.inkSoft).attr('stroke-width', 0.8);
      axisG.append('text')
        .attr('x', xp).attr('y', axisY)
        .attr('text-anchor', 'middle')
        .attr('font-family', serifFont)
        .attr('font-size', fs.yearAxis)
        .attr('fill', c.inkSoft)
        .text(yr);
    });

    // Footer credit
    svg.append('text')
      .attr('x', 12).attr('y', H - 8)
      .attr('text-anchor', 'start')
      .attr('font-family', serifFont).attr('font-size', fs.footer).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text(isEn
        ? 'after Johnston (1979–) and Johnston & Sidaway (2004–) · weights are editorial, not bibliometric'
        : '依据 Johnston（1979 起）与 Johnston & Sidaway（2004 起） · 强度为编辑判断，非文献计量');
  }
</script>
