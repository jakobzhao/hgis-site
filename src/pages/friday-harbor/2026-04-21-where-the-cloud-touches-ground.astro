    { id: 'wa',      name: { en: 'Quincy, WA',          zh: '昆西' },              lon: -119.85, lat: 47.23, cap: 700,  side: 'right' },
    { id: 'reno',    name: { en: 'Reno, NV',            zh: '里诺' },              lon: -119.81, lat: 39.53, cap: 600,  side: 'left'  },
    { id: 'slc',     name: { en: 'Salt Lake City',      zh: '盐湖城' },            lon: -111.89, lat: 40.76, cap: 300,  side: 'right' },

    // 2025–2026 additions — the new wave of multi-GW AI campuses
    { id: 'memphis', name: { en: 'Memphis, TN',         zh: '孟菲斯' },            lon: -90.05,  lat: 35.15, cap: 2000, side: 'right' }, // xAI Colossus 1+2+3
    { id: 'abilene', name: { en: 'Abilene, TX',         zh: '阿比林' },            lon: -99.73,  lat: 32.45, cap: 1200, side: 'left'  }, // Stargate / Crusoe / MSFT
    { id: 'rainier', name: { en: 'New Carlisle, IN',    zh: '新卡莱尔' },          lon: -86.36,  lat: 41.70, cap: 1500, side: 'right' }, // AWS Project Rainier ↔ Anthropic
    { id: 'la',      name: { en: 'Richland Parish, LA', zh: 'Richland 教区' },     lon: -91.74,  lat: 32.40, cap: 1000, side: 'right' }, // Meta Hyperion
    { id: 'cb',      name: { en: 'Council Bluffs, IA',  zh: '康瑟尔布拉夫斯' },    lon: -95.86,  lat: 41.26, cap: 900,  side: 'left'  }, // Google + Meta
    { id: 'wisc',    name: { en: 'Mt. Pleasant, WI',    zh: 'Mt. Pleasant' },      lon: -87.91,  lat: 42.72, cap: 400,  side: 'right' }, // MSFT Fairwater
    { id: 'cheyen',  name: { en: 'Cheyenne, WY',        zh: '夏延' },              lon: -104.82, lat: 41.14, cap: 500,  side: 'left'  }  // MSFT + Meta
  ];

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    paper2:  css.getPropertyValue('--bg-deep').trim()   || '#ddd4c2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
    sage:    css.getPropertyValue('--sage').trim()      || '#8e9c8a',
    sageS:   css.getPropertyValue('--sage-soft').trim() || '#b4bdaf',
    rose:    css.getPropertyValue('--rose').trim()      || '#c2a094',
    mist:    css.getPropertyValue('--mist').trim()      || '#a8b1b3',
  };
  const EVENT_DEEP = '#8a3e2e';

  let _states = null;
  fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json')
    .then(r => r.json())
    .then(us => {
      _states = feature(us, us.objects.states);
      requestAnimationFrame(() => draw());
    });

  window.addEventListener('resize', () => { if (_states) draw(); });

  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => { if (_states) draw(); })
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  function currentLang() {
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  function draw() {
    const states = _states;
    if (!states) return;
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(() => draw()); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const padL = 14, padR = 14, padT = 16, padB = 60;
    const mapW = W - padL - padR;
    const mapH = H - padT - padB;

    const projection = d3.geoAlbersUsa()
      .fitSize([mapW, mapH], states)
      .translate([padL + mapW / 2, padT + mapH / 2]);
    const path = d3.geoPath(projection);

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block')
      .style('overflow', 'hidden');

    // Background paper
    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // States base — warm putty
    svg.append('path').datum(states).attr('d', path)
      .attr('fill', c.paper2).attr('stroke', 'none');

    // ----- Climate zones (two polygons clipped to US states) -----
    // The previous single-gradient wash didn't read clearly because warm-on-
    // warm has limited contrast. Now: a chestnut polygon over the arid West
    // AND a sage polygon over the humid East, so the page actually splits
    // into two climate halves.
    svg.append('defs').append('clipPath').attr('id', 'us-states-clip')
      .append('path').datum(states).attr('d', path);
    const climateG = svg.append('g').attr('clip-path', 'url(#us-states-clip)');

    // Arid Southwest polygon — coast of SoCal up the eastern slope of the
    // Cascades, across MT/WY, down through the Plains/TX panhandle to S NM
    // and back along the AZ/CA border.
    const aridZone = {
      type: 'Polygon',
      coordinates: [[
        [-124, 32], [-124, 38], [-122, 42], [-120, 49],
        [-104, 49], [-104, 36], [-103, 31], [-110, 28],
        [-115, 31], [-122, 32], [-124, 32]
      ]]
    };
    climateG.append('path').datum(aridZone).attr('d', path)
      .attr('fill', '#c9a874').attr('fill-opacity', 0.55)
      .attr('stroke', 'none');

    // Humid East polygon — rough Mississippi-east-coast box.
    const humidZone = {
      type: 'Polygon',
      coordinates: [[
        [-95, 25], [-95, 49], [-67, 49], [-67, 25], [-95, 25]
      ]]
    };
    climateG.append('path').datum(humidZone).attr('d', path)
      .attr('fill', '#9bb098').attr('fill-opacity', 0.42)
      .attr('stroke', 'none');

    // State borders on top of climate zones
    svg.append('path').datum(states).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.45)
      .attr('stroke-width', 0.5)
      .attr('stroke-linejoin', 'round');

    // ----- Climate-zone floating labels -----
    const climateSerif = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';
    const climateLabels = [
      { lonLat: [-110, 36],  text: lang === 'zh' ? '干旱的西南' : 'Arid Southwest' },
      { lonLat: [-86,  37],  text: lang === 'zh' ? '湿润的东部' : 'Humid East' }
    ];
    climateLabels.forEach(({ lonLat, text }) => {
      const p = projection(lonLat);
      if (!p) return;
      svg.append('text').attr('x', p[0]).attr('y', p[1])
        .attr('fill', c.purpleD).attr('fill-opacity', 0.6)
        .attr('font-style', 'italic')
        .attr('font-family', climateSerif)
        .attr('font-size', 14).attr('letter-spacing', '0.30em')
        .attr('text-anchor', 'middle')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.85)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(text);
    });

    // ----- Cluster proportional symbols -----
    const maxCap = d3.max(CLUSTERS, d => d.cap);
    const rScale = d3.scaleSqrt().domain([0, maxCap]).range([0, 32]);

    // halos under everything
    const haloG = svg.append('g').attr('class', 'fh-cloud-halos');
    CLUSTERS.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.cap);
      haloG.append('circle').attr('cx', p[0]).attr('cy', p[1])
        .attr('r', r + 4).attr('fill', c.rose).attr('fill-opacity', 0.30);
    });

    // dots
    const dotG = svg.append('g').attr('class', 'fh-cloud-dots');
    CLUSTERS.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.cap);
      const g = dotG.append('g').attr('transform', `translate(${p[0]},${p[1]})`);
      g.append('circle').attr('r', r).attr('fill', EVENT_DEEP).attr('fill-opacity', 0.78)
        .attr('stroke', c.paper).attr('stroke-width', 1.2);
      if (d.anchor) {
        // Loudoun gets an extra slow pulsing ring
        const outer = g.append('circle').attr('r', r + 8).attr('fill', 'none')
          .attr('stroke', EVENT_DEEP).attr('stroke-opacity', 0.55).attr('stroke-width', 1.5);
        outer.append('animate').attr('attributeName', 'r')
          .attr('values', `${r + 6};${r + 16};${r + 6}`).attr('dur', '3.2s').attr('repeatCount', 'indefinite');
        outer.append('animate').attr('attributeName', 'stroke-opacity')
          .attr('values', '0.65;0.10;0.65').attr('dur', '3.2s').attr('repeatCount', 'indefinite');
      }
    });

    // labels — placed left or right of each dot per side hint
    const labelG = svg.append('g').attr('class', 'fh-cloud-labels');
    CLUSTERS.forEach(d => {
      const p = projection([d.lon, d.lat]);
      if (!p) return;
      const r = rScale(d.cap);
      const isRight = d.side !== 'left';
      const x = p[0] + (isRight ? r + 7 : -r - 7);
      const y = p[1] + 4;
      labelG.append('text')
        .attr('x', x).attr('y', y)
        .attr('text-anchor', isRight ? 'start' : 'end')
        .attr('fill', c.ink)
        .attr('font-size', d.anchor ? 13 : 11)
        .attr('font-weight', d.anchor ? 700 : 600)
        .attr('font-family', 'Inter, "Noto Sans CJK", sans-serif')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3.5)
        .attr('stroke-linejoin', 'round')
        .text(d.name[lang]);
    });

    // ----- Capacity legend (bottom-left of map area) -----
    const legendCaps = [500, 1500, 3500];
    const legX = padL + 24;
    const legY = padT + mapH - 8;
    const legG = svg.append('g').attr('transform', `translate(${legX},${legY})`);
    legG.append('text').attr('x', 0).attr('y', -54)
      .attr('font-size', 11).attr('fill', c.inkSoft)
      .attr('font-style', 'italic')
      .attr('font-family', lang === 'zh'
        ? '"Noto Serif SC", "Songti SC", serif'
        : '"Cormorant Garamond", Georgia, serif')
      .text(lang === 'zh' ? '估算运行容量（兆瓦）' : 'estimated capacity (MW)');
    legendCaps.forEach((cap, i) => {
      const r = rScale(cap);
      const x = i * 78;
      legG.append('circle').attr('cx', x).attr('cy', -22).attr('r', r)
        .attr('fill', 'none').attr('stroke', c.inkSoft).attr('stroke-width', 0.9);
      legG.append('text').attr('x', x).attr('y', -22 + r + 14)
        .attr('text-anchor', 'middle').attr('font-size', 10)
        .attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
        .text(`${cap}`);
    });

    // ----- Climate legend (two squares matching the polygon colours) -----
    const aridSwX = padL + mapW - 240;
    const aridSwY = padT + mapH - 28;
    const aridSwG = svg.append('g').attr('transform', `translate(${aridSwX},${aridSwY})`);
    // Arid swatch
    aridSwG.append('rect').attr('x', 0).attr('y', 0).attr('width', 14).attr('height', 14)
      .attr('fill', '#c9a874').attr('fill-opacity', 0.78)
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.4).attr('stroke-width', 0.5);
    aridSwG.append('text').attr('x', 20).attr('y', 11)
      .attr('font-size', 10).attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
      .text(lang === 'zh' ? '干旱 / 水资源紧张' : 'arid · water-stressed');
    // Humid swatch (next to arid)
    const humidOffsetX = lang === 'zh' ? 138 : 152;
    aridSwG.append('rect').attr('x', humidOffsetX).attr('y', 0).attr('width', 14).attr('height', 14)
      .attr('fill', '#9bb098').attr('fill-opacity', 0.78)
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.4).attr('stroke-width', 0.5);
    aridSwG.append('text').attr('x', humidOffsetX + 20).attr('y', 11)
      .attr('font-size', 10).attr('fill', c.inkSoft).attr('font-family', 'Inter, sans-serif')
      .text(lang === 'zh' ? '湿润' : 'humid');
  }
</script>
