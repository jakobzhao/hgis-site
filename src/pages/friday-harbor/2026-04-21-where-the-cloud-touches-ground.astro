  import { feature } from 'https://esm.sh/topojson-client@3';

  // Major US AI / hyperscaler data-center clusters, snapshot ~Q2 2026.
  // Capacity (MW) is illustrative and reflects operating + near-term-online
  // capacity; operators rarely publish exact figures so values are
  // reconstructed from public filings and trade-press coverage.
  const CLUSTERS = [
    // The original 11 — capacities updated to reflect 2025–26 build-out
    { id: 'loudoun', name: { en: 'Loudoun Co., VA',     zh: 'Loudoun 县' },       lon: -77.55,  lat: 39.05, cap: 3800, anchor: true,  side: 'right' },
    { id: 'phoenix', name: { en: 'Phoenix metro',       zh: '凤凰城' },            lon: -111.95, lat: 33.45, cap: 1400, side: 'right' },
