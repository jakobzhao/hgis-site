---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { entries, UI } from '../../data/friday-harbor';

const sorted = [...entries].sort((a, b) => b.date.localeCompare(a.date));
const total = sorted.length;
---
<BaseLayout
  title="Friday Harbor"
  description="A cartographer's notebook from the Humanistic GIS Lab."
>
  <div class="fh-root" data-lang="en">
    <section class="fh-index">
      <header class="fh-index-mast">
        <h1>
          <em><span data-lang="en">{UI.rubric.en}</span><span data-lang="zh">{UI.rubric.zh}</span></em>
        </h1>
        <div class="manifesto-wrap">
          <p class="manifesto">
            <span data-lang="en">{UI.manifesto.en}</span>
            <span data-lang="zh">{UI.manifesto.zh}</span>
          </p>
          <button class="fh-lang-toggle" type="button" aria-label="switch language">
            <span data-lang="en">中文</span><span data-lang="zh">EN</span>
          </button>
        </div>
      </header>

      <ol class="fh-list">
        {sorted.map((e, i) => {
          const dt = new Date(e.date + 'T00:00:00');
          const dlEn = dt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          const dlZh = dt.toLocaleDateString('zh-CN', { month: 'long', day: 'numeric', year: 'numeric' });
          const wdEn = dt.toLocaleDateString('en-US', { weekday: 'short' });
          const wdZh = dt.toLocaleDateString('zh-CN', { weekday: 'short' });
          const num = String(total - i).padStart(3, '0');
          return (
            <li class="fh-row">
              <a href={`/friday-harbor/${e.slug}/`} class="fh-row-link">
                <div class="fh-row-thumb"
                     data-fh-thumb={e.thumb ? JSON.stringify(e.thumb) : null}>
                  <!-- The mini-map renders into here at runtime. -->
                </div>
                <div class="fh-row-text">
                  <div class="fh-row-meta">
                    <span class="fh-no">№ {num}</span>
                    <span class="fh-date">
                      <b data-lang="en">{wdEn}</b><b data-lang="zh">{wdZh}</b>
                      <span data-lang="en"> {dlEn}</span><span data-lang="zh"> {dlZh}</span>
                    </span>
                    <span class="fh-place">
                      <span data-lang="en">{e.place.en}</span>
                      <span data-lang="zh">{e.place.zh}</span>
                    </span>
                  </div>
                  <h2>
                    <span data-lang="en">{e.title.en}</span>
                    <span data-lang="zh">{e.title.zh}</span>
                  </h2>
                  <p class="fh-row-lede">
                    <span data-lang="en">{e.subtitle.en}</span>
                    <span data-lang="zh">{e.subtitle.zh}</span>
                  </p>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .fh-root[data-lang="en"] [data-lang="zh"] { display: none !important; }
  .fh-root[data-lang="zh"] [data-lang="en"] { display: none !important; }
  .fh-root[data-lang="zh"] {
    --serif: "Cormorant Garamond", "Noto Serif SC", "Songti SC", "STSong", Georgia, serif;
  }
</style>

<style>
  .fh-index {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.75rem 5rem;
  }
  .fh-index-mast {
    padding: 0.4rem 0 1.4rem 0;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2rem;
    align-items: end;
  }
  .fh-index-mast h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 3.2rem;
    line-height: 1;
    margin: 0;
    letter-spacing: -0.012em;
  }
  .fh-index-mast h1 em {
    font-style: italic;
    color: var(--uw-purple);
  }
  .manifesto-wrap {
    display: flex; flex-direction: column; gap: 0.9rem; align-items: flex-start;
  }
  .manifesto {
    font-family: var(--serif);
    font-style: italic;
    line-height: 1.65;
    color: var(--ink);
    margin: 0;
    font-size: 1.02rem;
  }
  .fh-lang-toggle {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    font-family: inherit;
    align-self: flex-end;
  }
  .fh-lang-toggle:hover { border-color: var(--uw-purple); color: var(--uw-purple); }

  .fh-list { list-style: none; padding: 0; margin: 1.6rem 0 0; }
  .fh-row { border-bottom: 1px solid var(--rule); }
  .fh-row-link {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.6rem;
    padding: 1.6rem 0;
    color: var(--ink);
    border-bottom: 0;
    align-items: start;
  }
  .fh-row-link:hover { background: var(--bg-card, #f6f3ed); border-bottom: 0; }
  .fh-row-link:hover h2 { color: var(--uw-purple); }

  .fh-row-thumb {
    width: 280px;
    aspect-ratio: 5 / 3;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .fh-row-thumb svg { display: block; width: 100%; height: 100%; }

  .fh-row-meta {
    display: flex; gap: 1rem; align-items: baseline;
    margin-bottom: 0.55rem;
    font-size: 0.78rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }
  .fh-row-meta .fh-place { margin-left: auto; }
  .fh-no {
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    font-family: var(--serif);
  }
  .fh-date {
    font-size: 0.85rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }
  .fh-date b { font-weight: 600; color: var(--ink); }
  .fh-row-text h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.7rem;
    margin: 0 0 0.4rem;
    line-height: 1.15;
    letter-spacing: -0.005em;
  }
  .fh-row-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-faint);
    margin: 0 0 0.7rem;
    max-width: 640px;
  }
  .fh-place {
    font-size: 0.78rem;
    color: var(--ink-faint);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .fh-index-mast { grid-template-columns: 1fr; gap: 1rem; }
    .fh-row-link { grid-template-columns: 1fr; gap: 0.9rem; }
    .fh-row-thumb { width: 100%; }
    .fh-place { margin-left: 0; }
  }
</style>

<script type="module">
  // Live mini-map thumbnails for each entry card. The land geometry is
  // fetched once and reused across all cards.
  import * as d3 from 'https://esm.sh/d3@7';

  const NE = 'https://cdn.jsdelivr.net/gh/martynafford/natural-earth-geojson@master/10m';
  const els = Array.from(document.querySelectorAll('[data-fh-thumb]'))
    .filter(el => el.dataset.fhThumb);
  if (els.length) {
    fetch(`${NE}/physical/ne_10m_land.json`)
      .then(r => r.json())
      .then(land => els.forEach(el => render(el, land)))
      .catch(() => { /* leave the placeholder card if Natural Earth is down */ });
  }

  function render(el, land) {
    const data = JSON.parse(el.dataset.fhThumb);
    const w = el.clientWidth || 280;
    const h = el.clientHeight || 168;
    const { bbox, pins = [] } = data;

    const lon0 = (bbox.west + bbox.east) / 2;
    const lat0 = (bbox.south + bbox.north) / 2;
    const yProj = lat => Math.log(Math.tan(Math.PI/4 + lat * Math.PI/360));
    const lonSpan = (bbox.east - bbox.west) * Math.PI / 180;
    const ySpan   = yProj(bbox.north) - yProj(bbox.south);
    const scale = Math.min(w / lonSpan, h / ySpan) * 0.97;

    const projection = d3.geoMercator()
      .center([lon0, lat0])
      .scale(scale)
      .translate([w / 2, h / 2])
      .clipExtent([[0, 0], [w, h]])
      .precision(0.5);
    const path = d3.geoPath(projection);

    el.innerHTML = '';
    const svg = d3.select(el).append('svg')
      .attr('viewBox', `0 0 ${w} ${h}`)
      .attr('preserveAspectRatio', 'xMidYMid meet')
      .style('display', 'block');

    // Sea — same Morandi mist gradient as the main map
    const gid = `tg-${Math.random().toString(36).slice(2, 8)}`;
    const grad = svg.append('defs').append('linearGradient')
      .attr('id', gid)
      .attr('gradientUnits', 'userSpaceOnUse')
      .attr('x1', w / 2).attr('y1', 0)
      .attr('x2', w / 2).attr('y2', h);
    grad.append('stop').attr('offset', '0%').attr('stop-color', '#d2d8d6');
    grad.append('stop').attr('offset', '55%').attr('stop-color', '#bcc4c4');
    grad.append('stop').attr('offset', '100%').attr('stop-color', '#a8b1b3');
    svg.append('rect').attr('width', w).attr('height', h).attr('fill', `url(#${gid})`);

    // Coastal halo (sage soft)
    svg.append('path').datum(land).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#b4bdaf').attr('stroke-opacity', 0.55)
      .attr('stroke-width', 4);

    // Land — paper cream
    svg.append('path').datum(land).attr('d', path)
      .attr('fill', '#f5efe2')
      .attr('stroke', '#6c6358').attr('stroke-width', 0.6)
      .attr('stroke-linejoin', 'round');

    // Pin halos + dots (deep terracotta)
    pins.forEach(p => {
      const xy = projection([p.lon, p.lat]);
      if (!xy) return;
      svg.append('circle').attr('cx', xy[0]).attr('cy', xy[1])
        .attr('r', 9).attr('fill', '#c2a094').attr('fill-opacity', 0.45);
      svg.append('circle').attr('cx', xy[0]).attr('cy', xy[1])
        .attr('r', 3.5).attr('fill', '#8a3e2e');
    });
  }
</script>

<script is:inline>
  (function () {
    const root = document.querySelector('.fh-root');
    if (!root) return;
    let lang = 'en';
    try { lang = localStorage.getItem('fh-lang') || 'en'; } catch (e) {}
    if (lang !== 'en' && lang !== 'zh') lang = 'en';
    root.setAttribute('data-lang', lang);
    const btn = root.querySelector('.fh-lang-toggle');
    if (btn) btn.addEventListener('click', () => {
      const next = root.getAttribute('data-lang') === 'en' ? 'zh' : 'en';
      root.setAttribute('data-lang', next);
      try { localStorage.setItem('fh-lang', next); } catch (e) {}
    });
  })();
</script>
