---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { entries, UI } from '../../data/friday-harbor';

const sorted = [...entries].sort((a, b) => b.date.localeCompare(a.date));
const total = sorted.length;

// Cover story = the most recent entry. The rest of the list — the
// "archive" — renders below the cover with the toolbar.
const cover = sorted[0];
const archive = sorted.slice(1);

// Issue number for the cover story = chronological position in the
// registry (oldest = 001), matching the per-entry rule used in the
// FridayHarborLayout. The cover is the latest, so its number is `total`.
const coverIssueNo = String(total).padStart(3, '0');
const coverDt = new Date(cover.date + 'T00:00:00');
const coverDateEn = coverDt.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
const coverDateZh = coverDt.toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Friday Harbor"
  description="A cartographer's notebook from the Humanistic GIS Lab."
>
  <div class="fh-root" data-lang="en">
    <section class="fh-index">
      <header class="fh-flag">
        <h1 class="fh-flag-name">
          <span data-lang="en">{UI.rubric.en}</span><span data-lang="zh">{UI.rubric.zh}</span>
        </h1>
        <div class="fh-flag-manifesto">
          <p class="manifesto" data-lang="en">{UI.manifestoTop.en}</p>
          <p class="manifesto" data-lang="zh">{UI.manifestoTop.zh}</p>
        </div>
      </header>

      {/* ---- COVER STORY ---- */}
      <article class="fh-cover">
        <a href={`/friday-harbor/${cover.slug}/`} class="fh-cover-link">
          <div class="fh-cover-thumb"
               data-fh-thumb={cover.thumb ? JSON.stringify(cover.thumb) : null}>
            <p class="fh-cover-loading">
              <span data-lang="en">Loading map…</span>
              <span data-lang="zh">地图加载中…</span>
            </p>
          </div>
          <div class="fh-cover-text">
            <span class="fh-cover-kicker">
              <span data-lang="en">{UI.coverStory.en}</span>
              <span data-lang="zh">{UI.coverStory.zh}</span>
              <span class="fh-cover-no">№ {coverIssueNo}</span>
            </span>
            <h2 class="fh-cover-title">
              <span data-lang="en">{cover.title.en}</span>
              <span data-lang="zh">{cover.title.zh}</span>
            </h2>
            <p class="fh-cover-lede">
              <span data-lang="en">{cover.subtitle.en}</span>
              <span data-lang="zh">{cover.subtitle.zh}</span>
            </p>
            <p class="fh-cover-place">
              <span data-lang="en">{cover.place.en}</span>
              <span data-lang="zh">{cover.place.zh}</span>
            </p>
            <span class="fh-cover-cta">
              <span data-lang="en">{UI.readThis.en}</span>
              <span data-lang="zh">{UI.readThis.zh}</span>
            </span>
          </div>
        </a>
      </article>

      {/* ---- ARCHIVE ---- */}
      <div class="fh-toolbar" role="search" aria-label="search, sort, and language">
        <h3 class="fh-archive-head">
          <span data-lang="en">{UI.fromArchive.en}</span>
          <span data-lang="zh">{UI.fromArchive.zh}</span>
        </h3>
        <label class="fh-search">
          <span class="fh-search-icon" aria-hidden="true">⌕</span>
          <input
            type="search"
            id="fh-q"
            class="fh-search-input"
            autocomplete="off"
            spellcheck="false"
            data-ph-en={UI.searchPlaceholder.en}
            data-ph-zh={UI.searchPlaceholder.zh}
            aria-label="search"
          />
        </label>
        <div class="fh-sort">
          <span class="fh-sort-label">
            <span data-lang="en">{UI.sortLabel.en}</span><span data-lang="zh">{UI.sortLabel.zh}</span>
          </span>
          <button type="button" class="fh-sort-btn is-active" data-sort="newest" aria-pressed="true">
            <span data-lang="en">{UI.sortNewest.en}</span><span data-lang="zh">{UI.sortNewest.zh}</span>
          </button>
          <button type="button" class="fh-sort-btn" data-sort="oldest" aria-pressed="false">
            <span data-lang="en">{UI.sortOldest.en}</span><span data-lang="zh">{UI.sortOldest.zh}</span>
          </button>
          <button type="button" class="fh-sort-btn" data-sort="az" aria-pressed="false">
            <span data-lang="en">{UI.sortAZ.en}</span><span data-lang="zh">{UI.sortAZ.zh}</span>
          </button>
        </div>
        <div class="fh-lang-switch" role="group" aria-label="language">
          <button type="button" class="fh-lang-btn" data-lang-set="en" aria-label="English">EN</button>
          <button type="button" class="fh-lang-btn" data-lang-set="zh" aria-label="中文">中</button>
        </div>
        <p class="fh-search-status" id="fh-status" aria-live="polite"></p>
      </div>

      <ol class="fh-list" id="fh-list">
        {archive.map((e, i) => {
          const dt = new Date(e.date + 'T00:00:00');
          const dlEn = dt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
          const dlZh = dt.toLocaleDateString('zh-CN', { month: 'long', day: 'numeric', year: 'numeric' });
          const wdEn = dt.toLocaleDateString('en-US', { weekday: 'short' });
          const wdZh = dt.toLocaleDateString('zh-CN', { weekday: 'short' });
          // Archive numbering continues *down* from the cover. Cover = total,
          // first archive row = total - 1, etc. (i is 0-based within archive)
          const num = String(total - 1 - i).padStart(3, '0');
          // Pre-built searchable haystack (lower-cased) — JS reads
          // this attribute instead of walking the DOM each keystroke.
          const haystack = [
            e.title.en, e.title.zh, e.subtitle.en, e.subtitle.zh,
            e.place.en, e.place.zh,
            ...e.techniques,
          ].join('   ').toLowerCase();
          return (
            <li class="fh-row"
                data-date={e.date}
                data-title-en={e.title.en.toLowerCase()}
                data-title-zh={e.title.zh}
                data-search={haystack}>
              <a href={`/friday-harbor/${e.slug}/`} class="fh-row-link">
                <div class="fh-row-thumb"
                     data-fh-thumb={e.thumb ? JSON.stringify(e.thumb) : null}>
                  <!-- The mini-map renders into here at runtime. -->
                </div>
                <div class="fh-row-text">
                  <div class="fh-row-meta">
                    <span class="fh-no">№ {num}</span>
                    <span class="fh-date">
                      <b data-lang="en">{wdEn}</b><b data-lang="zh">{wdZh}</b>
                      <span data-lang="en"> {dlEn}</span><span data-lang="zh"> {dlZh}</span>
                    </span>
                    <span class="fh-place">
                      <span data-lang="en">{e.place.en}</span>
                      <span data-lang="zh">{e.place.zh}</span>
                    </span>
                  </div>
                  <h2>
                    <span data-lang="en">{e.title.en}</span>
                    <span data-lang="zh">{e.title.zh}</span>
                  </h2>
                  <p class="fh-row-lede">
                    <span data-lang="en">{e.subtitle.en}</span>
                    <span data-lang="zh">{e.subtitle.zh}</span>
                  </p>
                </div>
              </a>
            </li>
          );
        })}
      </ol>

      <div class="fh-list-more" id="fh-more">
        <button type="button" class="fh-show-all" id="fh-show-all">
          <span data-lang="en" data-tpl={UI.showAll.en}></span>
          <span data-lang="zh" data-tpl={UI.showAll.zh}></span>
        </button>
        <button type="button" class="fh-show-fewer" id="fh-show-fewer" hidden>
          <span data-lang="en">{UI.showFewer.en}</span>
          <span data-lang="zh">{UI.showFewer.zh}</span>
        </button>
      </div>
      <p class="fh-empty" id="fh-empty" hidden>
        <span data-lang="en">{UI.noMatches.en}</span>
        <span data-lang="zh">{UI.noMatches.zh}</span>
      </p>

      <footer class="fh-index-foot">
        <p class="fh-foot-explainer" data-lang="en">{UI.manifestoBottom.en}</p>
        <p class="fh-foot-explainer" data-lang="zh">{UI.manifestoBottom.zh}</p>
      </footer>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .fh-root[data-lang="en"] [data-lang="zh"] { display: none !important; }
  .fh-root[data-lang="zh"] [data-lang="en"] { display: none !important; }
  .fh-root[data-lang="zh"] {
    --serif: "Cormorant Garamond", "Noto Serif SC", "Songti SC", "STSong", Georgia, serif;
    --zh-display: "Kaiti SC", "STKaiti", "Kaiti", KaiTi, "Noto Serif SC", serif;
  }
  /* Index cards: extend the column register used inside each entry
     to the headings here, so the whole rubric reads as a literary
     column rather than a journal index. */
  .fh-root[data-lang="zh"] .fh-row-text h2,
  .fh-root[data-lang="zh"] .manifesto {
    font-family: var(--zh-display);
    font-style: normal;
    letter-spacing: 0.02em;
  }
  .fh-root[data-lang="zh"] .fh-row-lede {
    font-family: "Noto Serif SC", "Songti SC", "STSong", serif;
    font-style: normal;
    font-weight: 300;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }
</style>

<style>
  .fh-index {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.75rem 5rem;
  }

  /* ---- Masthead -------------------------------------------------
     Stripped lockup: just the wordmark + strapline + manifesto. The
     site header above already carries the publisher info, so we don't
     restate it here. The wordmark uses the same upright Cormorant
     register as the per-article titles (compare `.fh-title` in
     FridayHarborLayout) so the column reads as a single typographic
     family — the only difference is the purple. */
  .fh-flag {
    text-align: center;
    padding: 0.4rem 0 1.6rem;
  }
  .fh-flag-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(3.6rem, 9vw, 6.4rem);
    line-height: 0.95;
    margin: 0 0 0.3rem;
    letter-spacing: -0.012em;
    color: var(--uw-purple);
  }
  /* Chinese flag uses Kaiti for the calligraphic editorial register. */
  .fh-flag-name :global([data-lang="zh"]) {
    font-family: "Kaiti SC", "STKaiti", "Kaiti", KaiTi, "Noto Serif SC", serif;
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  .fh-flag-manifesto { max-width: 720px; margin: 1rem auto 0; }
  .manifesto {
    font-family: var(--serif);
    font-style: italic;
    line-height: 1.65;
    color: var(--ink);
    font-size: 1rem;
    margin: 0;
    text-align: left;
  }
  .fh-root[data-lang="zh"] .manifesto { text-align: justify; }

  /* ---- Cover story -----------------------------------------------
     One hero block per issue: large mini-map on the left, oversized
     title + lede on the right, with a kicker that reads "COVER STORY ·
     № 005" so the reader knows the editorial weight. The whole block
     is one anchor — clicking anywhere goes to the entry. */
  .fh-cover {
    margin: 1.4rem 0 2rem;
    padding: 1.6rem 0 1.8rem;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--rule);
  }
  .fh-cover-link {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2rem;
    color: var(--ink);
    border-bottom: 0;
    align-items: center;
  }
  .fh-cover-link:hover { border-bottom: 0; }
  .fh-cover-link:hover .fh-cover-title { color: var(--uw-purple); }
  .fh-cover-link:hover .fh-cover-cta { color: var(--uw-purple-deep); }
  .fh-cover-thumb {
    width: 100%;
    aspect-ratio: 5 / 3;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 6px 24px rgba(50, 42, 38, 0.10);
  }
  .fh-cover-thumb svg { display: block; width: 100%; height: 100%; }
  .fh-cover-loading {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: var(--ink-faint); font-style: italic; font-family: var(--serif);
    margin: 0;
  }
  .fh-cover-text { display: flex; flex-direction: column; gap: 0.6rem; }
  .fh-cover-kicker {
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--uw-gold);
    font-weight: 600;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .fh-root[data-lang="zh"] .fh-cover-kicker {
    text-transform: none;
    letter-spacing: 0.1em;
    font-size: 0.82rem;
  }
  .fh-cover-no {
    color: var(--ink-faint);
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.06em;
  }
  .fh-cover-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2rem, 3.6vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.012em;
    margin: 0.2rem 0 0.3rem;
    transition: color 0.18s ease;
  }
  .fh-root[data-lang="zh"] .fh-cover-title {
    font-family: var(--zh-display);
    letter-spacing: 0.02em;
  }
  .fh-cover-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }
  .fh-root[data-lang="zh"] .fh-cover-lede {
    font-family: "Noto Serif SC", "Songti SC", serif;
    font-style: normal;
    font-weight: 300;
  }
  .fh-cover-place {
    font-size: 0.78rem;
    color: var(--ink-faint);
    font-style: italic;
    margin: 0.3rem 0 0;
  }
  .fh-cover-cta {
    margin-top: 0.7rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--uw-purple);
    letter-spacing: 0.02em;
    transition: color 0.18s ease;
  }

  /* ---- Archive section header ------------------------------------
     Inline label that sits in the leftmost cell of the toolbar grid,
     so "From the archive · [search] [sort] [lang]" reads as one row.
     No top/bottom rules of its own — the toolbar's own border-bottom
     is the only horizontal rule under this band. */
  .fh-archive-head {
    margin: 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink-soft, #6c6358);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .fh-root[data-lang="zh"] .fh-archive-head {
    font-family: var(--zh-display);
    font-style: normal;
    letter-spacing: 0.1em;
  }

  /* ---- Toolbar: archive label + search + sort + language ---------- */
  .fh-toolbar {
    display: grid;
    grid-template-columns: auto minmax(220px, 1fr) auto auto;
    gap: 0.9rem 1.2rem;
    align-items: center;
    margin: 1.6rem 0 0.4rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--rule);
  }
  .fh-search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .fh-search-icon {
    position: absolute;
    left: 12px;
    color: var(--ink-faint);
    font-size: 1.1rem;
    pointer-events: none;
  }
  .fh-search-input {
    width: 100%;
    border: 1px solid var(--rule);
    background: var(--bg-card, #f6f3ed);
    color: var(--ink);
    border-radius: 999px;
    padding: 8px 14px 8px 36px;
    font-family: inherit;
    font-size: 0.92rem;
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .fh-search-input::placeholder { color: var(--ink-faint); font-style: italic; }
  .fh-search-input:focus {
    outline: none;
    border-color: var(--uw-purple);
    background: #fffdf7;
  }
  /* Keyboard-only visible focus ring (mouse click won't trigger it). */
  .fh-search-input:focus-visible {
    outline: 2px solid var(--uw-purple);
    outline-offset: 2px;
  }
  .fh-sort-btn:focus-visible,
  .fh-lang-btn:focus-visible,
  .hkg-step:focus-visible,
  .fh-show-all:focus-visible,
  .fh-show-fewer:focus-visible {
    outline: 2px solid var(--uw-purple);
    outline-offset: 2px;
  }
  .fh-sort {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .fh-sort-label {
    font-size: 0.72rem;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: 0.3rem;
  }
  .fh-sort-btn {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-soft, #6c6358);
    border-radius: 999px;
    padding: 5px 12px;
    font-family: inherit;
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .fh-sort-btn:hover { border-color: var(--uw-purple); color: var(--uw-purple); }
  .fh-sort-btn.is-active {
    background: var(--uw-purple);
    color: #fffdf7;
    border-color: var(--uw-purple);
  }
  .fh-search-status {
    grid-column: 1 / -1;
    margin: 0;
    font-size: 0.78rem;
    color: var(--ink-faint);
    font-style: italic;
    min-height: 1em;
  }
  .fh-search-status:empty { display: none; }

  /* ---- EN/中 segmented language switch ----------------------------
     Both options visible at once + active one highlighted = the
     reader knows it's a choice without having to interpret a single
     mystery label. */
  .fh-lang-switch {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 2px;
    background: var(--bg-card, #f6f3ed);
  }
  .fh-lang-btn {
    background: transparent;
    border: 0;
    padding: 4px 11px;
    font-family: inherit;
    font-size: 0.78rem;
    color: var(--ink-soft, #6c6358);
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.18s ease;
    line-height: 1;
  }
  .fh-lang-btn:hover:not(.is-active) {
    color: var(--uw-purple);
  }
  .fh-lang-btn.is-active {
    background: var(--uw-purple);
    color: #fffdf7;
  }

  /* ---- "Show all / Show fewer" + empty state ----------------------- */
  .fh-list-more {
    display: flex;
    justify-content: center;
    margin: 1.4rem 0 0;
  }
  .fh-list-more[hidden] { display: none; }
  .fh-show-all,
  .fh-show-fewer {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--uw-purple);
    border-radius: 999px;
    padding: 7px 18px;
    font-family: inherit;
    font-size: 0.86rem;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .fh-show-all:hover,
  .fh-show-fewer:hover {
    background: var(--uw-purple);
    color: #fffdf7;
    border-color: var(--uw-purple);
  }
  .fh-empty {
    margin: 2rem 0 0.5rem;
    text-align: center;
    color: var(--ink-faint);
    font-family: var(--serif);
    font-style: italic;
  }

  .fh-list { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .fh-row { border-bottom: 1px solid var(--rule); }
  .fh-row[hidden] { display: none; }
  .fh-row-link {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.6rem;
    padding: 1.6rem 0;
    color: var(--ink);
    border-bottom: 0;
    align-items: start;
  }
  .fh-row-link:hover { background: var(--bg-card, #f6f3ed); border-bottom: 0; }
  .fh-row-link:hover h2 { color: var(--uw-purple); }

  .fh-row-thumb {
    width: 280px;
    aspect-ratio: 5 / 3;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .fh-row-thumb svg { display: block; width: 100%; height: 100%; }

  .fh-row-meta {
    display: flex; gap: 1rem; align-items: baseline;
    margin-bottom: 0.55rem;
    font-size: 0.78rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }
  .fh-row-meta .fh-place { margin-left: auto; }
  .fh-no {
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    font-family: var(--serif);
  }
  .fh-date {
    font-size: 0.85rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }
  .fh-date b { font-weight: 600; color: var(--ink); }
  .fh-row-text h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.7rem;
    margin: 0 0 0.4rem;
    line-height: 1.15;
    letter-spacing: -0.005em;
  }
  .fh-row-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-faint);
    margin: 0 0 0.7rem;
    max-width: 640px;
  }
  .fh-place {
    font-size: 0.78rem;
    color: var(--ink-faint);
    font-style: italic;
  }

  /* ---- Footer block: single explainer paragraph. The masthead at the
     top tells the reader what Friday Harbor is; this block, below the
     list, tells them what the column does and how it is made. The
     vibe-coding disclosure used to be its own boxed aside next to this
     paragraph — folded into the same paragraph as the closing sentence
     to keep the page from carrying two parallel footers. */
  .fh-index-foot {
    margin-top: 2.4rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--rule);
    max-width: 760px;
  }
  .fh-foot-explainer {
    margin: 0;
    font-family: var(--serif);
    font-style: italic;
    line-height: 1.65;
    color: var(--ink);
    font-size: 1.02rem;
  }

  @media (max-width: 720px) {
    .fh-flag-name { font-size: clamp(2.6rem, 12vw, 4rem); }
    .fh-cover-link { grid-template-columns: 1fr; gap: 1.2rem; }
    .fh-row-link { grid-template-columns: 1fr; gap: 0.9rem; }
    .fh-row-thumb { width: 100%; }
    .fh-place { margin-left: 0; }
  }
</style>

<script type="module">
  // Live mini-map thumbnails for each entry card. The land geometry is
  // fetched once and reused across all cards.
  import * as d3 from 'https://esm.sh/d3@7';

  const NE = 'https://cdn.jsdelivr.net/gh/martynafford/natural-earth-geojson@master/10m';
  const els = Array.from(document.querySelectorAll('[data-fh-thumb]'))
    .filter(el => el.dataset.fhThumb);
  if (els.length) {
    fetch(`${NE}/physical/ne_10m_land.json`)
      .then(r => r.json())
      .then(land => els.forEach(el => render(el, land)))
      .catch(() => { /* leave the placeholder card if Natural Earth is down */ });
  }

  function render(el, land) {
    const data = JSON.parse(el.dataset.fhThumb);
    const w = el.clientWidth || 280;
    const h = el.clientHeight || 168;
    const { bbox, pins = [] } = data;

    const lon0 = (bbox.west + bbox.east) / 2;
    const lat0 = (bbox.south + bbox.north) / 2;
    const yProj = lat => Math.log(Math.tan(Math.PI/4 + lat * Math.PI/360));
    const lonSpan = (bbox.east - bbox.west) * Math.PI / 180;
    const ySpan   = yProj(bbox.north) - yProj(bbox.south);
    const scale = Math.min(w / lonSpan, h / ySpan) * 0.97;

    const projection = d3.geoMercator()
      .center([lon0, lat0])
      .scale(scale)
      .translate([w / 2, h / 2])
      .clipExtent([[0, 0], [w, h]])
      .precision(0.5);
    const path = d3.geoPath(projection);

    el.innerHTML = '';
    const svg = d3.select(el).append('svg')
      .attr('viewBox', `0 0 ${w} ${h}`)
      .attr('preserveAspectRatio', 'xMidYMid meet')
      .style('display', 'block');

    // Sea — same Morandi mist gradient as the main map
    const gid = `tg-${Math.random().toString(36).slice(2, 8)}`;
    const grad = svg.append('defs').append('linearGradient')
      .attr('id', gid)
      .attr('gradientUnits', 'userSpaceOnUse')
      .attr('x1', w / 2).attr('y1', 0)
      .attr('x2', w / 2).attr('y2', h);
    grad.append('stop').attr('offset', '0%').attr('stop-color', '#d2d8d6');
    grad.append('stop').attr('offset', '55%').attr('stop-color', '#bcc4c4');
    grad.append('stop').attr('offset', '100%').attr('stop-color', '#a8b1b3');
    svg.append('rect').attr('width', w).attr('height', h).attr('fill', `url(#${gid})`);

    // Coastal halo (sage soft)
    svg.append('path').datum(land).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#b4bdaf').attr('stroke-opacity', 0.55)
      .attr('stroke-width', 4);

    // Land — paper cream
    svg.append('path').datum(land).attr('d', path)
      .attr('fill', '#f5efe2')
      .attr('stroke', '#6c6358').attr('stroke-width', 0.6)
      .attr('stroke-linejoin', 'round');

    // Pin halos + dots (deep terracotta)
    pins.forEach(p => {
      const xy = projection([p.lon, p.lat]);
      if (!xy) return;
      svg.append('circle').attr('cx', xy[0]).attr('cy', xy[1])
        .attr('r', 9).attr('fill', '#c2a094').attr('fill-opacity', 0.45);
      svg.append('circle').attr('cx', xy[0]).attr('cy', xy[1])
        .attr('r', 3.5).attr('fill', '#8a3e2e');
    });
  }
</script>

<script is:inline>
  (function () {
    const root = document.querySelector('.fh-root');
    if (!root) return;

    // ----- language switch (segmented EN / 中) -------------------------
    var lang = 'en';
    try { lang = localStorage.getItem('fh-lang') || 'en'; } catch (e) {}
    if (lang !== 'en' && lang !== 'zh') lang = 'en';
    root.setAttribute('data-lang', lang);
    var langBtns = root.querySelectorAll('.fh-lang-btn');
    function paintLangButtons() {
      var cur = root.getAttribute('data-lang') || 'en';
      langBtns.forEach(function (b) {
        var on = b.getAttribute('data-lang-set') === cur;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }
    function applyLangToToolbar() {
      var cur = root.getAttribute('data-lang') || 'en';
      var input = document.getElementById('fh-q');
      if (input) {
        var ph = input.getAttribute('data-ph-' + cur) || '';
        input.placeholder = ph;
      }
      paintLangButtons();
      // show-all button: render its template with current visible-hidden count
      renderToolbarStatus();
    }
    langBtns.forEach(function (b) {
      b.addEventListener('click', function () {
        var next = b.getAttribute('data-lang-set') || 'en';
        if (root.getAttribute('data-lang') === next) return;
        root.setAttribute('data-lang', next);
        try { localStorage.setItem('fh-lang', next); } catch (e) {}
        applyLangToToolbar();
      });
    });

    // ----- search + sort + default-5 limit -----------------------------
    var DEFAULT_LIMIT = 5;
    var listEl   = document.getElementById('fh-list');
    var rowsAll  = listEl ? Array.prototype.slice.call(listEl.querySelectorAll('.fh-row')) : [];
    var input    = document.getElementById('fh-q');
    var sortBtns = document.querySelectorAll('.fh-sort-btn');
    var showAll  = document.getElementById('fh-show-all');
    var showFew  = document.getElementById('fh-show-fewer');
    var moreWrap = document.getElementById('fh-more');
    var emptyEl  = document.getElementById('fh-empty');
    var statusEl = document.getElementById('fh-status');

    var state = {
      q: '',
      sort: 'newest',
      expanded: false,   // when true, ignore the 5-row limit
    };

    function compareRows(a, b, mode) {
      var da = a.getAttribute('data-date') || '';
      var db = b.getAttribute('data-date') || '';
      if (mode === 'oldest') return da < db ? -1 : da > db ? 1 : 0;
      if (mode === 'az') {
        var langCur = root.getAttribute('data-lang') || 'en';
        var ka = (langCur === 'zh' ? a.getAttribute('data-title-zh') : a.getAttribute('data-title-en')) || '';
        var kb = (langCur === 'zh' ? b.getAttribute('data-title-zh') : b.getAttribute('data-title-en')) || '';
        return ka.localeCompare(kb, langCur === 'zh' ? 'zh' : 'en');
      }
      // default: newest first
      return da < db ? 1 : da > db ? -1 : 0;
    }

    function applyFilterAndSort() {
      if (!listEl) return;
      var q = state.q.trim().toLowerCase();
      // Filter
      var matched = rowsAll.filter(function (r) {
        if (!q) return true;
        var hay = r.getAttribute('data-search') || '';
        return hay.indexOf(q) !== -1;
      });
      // Sort: clone the matched array and sort, then reorder DOM
      var sorted = matched.slice().sort(function (a, b) { return compareRows(a, b, state.sort); });
      // Reattach in sorted order; hide non-matches.
      rowsAll.forEach(function (r) { r.hidden = true; });
      sorted.forEach(function (r) {
        listEl.appendChild(r);  // moving an element to the end re-orders it
      });
      // Apply limit-5 unless searching or expanded
      var limited = (!q && !state.expanded);
      sorted.forEach(function (r, i) {
        r.hidden = limited && i >= DEFAULT_LIMIT;
      });
      // Empty state
      if (emptyEl) emptyEl.hidden = sorted.length > 0;
      // Toolbar (show-all button + status text)
      var hiddenByLimit = limited ? Math.max(0, sorted.length - DEFAULT_LIMIT) : 0;
      if (moreWrap) moreWrap.hidden = (hiddenByLimit === 0 && !state.expanded);
      if (showAll) showAll.hidden = state.expanded || hiddenByLimit === 0;
      if (showFew) showFew.hidden = !state.expanded || q.length > 0;
      renderToolbarStatus(sorted.length, hiddenByLimit);
    }

    function renderToolbarStatus(matchCount, hiddenByLimit) {
      // show-all button label uses the {n} template baked from the data file
      var langCur = root.getAttribute('data-lang') || 'en';
      if (showAll) {
        showAll.querySelectorAll('[data-tpl]').forEach(function (sp) {
          var tpl = sp.getAttribute('data-tpl') || '';
          // n = total matched (the button is only shown when there are
          // hidden rows, so total is the right number to advertise)
          var n = (typeof matchCount === 'number') ? matchCount : rowsAll.length;
          sp.textContent = tpl.replace('{n}', n);
        });
      }
      // status line: only show a count while a query is active
      if (statusEl) {
        if (state.q && typeof matchCount === 'number') {
          var tplEn = '{n} matching';
          var tplZh = '{n} 篇匹配';
          statusEl.textContent = (langCur === 'zh' ? tplZh : tplEn).replace('{n}', matchCount);
        } else {
          statusEl.textContent = '';
        }
      }
    }

    if (input) {
      input.addEventListener('input', function () {
        state.q = input.value || '';
        // When searching, automatically expand so all matches are visible
        state.expanded = state.q.length > 0;
        applyFilterAndSort();
      });
    }
    sortBtns.forEach(function (b) {
      b.addEventListener('click', function () {
        state.sort = b.getAttribute('data-sort') || 'newest';
        sortBtns.forEach(function (x) {
          var on = x === b;
          x.classList.toggle('is-active', on);
          x.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        applyFilterAndSort();
      });
    });
    if (showAll) showAll.addEventListener('click', function () {
      state.expanded = true;
      applyFilterAndSort();
    });
    if (showFew) showFew.addEventListener('click', function () {
      state.expanded = false;
      applyFilterAndSort();
      // Scroll back up to the top of the list so the reader doesn't get
      // stranded mid-page after collapsing.
      if (listEl && listEl.scrollIntoView) listEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    applyLangToToolbar();
    applyFilterAndSort();
  })();
</script>
