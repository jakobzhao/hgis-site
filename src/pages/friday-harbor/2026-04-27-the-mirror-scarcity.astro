  function drawTimeAxis(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Shared 2022 → 2026 axis. US events above the axis, China events below.
    const axisX0 = x + 30;
    const axisX1 = x + w - 30;
    // Centre the axis vertically so US (above) and CN (below) event rows
    // get equal room to fan out into whatever vertical space remains.
    const axisY  = y + h * 0.5;

    const t0 = new Date('2022-01-01').getTime();
    const t1 = new Date('2026-06-01').getTime();
    const xs = d3.scaleLinear().domain([t0, t1]).range([axisX0, axisX1]);

    // Axis line
    svg.append('line').attr('x1', axisX0).attr('y1', axisY).attr('x2', axisX1).attr('y2', axisY)
      .attr('stroke', c.inkSoft).attr('stroke-width', 0.8);

    // Year ticks
    [2022, 2023, 2024, 2025, 2026].forEach(yr => {
      const tx = xs(new Date(`${yr}-01-01`).getTime());
      svg.append('line').attr('x1', tx).attr('y1', axisY - 4).attr('x2', tx).attr('y2', axisY + 4)
        .attr('stroke', c.inkSoft).attr('stroke-width', 0.8);
      svg.append('text').attr('x', tx).attr('y', axisY + 16)
        .attr('text-anchor', 'middle').attr('fill', c.inkSoft)
        .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
        .text(yr);
    });

    // Side labels — pinned to the band edges so they always sit at the
    // top / bottom of whatever vertical space the timeline got.
    svg.append('text').attr('x', x + 4).attr('y', y + 12)
      .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
      .attr('fill', US_TONE)
      .text(lang === 'zh' ? '美国 ▲' : 'US ▲');
    svg.append('text').attr('x', x + 4).attr('y', y + h - 6)
      .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
      .attr('fill', CN_TONE)
      .text(lang === 'zh' ? '中国 ▼' : 'CN ▼');

    // Events
    const usEvents = TIMELINE.filter(t => t.side === 'us');
    const cnEvents = TIMELINE.filter(t => t.side === 'cn');

    // Distribute the available vertical room evenly across the two
    // staggered rows on each side so a tall canvas doesn't leave the
    // bottom half empty.
    const halfH      = h / 2;
    const rowSpacing = Math.max(16, Math.min(60, (halfH - 24) / 2));

    drawEventTrack(svg, usEvents, xs, axisY, -1, US_TONE, rowSpacing, lang, sansFont);
    drawEventTrack(svg, cnEvents, xs, axisY, +1, CN_TONE, rowSpacing, lang, sansFont);
  }

  function drawEventTrack(svg, events, xs, axisY, direction, tone, rowSpacing, lang, sansFont) {
    // direction: -1 events go above the axis, +1 below.
    // Two-row stagger; row spacing scales with available canvas height.
    events.forEach((ev, i) => {
      const tx = xs(new Date(ev.date).getTime());
      const row = i % 2 === 0 ? 1 : 2;
      const ty = axisY + direction * (10 + row * rowSpacing);

      // Stem — connect tick to label with a thin guide line so events
      // remain readable even when labels are pushed far from the axis.
      svg.append('line')
        .attr('x1', tx).attr('y1', axisY)
        .attr('x2', tx).attr('y2', ty + (direction === -1 ? 4 : -4))
        .attr('stroke', tone).attr('stroke-width', 0.6)
        .attr('stroke-dasharray', '2 2').attr('opacity', 0.5);

      // Tick dot
      svg.append('circle')
        .attr('cx', tx).attr('cy', axisY).attr('r', 2.8)
        .attr('fill', tone);

      // Label
      svg.append('text')
        .attr('x', tx).attr('y', ty)
        .attr('text-anchor', 'middle').attr('font-family', sansFont)
        .attr('font-size', 9.5).attr('fill', tone)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(ev.label[lang]);
    });
  }
</script>
