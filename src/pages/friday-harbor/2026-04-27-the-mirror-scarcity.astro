    const bh = h - 26;
    boxes.forEach((b, i) => {
      const bx = x + 12 + i * (bw + 8);
      svg.append('rect')
        .attr('x', bx).attr('y', by).attr('width', bw).attr('height', bh)
        .attr('fill', '#f3e2d6').attr('stroke', CN_TONE).attr('stroke-width', 0.8)
        .attr('rx', 3);
      const lines = b.label.split('\n');
      lines.forEach((ln, li) => {
        svg.append('text')
          .attr('x', bx + bw / 2).attr('y', by + 16 + li * 13)
          .attr('text-anchor', 'middle').attr('font-family', sansFont)
          .attr('font-size', li === 0 ? 11 : 9.5)
          .attr('fill', li === 0 ? CN_TONE : c.inkSoft)
