<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';

  // ---- Policy timeline events ----
  // Two parallel tracks (US above, China below) on a shared 2022→2026 axis.
  const TIMELINE = [
    // US track — grid + nuclear + capacity
    { side: 'us', date: '2024-03-15', label: { en: 'AWS buys Talen DC campus', zh: 'AWS 收购 Talen 园区' } },
    { side: 'us', date: '2024-09-20', label: { en: 'Microsoft × TMI deal',     zh: 'Microsoft × 三里岛 PPA' } },
    { side: 'us', date: '2025-01-21', label: { en: 'Stargate $500 B announced', zh: 'Stargate 5,000 亿计划' } },
    { side: 'us', date: '2025-07-15', label: { en: 'PJM auction at price cap',  zh: 'PJM 容量拍卖触顶' } },
    { side: 'us', date: '2025-10-29', label: { en: 'AWS Project Rainier live',  zh: 'AWS Rainier 上线' } },
    { side: 'us', date: '2026-01-26', label: { en: 'Memphis Colossus → 2 GW',   zh: 'Memphis Colossus → 2 吉瓦' } },

    // China track — export controls + chips
    { side: 'cn', date: '2022-10-07', label: { en: 'First US export controls', zh: '美国首轮出口管制' } },
    { side: 'cn', date: '2023-10-17', label: { en: 'A800 / H800 banned',       zh: 'A800 / H800 被禁' } },
    { side: 'cn', date: '2025-01-13', label: { en: 'AI Diffusion Rule',        zh: 'AI Diffusion Rule' } },
    { side: 'cn', date: '2025-04-15', label: { en: 'H20 banned ($5.5 B hit)',  zh: 'H20 一度被禁（$5.5B 减值）' } },
    { side: 'cn', date: '2025-07-15', label: { en: 'H20 reinstated',           zh: 'H20 恢复出货' } },
    { side: 'cn', date: '2025-12-08', label: { en: 'Operation Gatekeeper',     zh: '"看门人"行动起诉' } },
    { side: 'cn', date: '2026-01-30', label: { en: 'CXMT HBM3 sample to Huawei', zh: 'CXMT 向华为送 HBM3 样片' } }
  ];

  // ---- Chinese hub schematic locations ----
  // Schematic only — these are political-zone polygons, not site coords.
  // We render them as labelled rectangles, no base map.
  const CN_HUBS = [
    { id: 'jjj',     label: { en: 'Beijing-Tianjin-Hebei', zh: '京津冀' } },
    { id: 'csj',     label: { en: 'Yangtze Delta',         zh: '长三角' } },
    { id: 'gba',     label: { en: 'Greater Bay',           zh: '大湾区' } },
    { id: 'cy',      label: { en: 'Chengdu-Chongqing',     zh: '成渝' } },
    { id: 'nm',      label: { en: 'Inner Mongolia',        zh: '内蒙古' } },
    { id: 'gz',      label: { en: 'Guizhou',               zh: '贵州' } },
    { id: 'gs',      label: { en: 'Gansu',                 zh: '甘肃' } },
    { id: 'nx',      label: { en: 'Ningxia',               zh: '宁夏' } }
  ];

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    paper2:  css.getPropertyValue('--bg-deep').trim()   || '#ddd4c2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
  };
  const US_TONE = '#475569';   // slate — "electrons"
  const US_FILL = '#94a3b8';
  const CN_TONE = '#8a3e2e';   // chestnut — "silicon"
  const CN_FILL = '#b6604a';
  const SHORT   = '#c2855e';   // shortfall fill

  function currentLang() {
    const fhRoot = document.querySelector('.fh-root');
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => draw())
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  window.addEventListener('resize', () => draw());
  requestAnimationFrame(() => draw());

  function draw() {
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(() => draw()); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const serifFont = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';
    const sansFont = 'Inter, "Noto Sans CJK", sans-serif';

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block');

    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ----- Layout regions -----
    const padX = 18;
    const padTop = 18;
    const padBot = 18;

    // Top header strip
    const headH = 40;
    const colW = (W - padX * 3) / 2;
    const colLX = padX;
    const colRX = padX + colW + padX;

    // Two mirror rows: electricity, then silicon. Each row shows both
    // countries on the same metric so the asymmetry reads horizontally.
    const powerRowY = padTop + headH + 12;
    const powerRowH = 96;

    const chipRowY = powerRowY + powerRowH + 12;
    const chipRowH = 96;

    const workaroundY = chipRowY + chipRowH + 16;
    const workaroundH = 70;

    const timelineY = workaroundY + workaroundH + 16;
    // Use whatever vertical space remains for the timeline so the
    // canvas doesn't bottom out into empty space.
    const timelineH = H - timelineY - padBot;

    // ----- Headers -----
    svg.append('text')
      .attr('x', colLX + colW / 2).attr('y', padTop + 16)
      .attr('text-anchor', 'middle')
      .attr('fill', US_TONE)
      .attr('font-family', serifFont)
      .attr('font-size', 17).attr('font-style', 'italic').attr('letter-spacing', '0.18em')
      .text(lang === 'zh' ? '美国' : 'United States');

    svg.append('text')
      .attr('x', colRX + colW / 2).attr('y', padTop + 16)
      .attr('text-anchor', 'middle')
      .attr('fill', CN_TONE)
      .attr('font-family', serifFont)
      .attr('font-size', 17).attr('font-style', 'italic').attr('letter-spacing', '0.18em')
      .text(lang === 'zh' ? '中国' : 'China');

    // Subhead: the asymmetry summary
    svg.append('text')
      .attr('x', colLX + colW / 2).attr('y', padTop + 34)
      .attr('text-anchor', 'middle')
      .attr('fill', c.purpleD)
      .attr('font-family', serifFont).attr('font-size', 12).attr('font-style', 'italic')
      .text(lang === 'zh' ? '电力短 · 芯片足' : 'short on electrons · long on silicon');

    svg.append('text')
      .attr('x', colRX + colW / 2).attr('y', padTop + 34)
      .attr('text-anchor', 'middle')
      .attr('fill', c.purpleD)
      .attr('font-family', serifFont).attr('font-size', 12).attr('font-style', 'italic')
      .text(lang === 'zh' ? '电力足 · 芯片短' : 'long on electrons · short on silicon');

    // ----- Row 1: Electricity (both countries) -----
    drawComparisonRow(svg, padX, powerRowY, W - padX * 2, powerRowH,
      colLX, colRX, colW, lang, sansFont, serifFont,
      {
        label: lang === 'zh' ? '电力 ⚡' : 'electricity ⚡',
        left: {
          accent: US_TONE, fill: US_FILL, gapColor: SHORT,
          headline: lang === 'zh'
            ? 'AI 用电需求 79 GW · 已落实 32 GW · 缺 47 GW'
            : 'AI power demand 79 GW · served 32 GW · short 47 GW',
          metPct: 32 / 79,
          gapPct: 47 / 79,
          metLabel: lang === 'zh' ? '41% 已供' : '41% met',
          gapLabel: lang === 'zh' ? '59% 缺口' : '59% short',
          caption: lang === 'zh'
            ? 'PJM 容量拍卖触顶仍未采足——历史首次'
            : 'PJM cap auction failed for the first time'
        },
        right: {
          accent: CN_TONE, fill: CN_FILL, gapColor: SHORT,
          headline: lang === 'zh'
            ? 'AI 用电需求 ~30 GW · 总装机 3,400 GW · 2024 年 +370 GW'
            : 'AI power demand ~30 GW · 3,400 GW grid · +370 GW added 2024',
          metPct: 1, gapPct: 0,
          metLabel: lang === 'zh' ? '100% 已供（结构性富余）' : '100% met (structural surplus)',
          caption: lang === 'zh'
            ? '「东数西算」把负荷甩去西部清洁能源富余区'
            : '"East Data, West Compute" routes load to surplus hubs'
        }
      });

    // ----- Row 2: Silicon (both countries) -----
    drawComparisonRow(svg, padX, chipRowY, W - padX * 2, chipRowH,
      colLX, colRX, colW, lang, sansFont, serifFont,
      {
        label: lang === 'zh' ? '芯片 ◆' : 'silicon ◆',
        left: {
          accent: US_TONE, fill: US_FILL, gapColor: SHORT,
          headline: lang === 'zh'
            ? 'Hyperscaler 加速卡订单基本兑现 · 2026 capex ~$640B'
            : 'Hyperscaler accelerator orders fulfilled · ~$640B 2026 capex',
          metPct: 0.97, gapPct: 0.03,
          metLabel: lang === 'zh' ? '~97% 兑现' : '~97% met',
          gapLabel: lang === 'zh' ? 'CoWoS' : 'CoWoS',
          caption: lang === 'zh'
            ? '台积电 CoWoS 封装是唯一意义上的瓶颈'
            : 'TSMC CoWoS packaging the only meaningful bottleneck'
        },
        right: {
          accent: CN_TONE, fill: CN_FILL, gapColor: SHORT,
          headline: lang === 'zh'
            ? '昇腾逻辑产能 1,175k · HBM 限制下出货 280k · 差 4–5×'
            : 'Ascend logic 1,175k · HBM-limited shipped 280k · 4–5× gap',
          metPct: 280 / 1175,
          gapPct: 1 - 280 / 1175,
          metLabel: lang === 'zh' ? '~24% 兑现' : '~24% met',
          gapLabel: lang === 'zh' ? '~76% 被 HBM 卡死' : '~76% HBM-locked',
          caption: lang === 'zh'
            ? '长鑫 HBM 产量远跟不上中芯逻辑晶圆'
            : 'CXMT HBM output lags SMIC logic-die capacity'
        }
      });

    // ----- US workaround: gas / nuclear -----
    drawUSWorkaround(svg, colLX, workaroundY, colW, workaroundH, lang, sansFont, serifFont);

    // ----- China workaround: hubs + smuggling + algorithm -----
    drawCNWorkaround(svg, colRX, workaroundY, colW, workaroundH, lang, sansFont, serifFont);

    // ----- Shared time axis -----
    drawTimeAxis(svg, padX, timelineY, W - padX * 2, timelineH, lang, sansFont, serifFont);
  }

  // ===== Drawing helpers =====

  function ensureHatch(svg, id, baseFill, lineColor) {
    const defs = svg.select('defs').empty() ? svg.append('defs') : svg.select('defs');
    if (defs.select(`#${id}`).empty()) {
      const pat = defs.append('pattern').attr('id', id)
        .attr('patternUnits', 'userSpaceOnUse').attr('width', 6).attr('height', 6)
        .attr('patternTransform', 'rotate(45)');
      pat.append('rect').attr('width', 6).attr('height', 6).attr('fill', baseFill);
      pat.append('line').attr('x1', 0).attr('y1', 0).attr('x2', 0).attr('y2', 6)
        .attr('stroke', lineColor).attr('stroke-width', 2);
    }
  }

  function drawComparisonRow(svg, x, y, w, h, colLX, colRX, colW, lang, sansFont, serifFont, opts) {
    // Centered row label across the full width
    svg.append('text')
      .attr('x', x + w / 2).attr('y', y + 12)
      .attr('text-anchor', 'middle')
      .attr('fill', c.purpleD).attr('font-family', serifFont)
      .attr('font-size', 12).attr('font-style', 'italic').attr('letter-spacing', '0.22em')
      .text(opts.label);

    drawComparisonCell(svg, colLX, y + 18, colW, h - 18, opts.left,  lang, sansFont, serifFont, 'us');
    drawComparisonCell(svg, colRX, y + 18, colW, h - 18, opts.right, lang, sansFont, serifFont, 'cn');
  }

  function drawComparisonCell(svg, x, y, w, h, cell, lang, sansFont, serifFont, side) {
    const barX = x + 10;
    const barW = w - 20;
    const barY = y + 26;
    const barH = 28;

    // Headline above the bar
    svg.append('text')
      .attr('x', x + w / 2).attr('y', y + 14)
      .attr('text-anchor', 'middle').attr('font-family', sansFont)
      .attr('font-size', 10.5).attr('fill', cell.accent).attr('font-weight', 600)
      .text(cell.headline);

    // Track outline (full bar, light)
    svg.append('rect')
      .attr('x', barX).attr('y', barY).attr('width', barW).attr('height', barH)
      .attr('fill', side === 'us' ? '#eef1f5' : '#f3e7dd')
      .attr('stroke', cell.accent).attr('stroke-width', 0.6);

    const filledW = barW * cell.metPct;
    const gapW    = barW * cell.gapPct;

    // Filled portion (met)
    if (filledW > 0) {
      svg.append('rect')
        .attr('x', barX).attr('y', barY).attr('width', filledW).attr('height', barH)
        .attr('fill', cell.fill).attr('stroke', cell.accent).attr('stroke-width', 0.6);
    }

    // Gap portion (hatched red)
    if (gapW > 0) {
      const hatchId = side === 'us' ? 'hatchGapUS' : 'hatchGapCN';
      ensureHatch(svg, hatchId, side === 'us' ? '#f1d4c4' : '#f3d4c0', cell.gapColor);
      svg.append('rect')
        .attr('x', barX + filledW).attr('y', barY).attr('width', gapW).attr('height', barH)
        .attr('fill', `url(#${hatchId})`)
        .attr('stroke', cell.gapColor).attr('stroke-width', 0.6);
    }

    // Met label — inside if room, otherwise to the right of the bar
    if (filledW > 80) {
      svg.append('text')
        .attr('x', barX + filledW / 2).attr('y', barY + barH / 2 + 4)
        .attr('text-anchor', 'middle').attr('font-family', sansFont)
        .attr('font-size', 10.5).attr('fill', '#fff').attr('font-weight', 700)
        .text(cell.metLabel);
    } else if (filledW > 4) {
      svg.append('text')
        .attr('x', barX + filledW + 4).attr('y', barY + barH / 2 + 4)
        .attr('font-family', sansFont).attr('font-size', 10).attr('fill', cell.accent).attr('font-weight', 700)
        .text(cell.metLabel);
    }

    // Gap label — inside if room
    if (gapW > 80 && cell.gapLabel) {
      svg.append('text')
        .attr('x', barX + filledW + gapW / 2).attr('y', barY + barH / 2 + 4)
        .attr('text-anchor', 'middle').attr('font-family', sansFont)
        .attr('font-size', 10.5).attr('fill', cell.gapColor).attr('font-weight', 700)
        .text(cell.gapLabel);
    } else if (gapW > 4 && cell.gapLabel) {
      svg.append('text')
        .attr('x', barX + barW + 4).attr('y', barY + barH / 2 + 4)
        .attr('font-family', sansFont).attr('font-size', 10).attr('fill', cell.gapColor).attr('font-weight', 700)
        .text(cell.gapLabel);
    }

    // Caption below the bar
    if (cell.caption) {
      svg.append('text')
        .attr('x', x + w / 2).attr('y', barY + barH + 16)
        .attr('text-anchor', 'middle').attr('font-family', serifFont)
        .attr('font-size', 10.5).attr('fill', c.inkSoft).attr('font-style', 'italic')
        .text(cell.caption);
    }
  }

  function drawUSWorkaround(svg, x, y, w, h, lang, sansFont, serifFont) {
    svg.append('text')
      .attr('x', x + w / 2).attr('y', y + 12)
      .attr('text-anchor', 'middle')
      .attr('fill', c.inkSoft).attr('font-family', serifFont)
      .attr('font-size', 12).attr('font-style', 'italic')
      .text(lang === 'zh' ? '应对：自建电源（绕过电网）' : 'Workaround: build power off the grid');

    // Three escape valves as boxes
    const boxes = [
      { label: lang === 'zh' ? '现场天然气 1 GW+\n(Stargate Abilene)' : 'On-site gas 1 GW+\n(Stargate Abilene)' },
      { label: lang === 'zh' ? '重启核电 ≈ 2.8 GW\n(MSFT TMI · AWS Talen)' : 'Restart nuclear ≈ 2.8 GW\n(MSFT TMI · AWS Talen)' },
      { label: lang === 'zh' ? '小型模块堆 (SMR)\n2030 年后' : 'Small modular reactors\npost-2030' }
    ];
    const bw = (w - 24) / 3 - 8;
    const by = y + 22;
    const bh = h - 26;
    boxes.forEach((b, i) => {
      const bx = x + 12 + i * (bw + 8);
      svg.append('rect')
        .attr('x', bx).attr('y', by).attr('width', bw).attr('height', bh)
        .attr('fill', '#e3eaf1').attr('stroke', US_TONE).attr('stroke-width', 0.8)
        .attr('rx', 3);
      const lines = b.label.split('\n');
      lines.forEach((ln, li) => {
        svg.append('text')
          .attr('x', bx + bw / 2).attr('y', by + 16 + li * 13)
          .attr('text-anchor', 'middle').attr('font-family', sansFont)
          .attr('font-size', li === 0 ? 11 : 9.5)
          .attr('fill', li === 0 ? US_TONE : c.inkSoft)
          .attr('font-weight', li === 0 ? 600 : 400)
          .text(ln);
      });
    });
  }

  function drawCNWorkaround(svg, x, y, w, h, lang, sansFont, serifFont) {
    svg.append('text')
      .attr('x', x + w / 2).attr('y', y + 12)
      .attr('text-anchor', 'middle')
      .attr('fill', c.inkSoft).attr('font-family', serifFont)
      .attr('font-size', 12).attr('font-style', 'italic')
      .text(lang === 'zh' ? '应对：算法优化 + 灰渠道 + 国家算力网' : 'Workaround: algorithm + grey channels + state network');

    const boxes = [
      { label: lang === 'zh' ? '算法优化\n(DeepSeek V3: 2,048 H800)' : 'Algorithmic efficiency\n(DeepSeek V3: 2,048 H800)' },
      { label: lang === 'zh' ? '走私 / 转口\n(新加坡·马来西亚·泰国)' : 'Smuggling / re-export\n(Singapore·Malaysia·Thailand)' },
      { label: lang === 'zh' ? '国家算力网\n8 枢纽 · 138.8 万 PFlops' : 'National compute network\n8 hubs · 1.388 M PFlops' }
    ];
    const bw = (w - 24) / 3 - 8;
