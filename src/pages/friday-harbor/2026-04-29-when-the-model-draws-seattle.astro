<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    paper2:  css.getPropertyValue('--bg-deep').trim()   || '#ddd4c2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
    sage:    css.getPropertyValue('--sage').trim()      || '#8e9c8a',
    sageS:   css.getPropertyValue('--sage-soft').trim() || '#b4bdaf',
    rose:    css.getPropertyValue('--rose').trim()      || '#c2a094',
    mist:    css.getPropertyValue('--mist').trim()      || '#a8b1b3',
  };
  const REAL_FILL   = 'rgba(142, 156, 138, 0.55)';
  const REAL_STROKE = '#5e7558';
  const CLAUDE_FILL = 'rgba(194, 160, 148, 0.50)';
  const CLAUDE_STROKE = '#a05543';
  const SEA = '#cfd5d3';

  // Common bbox / projection so the two panels are directly comparable.
  const BBOX = [[-122.46, 47.49], [-122.23, 47.74]];

  // Same neighborhoods to label across both panels (so the eye can
  // track a name from one map to the other).

  let _real = null, _claude = null;
  Promise.all([
    fetch('/data/seattle-council-real.geojson').then(r => r.json()),
    fetch('/data/seattle-council-claude.geojson').then(r => r.json()),
  ]).then(([realGJ, claudeGJ]) => {
    _real = realGJ;
    _claude = claudeGJ;
    requestAnimationFrame(drawAll);
  }).catch(err => {
    document.querySelectorAll('.map-status').forEach(el => {
      el.textContent = 'Could not load neighborhood data.';
    });
  });

  window.addEventListener('resize', () => { if (_real && _claude) drawAll(); });
  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => { if (_real && _claude) drawAll(); })
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  function currentLang() {
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  function drawAll() {
    drawPanel('stage-real',   _real,   { kind: 'real',   showSilhouette: false });
    drawPanel('stage-claude', _claude, { kind: 'claude', showSilhouette: true  });
  }

  // Categorical palette: one tint per district number, shared between
  // both panels so D3-real and D3-claude carry the same colour and the
  // viewer can match them by eye.
  const D_PALETTE = {
    1: 'rgba(186, 154, 142, 0.78)',  // rose
    2: 'rgba(170, 132, 116, 0.78)',  // deeper rose
    3: 'rgba(160, 168, 142, 0.78)',  // sage
    4: 'rgba(178, 188, 168, 0.78)',  // pale sage
    5: 'rgba(196, 178, 142, 0.78)',  // sand
    6: 'rgba(150, 168, 174, 0.78)',  // mist blue
    7: 'rgba(178, 158, 178, 0.78)',  // muted purple
  };
  function districtFill(feature) {
    return D_PALETTE[feature.properties.num] || 'rgba(160,160,160,0.5)';
  }
  function districtLabel(feature) {
    return feature.properties.district || ('D' + feature.properties.num);
  }

  function makeProjection(W, H) {
    // Plain Mercator with manual scale + translate — Albers' conic
    // distortion turns into visible arcs at city scale and does not
    // play well with d3's fitExtent on a small bbox.
    const lon0 = (BBOX[0][0] + BBOX[1][0]) / 2;
    const lat0 = (BBOX[0][1] + BBOX[1][1]) / 2;
    const yProj = lat => Math.log(Math.tan(Math.PI/4 + lat * Math.PI/360));
    const lonSpan = (BBOX[1][0] - BBOX[0][0]) * Math.PI / 180;
    const ySpan   = yProj(BBOX[1][1]) - yProj(BBOX[0][1]);
    const scale = Math.min(W / lonSpan, H / ySpan) * 0.96;
    const tx = W / 2 - (lon0 * Math.PI / 180) * scale;
    const ty = H / 2 + yProj(lat0) * scale;
    return d3.geoMercator()
      .scale(scale).translate([tx, ty])
      .clipExtent([[0, 0], [W, H]])
      .precision(0.3);
  }

  function drawPanel(stageId, data, style) {
    const stage = document.getElementById(stageId);
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(drawAll); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const projection = makeProjection(W, H);
    const path = d3.geoPath(projection);

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block');

    // Sea
    svg.append('rect').attr('width', W).attr('height', H).attr('fill', SEA);

    // Subtle bbox frame
    svg.append('rect').attr('x', 0.5).attr('y', 0.5)
      .attr('width', W - 1).attr('height', H - 1)
      .attr('fill', 'none').attr('stroke', c.ink).attr('stroke-opacity', 0.25)
      .attr('stroke-width', 0.6);

    // On the Claude panel, draw the actual Seattle silhouette underneath
    // (very faint paper fill, thin stroke) so the viewer can SEE how the
    // model's rectangles relate to where the city actually is. Then clip
    // Claude's rectangles to that silhouette so the right panel's filled
    // extent matches the left panel's extent — rectangles that spill into
    // Lake Washington or Puget Sound are visibly cut off at the shoreline.
    if (style.showSilhouette) {
      // Faint Seattle silhouette as a baseline reference, NOT a clip.
      // With Claude's tiled output, the most informative thing is to see
      // where the model's rectangles overshoot the city into water and
      // where they leave gaps — clipping would hide both.
      svg.append('g').attr('class', 'silhouette')
        .selectAll('path')
        .data(_real.features)
        .join('path')
        .attr('d', path)
        .attr('fill', '#e8e3d6')
        .attr('stroke', c.inkFaint).attr('stroke-opacity', 0.45)
        .attr('stroke-width', 0.5)
        .attr('stroke-linejoin', 'round');
    }

    const layer = svg.append('g').attr('class', 'nbhd-layer');
    layer.selectAll('path')
      .data(data.features)
      .join('path')
      .attr('d', path)
      .attr('fill', d => districtFill(d))
      .attr('stroke', '#3a3530')
      .attr('stroke-opacity', 0.75)
      .attr('stroke-width', 1.4)
      .attr('stroke-linejoin', 'round');

    // District labels at polygon centroid, with paper halo
    const labelG = svg.append('g').attr('class', 'district-labels');
    data.features.forEach(f => {
      const cen = path.centroid(f);
      if (!cen || isNaN(cen[0])) return;
      labelG.append('text')
        .attr('x', cen[0]).attr('y', cen[1])
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'middle')
        .attr('font-size', 16)
        .attr('font-family', 'Inter, "Noto Sans CJK", sans-serif')
        .attr('font-weight', 700)
        .attr('fill', c.ink)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.95)').attr('stroke-width', 4)
        .attr('stroke-linejoin', 'round')
        .text(districtLabel(f));
    });
  }
</script>
