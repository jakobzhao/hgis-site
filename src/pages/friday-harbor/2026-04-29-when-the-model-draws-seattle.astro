  .seamap-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }
  .seamap-panel {
    display: flex; flex-direction: column;
  }
  .seamap-tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 0 0 0.4rem;
    padding: 0.18rem 0.55rem;
    background: rgba(142, 156, 138, 0.16);
    border-left: 2px solid var(--sage);
    align-self: flex-start;
    border-radius: 0 2px 2px 0;
  }
  .seamap-tag.tag-claude {
    background: rgba(194, 160, 148, 0.20);
    border-left-color: #8a3e2e;
    color: #6e3024;
  }
  .seamap-stage {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: transparent;
    border: 0;
    overflow: hidden;
    display: grid;
