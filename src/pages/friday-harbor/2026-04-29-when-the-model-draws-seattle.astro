    display: flex; flex-direction: column;
  }
  .seamap-tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 0 0 0.4rem;
    padding: 0.18rem 0.55rem;
    background: rgba(142, 156, 138, 0.16);
    border-left: 2px solid var(--sage);
    align-self: flex-start;
