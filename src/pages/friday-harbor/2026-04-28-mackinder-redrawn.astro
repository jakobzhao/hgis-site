<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';

  // Six concentric layers, drawn from the Earth's interior outward.
  // The diagram is a radial cross-section: each band is an annulus, and
  // chokepoints sit at their actual longitude on the appropriate band.
  const LAYERS = [
    { id: 'sub',   label: { en: 'Subterranean', zh: '地下' },     depth: { en: '−mantle · drill cores',  zh: '−地幔 · 钻芯' },        fill: '#6b3f2c', text: '#fff8e5' },
    { id: 'floor', label: { en: 'Sea floor',    zh: '海底' },     depth: { en: '−4,000 m avg.',           zh: '平均 −4,000 米' },     fill: '#2f4150', text: '#e7e3d6' },
    { id: 'land',  label: { en: 'Land surface', zh: '地表' },     depth: { en: "Mackinder's layer",       zh: '麦金德的层' },         fill: '#e8d6c1', text: '#2c2823' },
    { id: 'sea',   label: { en: 'Sea surface',  zh: '海面' },     depth: { en: '+sea level',              zh: '+海平面' },            fill: '#7e92a3', text: '#fffdf7' },
    { id: 'atmo',  label: { en: 'Atmosphere',   zh: '大气' },     depth: { en: '0 — +50 km',              zh: '0 — +50 km' },         fill: '#aab5b8', text: '#2c2823' },
    { id: 'orbit', label: { en: 'Orbit',        zh: '轨道' },     depth: { en: '+200 km — +36,000 km',    zh: '+200 km — +36,000 km' }, fill: '#0a1428', text: '#e7e3d6' }
  ];

  // Eleven curated chokepoints — the most binding one or two per layer.
  // `lon` is the real-world longitude in degrees (-180..+180); the script
  // maps it onto an angular position on the corresponding band.
  const CHOKEPOINTS = [
    // — Subterranean —
    { layer: 'sub',   lon: 109.5, label: { en: 'Bayan Obo',         zh: '白云鄂博' },     note: { en: '~70% global rare-earth supply',   zh: '占全球稀土约 70%' } },
    { layer: 'sub',   lon: 26.0,  label: { en: 'DRC Copperbelt',    zh: '刚果铜带' },     note: { en: '~74% mined cobalt',               zh: '占全球钴开采约 74%' } },
    // — Sea floor —
    { layer: 'floor', lon: 19.0,  label: { en: 'Baltic cables',     zh: '波罗的海光缆' }, note: { en: 'cable cuts 2023–25',              zh: '光缆切割 2023–25' } },
    { layer: 'floor', lon: 42.0,  label: { en: 'Red Sea cables',    zh: '红海光缆' },     note: { en: 'AAE-1 / EIG / SEACOM cuts 2024',  zh: 'AAE-1 / EIG / SEACOM 2024' } },
    // — Land surface —
    { layer: 'land',  lon: 121.0, label: { en: 'Taiwan Strait',     zh: '台海' },         note: { en: 'TSMC · 90% leading-edge logic',   zh: 'TSMC · 90% 先进逻辑芯片' } },
    { layer: 'land',  lon: 80.4,  label: { en: 'Khorgos',           zh: '霍尔果斯' },     note: { en: 'Belt & Road land hub',            zh: '一带一路陆路集结点' } },
    // — Sea surface —
    { layer: 'sea',   lon: 56.5,  label: { en: 'Hormuz',            zh: '霍尔木兹' },     note: { en: '~20% world oil transits',         zh: '全球约 20% 石油过境' } },
    { layer: 'sea',   lon: 102.5, label: { en: 'Malacca',           zh: '马六甲' },       note: { en: '~25% world trade · East–West',    zh: '全球约 25% 贸易 · 东西方' } },
    // — Atmosphere —
    { layer: 'atmo',  lon: 90.0,  label: { en: 'Russian airspace',  zh: '俄罗斯领空' },   note: { en: 'closed Feb 2022 · global reroutes', zh: '2022.02 关闭 · 全球绕飞' } },
    // — Orbit —
    { layer: 'orbit', lon: 0,     label: { en: 'GEO equatorial arc', zh: 'GEO 赤道带' },  note: { en: '~1,800 ITU slots · finite',       zh: '约 1,800 个 ITU 槽位 · 有限' } },
    { layer: 'orbit', lon: -100,  label: { en: 'Starlink LEO shell', zh: 'Starlink LEO' }, note: { en: 'one operator > 50% of LEO sats',  zh: '单一运营商 > 50% LEO 卫星' } }
  ];

  // Mackinder's 1904 Pivot Area, simplified to a longitude span. Drawn
  // as a faint shadow on the land band between these two longitudes.
  const PIVOT_LON = { west: 40, east: 145 };

  const ACCENT = '#b6604a';     // chokepoint markers + spokes
  const ACCENT_DK = '#8a3e2e';  // marker outline / dark accent

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
  };

  function currentLang() {
    const fhRoot = document.querySelector('.fh-root');
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => draw())
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  window.addEventListener('resize', () => draw());
  requestAnimationFrame(() => draw());

  // === geometry helpers ===

  // Map real-world longitude (-180..+180) to an angle alpha, measured in
  // degrees CCW from the positive x-axis (so alpha=0° is "right",
  // alpha=90° is "top", alpha=180° is "left", alpha=-90° is "bottom").
  // This puts lon=0 (Greenwich) on the right rim, lon=90E at the top,
  // lon=180/-180 on the left rim, lon=-90 at the bottom — i.e. the
  // viewer is looking at the Earth from above the North Pole.
  function lonToAlpha(lon) { return lon; }

  // Cartesian position on a circle of radius r at angle alphaDeg, in SVG
  // coordinates (y-axis inverted).
  function polar(cx, cy, r, alphaDeg) {
    const a = alphaDeg * Math.PI / 180;
    return { x: cx + r * Math.cos(a), y: cy - r * Math.sin(a) };
  }

  // Annular sector path between angles alphaStartDeg and alphaEndDeg
  // (going CCW from start to end), inner radius r0, outer radius r1.
  function sectorPath(cx, cy, r0, r1, alphaStartDeg, alphaEndDeg) {
    let span = alphaEndDeg - alphaStartDeg;
    while (span < 0)   span += 360;
    while (span > 360) span -= 360;
    const largeArc = span > 180 ? 1 : 0;
    const pOuterStart = polar(cx, cy, r1, alphaStartDeg);
    const pOuterEnd   = polar(cx, cy, r1, alphaEndDeg);
    const pInnerEnd   = polar(cx, cy, r0, alphaEndDeg);
    const pInnerStart = polar(cx, cy, r0, alphaStartDeg);
    // sweep-flag: in SVG (y-down), CCW in math = sweep=0
    return `M ${pOuterStart.x} ${pOuterStart.y} ` +
           `A ${r1} ${r1} 0 ${largeArc} 0 ${pOuterEnd.x} ${pOuterEnd.y} ` +
           `L ${pInnerEnd.x} ${pInnerEnd.y} ` +
           `A ${r0} ${r0} 0 ${largeArc} 1 ${pInnerStart.x} ${pInnerStart.y} Z`;
  }

  function draw() {
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(() => draw()); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const serifFont = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';
    const sansFont = 'Inter, "Noto Sans CJK", sans-serif';

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block');

    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ---- Title strip ----
    svg.append('text')
      .attr('x', 24).attr('y', 28)
      .attr('font-family', serifFont).attr('font-size', 18).attr('font-style', 'italic')
      .attr('fill', c.purpleD).attr('letter-spacing', '0.16em')
      .text(lang === 'zh' ? '地球的剖面 · 1904 ↔ 2026' : 'Section through the Earth · 1904 ↔ 2026');
    svg.append('text')
      .attr('x', W - 24).attr('y', 28)
      .attr('text-anchor', 'end')
      .attr('font-family', serifFont).attr('font-size', 12).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text(lang === 'zh' ? '六层 · 11 个咽喉点' : 'six layers · eleven chokepoints');

    // ---- Geometry ----
    // Layout budget: title strip up top, disk centred vertically with a
    // ring of chokepoint labels around it, footer at the bottom.
    const padTop      = 48;   // below the title strip
    const padBot      = 28;   // above the footer credit
    const labelMargin = 95;   // space the chokepoint label ring takes
                              // beyond the disk's outer rim
    const legendW     = 130;  // left-margin layer legend column
    const innerR      = 22;   // a small Earth core dot
    const cx = legendW + (W - legendW) / 2;
    const cy = (padTop + (H - padBot)) / 2;
    // Disk is sized by the smaller of the available half-axes minus the
    // label margin, so chokepoint labels never spill off the canvas.
    const outerR = Math.min(
      (W - legendW) / 2 - labelMargin - 30,
      Math.min(cy - padTop, H - padBot - cy) - labelMargin
    );
    const bandH = (outerR - innerR) / LAYERS.length;

    // ---- Defs: gradients + patterns ----
    const defs = svg.append('defs');

    const atmoGrad = defs.append('radialGradient')
      .attr('id', 'atmoGrad')
      .attr('cx', '50%').attr('cy', '50%').attr('r', '50%');
    atmoGrad.append('stop').attr('offset', '0%').attr('stop-color', '#cdd6d8');
    atmoGrad.append('stop').attr('offset', '100%').attr('stop-color', '#7d8e94');

    const stratPat = defs.append('pattern').attr('id', 'stratPat')
      .attr('patternUnits', 'userSpaceOnUse')
      .attr('width', 12).attr('height', 12)
      .attr('patternTransform', 'rotate(-12)');
    stratPat.append('rect').attr('width', 12).attr('height', 12).attr('fill', '#6b3f2c');
    stratPat.append('line').attr('x1', 0).attr('y1', 4).attr('x2', 12).attr('y2', 4)
      .attr('stroke', '#4a2a1c').attr('stroke-width', 0.6).attr('stroke-opacity', 0.5);
    stratPat.append('line').attr('x1', 0).attr('y1', 9).attr('x2', 12).attr('y2', 9)
      .attr('stroke', '#7c4f37').attr('stroke-width', 0.4).attr('stroke-opacity', 0.4);

    // ---- Concentric layer bands (annular rings) ----
    // Each band is a d3 ring (innerRadius..outerRadius across full 2π)
    // so inner bands aren't painted over by the outer ones.
    LAYERS.forEach((L, i) => {
      const r0 = innerR + i * bandH;
      const r1 = innerR + (i + 1) * bandH;
      const fill = L.id === 'atmo' ? 'url(#atmoGrad)'
                : L.id === 'sub'   ? 'url(#stratPat)'
                : L.fill;

      const ringPath = d3.arc()
        .innerRadius(r0).outerRadius(r1)
        .startAngle(0).endAngle(Math.PI * 2);

      svg.append('path')
        .attr('d', ringPath())
        .attr('transform', `translate(${cx}, ${cy})`)
        .attr('fill', fill)
        .attr('stroke', '#000').attr('stroke-opacity', 0.10).attr('stroke-width', 0.5);

      // Star field on orbit band — deterministic so it doesn't shimmer
      // on resize.
      if (L.id === 'orbit') {
        let seed = 5331;
        const rnd = () => { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };
        for (let k = 0; k < 220; k++) {
          const a  = rnd() * Math.PI * 2;
          const rr = r0 + rnd() * (r1 - r0);
          const sx = cx + rr * Math.cos(a);
          const sy = cy - rr * Math.sin(a);
          const sz = 0.3 + rnd() * 1.0;
          svg.append('circle').attr('cx', sx).attr('cy', sy).attr('r', sz)
            .attr('fill', '#fff8e5').attr('fill-opacity', 0.35 + rnd() * 0.5);
        }
      }
    });

    // ---- Mackinder Pivot 1904: faint shadow on the land band ----
    const landIdx = LAYERS.findIndex(L => L.id === 'land');
    const landR0 = innerR + landIdx * bandH;
    const landR1 = innerR + (landIdx + 1) * bandH;
    const pivotPath = sectorPath(cx, cy, landR0, landR1,
      lonToAlpha(PIVOT_LON.west), lonToAlpha(PIVOT_LON.east));
    svg.append('path')
      .attr('d', pivotPath)
      .attr('fill', '#6c6358').attr('fill-opacity', 0.28)
      .attr('stroke', '#6c6358').attr('stroke-opacity', 0.55)
      .attr('stroke-width', 0.8).attr('stroke-dasharray', '3 3');
    // Pivot label — placed at the band's mid-radius, mid-arc.
    {
      const midR = (landR0 + landR1) / 2;
      const midAlpha = (PIVOT_LON.west + PIVOT_LON.east) / 2;
      const pos = polar(cx, cy, midR, midAlpha);
      svg.append('text')
        .attr('x', pos.x).attr('y', pos.y)
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('font-family', serifFont).attr('font-size', 9).attr('font-style', 'italic')
        .attr('fill', '#3a3530').attr('opacity', 0.65).attr('letter-spacing', '0.06em')
        .text(lang === 'zh' ? '麦金德 1904 心脏地带' : 'Mackinder Pivot 1904');
    }

    // ---- Sea-level horizon ring ----
    // Boundary between sea-surface (i=3) and atmosphere (i=4).
    const seaLevelR = innerR + 4 * bandH;
    svg.append('circle')
      .attr('cx', cx).attr('cy', cy).attr('r', seaLevelR)
      .attr('fill', 'none')
      .attr('stroke', '#fff8e5').attr('stroke-opacity', 0.85).attr('stroke-width', 1.4);
    svg.append('circle')
      .attr('cx', cx).attr('cy', cy).attr('r', seaLevelR)
      .attr('fill', 'none')
      .attr('stroke', '#0a1428').attr('stroke-opacity', 0.55).attr('stroke-width', 1.4)
      .attr('stroke-dasharray', '6 4');

    // ---- Earth core (decorative dot at centre) ----
    svg.append('circle').attr('cx', cx).attr('cy', cy).attr('r', innerR)
      .attr('fill', '#8a3e2e');
    svg.append('text')
      .attr('x', cx).attr('y', cy + 3)
      .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
      .attr('font-family', sansFont).attr('font-size', 8.5)
      .attr('fill', '#fff8e5').attr('opacity', 0.85).attr('letter-spacing', '0.12em')
      .text(lang === 'zh' ? '地核' : 'core');

    // ---- Compass marks: longitudes at the rim ----
    const compass = [
      { lon: 0,    lab: '0°' },
      { lon: 90,   lab: '90°E' },
      { lon: 180,  lab: '180°' },
      { lon: -90,  lab: '90°W' }
    ];
    compass.forEach(m => {
      const a = lonToAlpha(m.lon);
      const p1 = polar(cx, cy, outerR, a);
      const p2 = polar(cx, cy, outerR + 6, a);
      svg.append('line').attr('x1', p1.x).attr('y1', p1.y).attr('x2', p2.x).attr('y2', p2.y)
        .attr('stroke', c.inkFaint).attr('stroke-width', 0.6);
      const p3 = polar(cx, cy, outerR + 16, a);
      svg.append('text')
        .attr('x', p3.x).attr('y', p3.y)
        .attr('text-anchor', 'middle').attr('dominant-baseline', 'middle')
        .attr('font-family', sansFont).attr('font-size', 9.5)
        .attr('fill', c.inkFaint).attr('letter-spacing', '0.04em')
        .text(m.lab);
    });

    // ---- Layer legend on the LEFT margin ----
    // A simple key with a coloured swatch per band, ordered from outer
    // (orbit) at top to inner (sub) at bottom — mirrors the visual
    // stacking on the disk's left side.
    const legX     = 16;
    const legTop   = padTop + 6;
    const legLineH = 30;
    LAYERS.slice().reverse().forEach((L, vi) => {
      const ly = legTop + vi * legLineH;
      const swatchFill = L.id === 'sub'  ? '#6b3f2c'
                       : L.id === 'atmo' ? '#a3afb2'
                       : L.fill;
      svg.append('rect')
        .attr('x', legX).attr('y', ly).attr('width', 14).attr('height', 14)
        .attr('fill', swatchFill)
        .attr('stroke', c.inkSoft).attr('stroke-width', 0.5);
      svg.append('text')
        .attr('x', legX + 20).attr('y', ly + 11)
        .attr('font-family', serifFont).attr('font-size', 12.5).attr('font-weight', 500)
        .attr('fill', c.ink)
        .text(L.label[lang]);
      svg.append('text')
        .attr('x', legX + 20).attr('y', ly + 23)
        .attr('font-family', sansFont).attr('font-size', 9)
        .attr('fill', c.inkFaint).attr('letter-spacing', '0.03em')
        .text(L.depth[lang]);
    });

    // ---- Chokepoints: marker + radial spoke + label ----
    // Two label-radius rings (alternating) to break up close-angle
    // collisions. Label radius is independent of layer, so spokes vary
    // in length but labels read at a consistent distance from the rim.
    const labelRA = outerR + 28;
    const labelRB = outerR + 70;

    // Sort by alpha so we can alternate between the two label rings
    // along the angular sweep.
    const ordered = CHOKEPOINTS
      .map((cp, idx) => ({ ...cp, _idx: idx, alpha: lonToAlpha(cp.lon) }))
      .sort((a, b) => a.alpha - b.alpha);

    ordered.forEach((cp, i) => {
      const layerIdx = LAYERS.findIndex(L => L.id === cp.layer);
      const r0 = innerR + layerIdx * bandH;
      const r1 = innerR + (layerIdx + 1) * bandH;
      const rMid = (r0 + r1) / 2;
      const a = cp.alpha;

      const labelR = i % 2 === 0 ? labelRA : labelRB;
      const pMarker = polar(cx, cy, rMid, a);
      const pLabel  = polar(cx, cy, labelR, a);

      // Spoke (marker → label)
      svg.append('line')
        .attr('x1', pMarker.x).attr('y1', pMarker.y)
        .attr('x2', pLabel.x).attr('y2', pLabel.y)
        .attr('stroke', ACCENT).attr('stroke-width', 0.8)
        .attr('stroke-dasharray', '3 3').attr('opacity', 0.55);

      // Marker dot — paper halo so it pops on dark bands too
      svg.append('circle')
        .attr('cx', pMarker.x).attr('cy', pMarker.y).attr('r', 5.5)
        .attr('fill', '#fff8e5').attr('fill-opacity', 0.95);
      svg.append('circle')
        .attr('cx', pMarker.x).attr('cy', pMarker.y).attr('r', 4)
        .attr('fill', ACCENT).attr('stroke', ACCENT_DK).attr('stroke-width', 1);

      // Label — text-anchor depends on which side of the disk the
      // chokepoint sits on, so labels grow outward away from the rim.
      const cosA = Math.cos(a * Math.PI / 180);
      const anchor = cosA >= 0 ? 'start' : 'end';
      const dx = cosA >= 0 ? 4 : -4;

      svg.append('text')
        .attr('x', pLabel.x + dx).attr('y', pLabel.y - 2)
        .attr('text-anchor', anchor).attr('dominant-baseline', 'alphabetic')
        .attr('font-family', sansFont).attr('font-size', 11.5).attr('font-weight', 600)
        .attr('fill', c.ink).attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.95)').attr('stroke-width', 3.5)
        .attr('stroke-linejoin', 'round')
        .text(cp.label[lang]);

      svg.append('text')
        .attr('x', pLabel.x + dx).attr('y', pLabel.y + 11)
        .attr('text-anchor', anchor).attr('dominant-baseline', 'alphabetic')
        .attr('font-family', serifFont).attr('font-size', 9.5).attr('font-style', 'italic')
        .attr('fill', c.inkSoft).attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.95)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(cp.note[lang]);
    });

    // ---- Footer credit ----
    svg.append('text')
      .attr('x', W - 12).attr('y', H - 6)
      .attr('text-anchor', 'end')
      .attr('font-family', serifFont).attr('font-size', 9).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text(lang === 'zh'
        ? 'Mackinder 1904 · Elden 2013 · Farrell & Newman 2023'
        : 'after Mackinder 1904 · Elden 2013 · Farrell & Newman 2023');
  }
</script>
