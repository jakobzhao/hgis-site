<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';
  import { feature } from 'https://esm.sh/topojson-client@3';

  // ===== Mackinder zones, drawn on the surface of a globe =====
  // The 1904 Pivot Area, simplified as a closed polygon over central +
  // northern Eurasia. Painted as a translucent purple wash over the land.
  const HEARTLAND = [
    [25, 60], [40, 50], [50, 45], [55, 35], [70, 35],
    [90, 38], [110, 42], [130, 50], [140, 60], [130, 75],
    [90, 78], [45, 70], [25, 60]
  ];
  const HEARTLAND_FEATURE = {
    type: 'Feature',
    geometry: { type: 'Polygon', coordinates: [HEARTLAND] }
  };

  // Spykman's 1942 Rimland — the coastal arc of Eurasia, where every
  // binding 2026 chokepoint actually sits. Drawn as a thick gold polyline.
  const RIMLAND = [
    [-9, 38], [3, 36], [10, 38], [25, 35], [35, 32], [43, 13],
    [50, 25], [56, 26], [66, 24], [76, 9], [80, 6], [90, 22],
    [100, 13], [104, 1], [108, 11], [114, 22], [121, 24],
    [127, 36], [139, 36], [143, 44]
  ];
  const RIMLAND_FEATURE = {
    type: 'Feature',
    geometry: { type: 'LineString', coordinates: RIMLAND }
  };

  // The geostationary belt projects down to the equator; tracing it as a
  // dashed line is the cleanest way to put "orbit" back on a surface.
  const EQUATOR_FEATURE = {
    type: 'Feature',
    geometry: {
      type: 'LineString',
      coordinates: d3.range(-180, 181, 5).map(lon => [lon, 0])
    }
  };

  // ===== Chokepoints — every one is a place on the surface =====
  // `zone` records which Mackinder/Spykman band the point sits in:
  //   heart = inside the Heartland polygon
  //   rim   = on the Rimland coastal arc
  //   outer = the Americas / sub-Saharan / Australia
  // Lat/lon are the actual surface manifestation. "Subterranean" lives
  // at the mine head, "orbit" at the launch site, "atmospheric closure"
  // at the capital that issued the closure — all genuine surface places.
  const CHOKEPOINTS = [
    // mining
    { lon: 109.5, lat: 41.8,  zone: 'heart', label: { en: 'Bayan Obo',         zh: '白云鄂博' },     note: { en: 'rare earth · ~70%',     zh: '稀土 · 约 70%' } },
    { lon: 26.0,  lat: -10.7, zone: 'outer', label: { en: 'DRC Copperbelt',    zh: '刚果铜带' },     note: { en: 'cobalt · ~74%',         zh: '钴 · 约 74%' } },
    // sea-floor cables
    { lon: 19.0,  lat: 58.0,  zone: 'rim',   label: { en: 'Baltic cables',     zh: '波罗的海光缆' }, note: { en: '4 cuts · 2024',         zh: '2024 切 4 条' } },
    { lon: 42.0,  lat: 17.0,  zone: 'rim',   label: { en: 'Red Sea cables',    zh: '红海光缆' },     note: { en: 'cuts · 2024',           zh: '2024 受切' } },
    // land-surface fabs / data
    { lon: 121.0, lat: 24.5,  zone: 'rim',   label: { en: 'TSMC · Hsinchu',    zh: '台积电 · 新竹' }, note: { en: '~90% leading-edge',    zh: '先进制程约 90%' } },
    { lon: 5.5,   lat: 51.4,  zone: 'rim',   label: { en: 'ASML · Veldhoven',  zh: 'ASML · 维尔德霍芬' }, note: { en: 'all EUV machines', zh: '全部 EUV 光刻机' } },
    { lon: -77.5, lat: 39.0,  zone: 'outer', label: { en: 'Loudoun · data',    zh: 'Loudoun · 数据' }, note: { en: '~70% of internet',    zh: '全球流量约 70%' } },
    { lon: 80.4,  lat: 44.0,  zone: 'heart', label: { en: 'Khorgos',           zh: '霍尔果斯' },     note: { en: 'Belt & Road land hub',  zh: '一带一路陆港' } },
    // sea-surface oil chokepoints
    { lon: 56.5,  lat: 26.5,  zone: 'rim',   label: { en: 'Hormuz',            zh: '霍尔木兹' },     note: { en: '~20% world oil',        zh: '全球约 20% 石油' } },
    { lon: 103.8, lat: 1.4,   zone: 'rim',   label: { en: 'Malacca',           zh: '马六甲' },       note: { en: '~25% world trade',      zh: '全球约 25% 贸易' } },
    // atmosphere — surface anchor: the capital that closed the airspace
    { lon: 37.6,  lat: 55.7,  zone: 'heart', label: { en: 'Moscow · airspace', zh: '莫斯科 · 领空' }, note: { en: 'closed Feb 2022',      zh: '2022.02 关闭' } },
    // orbit — surface anchor: launch base
    { lon: -120.6, lat: 34.7, zone: 'outer', label: { en: 'Vandenberg',        zh: '范登堡' },        note: { en: 'Starlink launches',     zh: 'Starlink 发射' } },
  ];

  const ACCENT    = '#b6604a';  // chokepoint dots
  const ACCENT_DK = '#8a3e2e';  // dot outline

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
  };

  function currentLang() {
    const fhRoot = document.querySelector('.fh-root');
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  // ===== Persistent rotation state across re-renders =====
  let _land = null;
  let _rotation = [-70, -25, 0];       // initial: Eurasia centred, slight N tilt
  let _autoRotate = true;
  let _hoverInside = false;
  let _draggingNow = false;
  let _resumeTimer = 0;
  let _dragStart = null;

  // Re-render on language toggle
  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => render())
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  window.addEventListener('resize', () => render());
  requestAnimationFrame(() => render());

  // Load world land — same dataset as the homepage globe.
  fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/land-110m.json')
    .then(r => r.json())
    .then(world => {
      _land = feature(world, world.objects.land);
      render();
    });

  // ===== Interactions: pointer drag + auto-rotate =====
  // Attached to #stage (not the SVG), so they survive the per-frame
  // SVG re-build. Idempotent via the `_mackHandlersAttached` flag.
  function attachStageHandlers() {
    const stage = document.getElementById('stage');
    if (!stage || stage._mackHandlersAttached) return;
    stage._mackHandlersAttached = true;

    stage.addEventListener('pointerenter', () => { _hoverInside = true; });
    stage.addEventListener('pointerleave', () => { _hoverInside = false; });

    stage.addEventListener('pointerdown', (e) => {
      // Don't hijack clicks meant for the watermark / expand button.
      if (e.target && e.target.closest && e.target.closest('.fh-watermark, .fh-expand-btn')) return;
      _autoRotate = false;
      _draggingNow = true;
      _dragStart = { x: e.clientX, y: e.clientY, rot: [..._rotation] };
      try { stage.setPointerCapture(e.pointerId); } catch (err) {}
    });
    stage.addEventListener('pointermove', (e) => {
      if (!_dragStart) return;
      const dx = e.clientX - _dragStart.x;
      const dy = e.clientY - _dragStart.y;
      const k = 0.4;
      _rotation = [
        _dragStart.rot[0] + dx * k,
        Math.max(-85, Math.min(85, _dragStart.rot[1] - dy * k)),
        _dragStart.rot[2]
      ];
      render();
    });
    function endDrag(e) {
      if (!_dragStart) return;
      _dragStart = null;
      _draggingNow = false;
      try { stage.releasePointerCapture(e.pointerId); } catch (err) {}
      clearTimeout(_resumeTimer);
      _resumeTimer = setTimeout(() => { _autoRotate = true; }, 1800);
    }
    stage.addEventListener('pointerup', endDrag);
    stage.addEventListener('pointercancel', endDrag);
  }

  // Auto-rotate timer — pauses while the cursor is over the figure or a
  // drag is in progress; the homepage globe uses the same pattern.
  let _lastT = 0;
  d3.timer(t => {
    if (!_autoRotate || _hoverInside || _draggingNow || !_land) {
      _lastT = t;
      return;
    }
    const dt = t - _lastT;
    _lastT = t;
    _rotation[0] += dt * 0.008;
    if (_rotation[0] > 180)  _rotation[0] -= 360;
    if (_rotation[0] < -180) _rotation[0] += 360;
    render();
  });

  // ===== Render =====
  function render() {
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(render); return; }

    attachStageHandlers();

    if (!_land) {
      // Loader placeholder until the world atlas arrives.
      if (!stage.querySelector('p.map-status')) {
        stage.innerHTML = '<p class="map-status"><span data-lang="en">Loading globe…</span><span data-lang="zh">地球加载中…</span></p>';
      }
      return;
    }

    stage.innerHTML = '';

    const lang = currentLang();
    const serifFont = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';
    const sansFont = 'Inter, "Noto Sans CJK", sans-serif';

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block')
      .style('overflow', 'hidden');

    // Background
    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ---- Title strip ----
    svg.append('text')
      .attr('x', 24).attr('y', 28)
      .attr('font-family', serifFont).attr('font-size', 18).attr('font-style', 'italic')
      .attr('fill', c.purpleD).attr('letter-spacing', '0.16em')
      .text(lang === 'zh' ? 'Mackinder 重画 · 1904 ↔ 2026' : 'Mackinder, redrawn · 1904 ↔ 2026');

    // Layout budget: title up top, footer down bottom, the map fills the middle.
    const padTop = 48;
    const padBot = 24;
    const cx = W / 2;
    const cy = (padTop + H - padBot) / 2;
    const R  = Math.min(W * 0.42, (H - padTop - padBot) * 0.50);

    const proj = d3.geoOrthographic()
      .scale(R)
      .translate([cx, cy])
      .clipAngle(90)
      .rotate(_rotation);
    const path = d3.geoPath(proj);

    // Sphere fill (deep night blue)
    svg.append('path').datum({type: 'Sphere'}).attr('d', path)
      .attr('fill', '#1f2734').attr('stroke', c.rule).attr('stroke-width', 0.6);

    // Soft inner radial shading — gives the planet a roundness
    const defs = svg.append('defs');
    const shade = defs.append('radialGradient')
      .attr('id', 'mack-sphere-shade')
      .attr('cx', '34%').attr('cy', '32%').attr('r', '70%');
    shade.append('stop').attr('offset', '0%').attr('stop-color', 'rgba(255,255,255,0.10)');
    shade.append('stop').attr('offset', '60%').attr('stop-color', 'rgba(255,255,255,0)');
    shade.append('stop').attr('offset', '100%').attr('stop-color', 'rgba(0,0,0,0.18)');
    svg.append('circle').attr('cx', cx).attr('cy', cy).attr('r', R)
      .attr('fill', 'url(#mack-sphere-shade)')
      .attr('pointer-events', 'none');

    // Graticule
    const grat = d3.geoGraticule10();
    svg.append('path').datum(grat).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#b5a57b')
      .attr('stroke-opacity', 0.18)
      .attr('stroke-width', 0.5);

    // Equator — surface trace of the GEO arc, the only "orbital" thing
    // that doesn't have a single ground point.
    svg.append('path').datum(EQUATOR_FEATURE).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#d8c581')
      .attr('stroke-opacity', 0.6)
      .attr('stroke-width', 1.2)
      .attr('stroke-dasharray', '5 4');

    // Land
    svg.append('path').datum(_land).attr('d', path)
      .attr('fill', '#e8dcbf')
      .attr('stroke', '#a89776')
      .attr('stroke-width', 0.45);

    // Heartland — purple wash polygon over central + northern Eurasia
    svg.append('path').datum(HEARTLAND_FEATURE).attr('d', path)
      .attr('fill', 'rgba(74, 62, 77, 0.42)')
      .attr('stroke', '#4a3e4d')
      .attr('stroke-opacity', 0.55)
      .attr('stroke-width', 1.0)
      .attr('stroke-dasharray', '5 4');

    // Rimland — gold thick stroke, with a warm inner highlight
    svg.append('path').datum(RIMLAND_FEATURE).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#b5a57b')
      .attr('stroke-opacity', 0.88)
      .attr('stroke-width', 6)
      .attr('stroke-linecap', 'round')
      .attr('stroke-linejoin', 'round');
    svg.append('path').datum(RIMLAND_FEATURE).attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', '#fff8d8')
      .attr('stroke-opacity', 0.6)
      .attr('stroke-width', 2.2)
      .attr('stroke-linecap', 'round')
      .attr('stroke-linejoin', 'round');

    // Visibility helper — points behind the horizon get hidden.
    const center = [-_rotation[0], -_rotation[1]];
    const visible = (lon, lat, margin = 0.02) =>
      d3.geoDistance([lon, lat], center) < Math.PI / 2 - margin;

    // Zone labels — drawn on the surface using the projection
    const ZONE_LABELS = [
      { lon: 80,   lat: 56, text: { en: 'HEARTLAND',      zh: '心脏地带' }, color: '#4a3e4d' },
      { lon: 88,   lat: 18, text: { en: 'RIMLAND',        zh: '边缘地带' }, color: '#7a6a3a' },
      { lon: -100, lat: 38, text: { en: 'OUTER CRESCENT', zh: '外新月' },   color: '#6c6358' },
    ];
    ZONE_LABELS.forEach(z => {
      if (!visible(z.lon, z.lat, 0.05)) return;
      const p = proj([z.lon, z.lat]);
      if (!p) return;
      svg.append('text')
        .attr('x', p[0]).attr('y', p[1])
        .attr('text-anchor', 'middle')
        .attr('fill', z.color)
        .attr('font-family', serifFont)
        .attr('font-style', 'italic')
        .attr('font-size', Math.max(11, R * 0.05))
        .attr('font-weight', 500)
        .attr('letter-spacing', '0.18em')
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.88)')
        .attr('stroke-width', 4)
        .attr('stroke-linejoin', 'round')
        .text(z.text[lang]);
    });

    // Chokepoints — only render the ones currently on the front of the globe.
    const cpG = svg.append('g').attr('class', 'fh-chokepoints');
    CHOKEPOINTS.forEach(cp => {
      if (!visible(cp.lon, cp.lat)) return;
      const p = proj([cp.lon, cp.lat]);
      if (!p) return;
      const g = cpG.append('g').attr('transform', `translate(${p[0]},${p[1]})`);
      g.append('circle').attr('r', 9).attr('fill', ACCENT).attr('fill-opacity', 0.20);
      g.append('circle').attr('r', 4).attr('fill', ACCENT_DK)
        .attr('stroke', '#fff8e5').attr('stroke-width', 1.2);
      const onRight = p[0] > cx;
      const dx = onRight ? 9 : -9;
      const anchor = onRight ? 'start' : 'end';
      g.append('text')
        .attr('x', dx).attr('y', 4)
        .attr('text-anchor', anchor)
        .attr('fill', c.ink)
        .attr('font-family', sansFont)
        .attr('font-size', Math.max(10, R * 0.032))
        .attr('font-weight', 600)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 3)
        .attr('stroke-linejoin', 'round')
        .text(cp.label[lang]);
    });

    // Footer credit — bottom-left so it doesn't collide with the
    // bottom-right HGIS Lab · Friday Harbor watermark.
    svg.append('text')
      .attr('x', 12).attr('y', H - 8)
      .attr('text-anchor', 'start')
      .attr('font-family', serifFont).attr('font-size', 9).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text('after Mackinder 1904 · Spykman 1942 · Farrell & Newman 2023');
  }
</script>
