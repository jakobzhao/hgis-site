<script type="module">
  import * as d3 from 'https://esm.sh/d3@7';

  // The six vertical layers, top → bottom. Each band gets a
  // colour, a label, an altitude/depth string, and an inline panel
  // drawn on its right side.
  const LAYERS = [
    { id: 'orbit',  label: { en: 'Orbit',          zh: '轨道' },     depth: { en: '+200 km — +36,000 km', zh: '+200 km — +36,000 km' },  fill: '#0a1428', text: '#e7e3d6' },
    { id: 'atmo',   label: { en: 'Atmosphere',     zh: '大气' },     depth: { en: '0 — +50 km',           zh: '0 — +50 km' },            fill: '#aab5b8', text: '#2c2823' },
    { id: 'sea',    label: { en: 'Sea surface',    zh: '海面' },     depth: { en: '+sea level',           zh: '+海平面' },               fill: '#7e92a3', text: '#fffdf7' },
    { id: 'floor',  label: { en: 'Sea floor',      zh: '海底' },     depth: { en: '−4,000 m avg.',        zh: '平均 −4,000 米' },        fill: '#2f4150', text: '#e7e3d6' },
    { id: 'land',   label: { en: 'Land surface',   zh: '地表' },     depth: { en: 'where Mackinder lived', zh: '麦金德的层' },           fill: '#e8d6c1', text: '#2c2823' },
    { id: 'sub',    label: { en: 'Subterranean',   zh: '地下' },     depth: { en: '−mantle · drill cores', zh: '−地幔 · 钻芯' },         fill: '#6b3f2c', text: '#fffdf7' }
  ];

  // Mackinder's 1904 Pivot Area, simplified to a rough lat/lon
  // polygon traced over the Eurasian heartland. Drawn as a faint
  // grey palimpsest on the land-surface band.
  const PIVOT_LONLAT = [
    [40, 47], [55, 54], [75, 60], [105, 67], [125, 70], [140, 65],
    [145, 55], [125, 50], [105, 47], [85, 45], [65, 41], [50, 40],
    [40, 47]
  ];

  const css = getComputedStyle(document.documentElement);
  const c = {
    paper:   css.getPropertyValue('--bg-card').trim()   || '#f5efe2',
    paper2:  css.getPropertyValue('--bg-deep').trim()   || '#ddd4c2',
    rule:    css.getPropertyValue('--rule').trim()      || '#d6cdbf',
    ink:     css.getPropertyValue('--ink').trim()       || '#2c2823',
    inkSoft: css.getPropertyValue('--ink-soft').trim()  || '#6c6358',
    inkFaint:css.getPropertyValue('--ink-faint').trim() || '#98907f',
    purple:  css.getPropertyValue('--uw-purple').trim() || '#6a5a6e',
    purpleD: css.getPropertyValue('--uw-purple-deep').trim() || '#4a3e4d',
  };
  const US_TONE = '#475569';
  const CN_TONE = '#8a3e2e';

  function currentLang() {
    const fhRoot = document.querySelector('.fh-root');
    return fhRoot && fhRoot.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
  }

  const fhRoot = document.querySelector('.fh-root');
  if (fhRoot) {
    new MutationObserver(() => draw())
      .observe(fhRoot, { attributes: true, attributeFilter: ['data-lang'] });
  }
  window.addEventListener('resize', () => draw());
  requestAnimationFrame(() => draw());

  function draw() {
    const stage = document.getElementById('stage');
    if (!stage) return;
    const W = stage.clientWidth | 0;
    const H = stage.clientHeight | 0;
    if (W < 50 || H < 50) { requestAnimationFrame(() => draw()); return; }
    stage.innerHTML = '';

    const lang = currentLang();
    const serifFont = lang === 'zh'
      ? '"Noto Serif SC", "Songti SC", serif'
      : '"Cormorant Garamond", Georgia, serif';
    const sansFont = 'Inter, "Noto Sans CJK", sans-serif';

    const svg = d3.select(stage).append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', W).attr('height', H)
      .style('display', 'block');

    svg.append('rect').attr('width', W).attr('height', H).attr('fill', c.paper);

    // ---- Textures used by certain bands (defined once via <defs>) ----
    const defs = svg.append('defs');

    // Atmospheric haze: vertical gradient from dark sky-blue (top) to
    // pale haze (bottom) — gives the band a real "sky column" feel.
    const atmoGrad = defs.append('linearGradient')
      .attr('id', 'atmoGrad')
      .attr('x1', 0).attr('y1', 0).attr('x2', 0).attr('y2', 1);
    atmoGrad.append('stop').attr('offset', '0%').attr('stop-color', '#7d8e94');
    atmoGrad.append('stop').attr('offset', '100%').attr('stop-color', '#cdd6d8');

    // Sea-floor water column: subtle vertical wave lines fading top → bottom
    const waterGrad = defs.append('linearGradient')
      .attr('id', 'waterGrad')
      .attr('x1', 0).attr('y1', 0).attr('x2', 0).attr('y2', 1);
    waterGrad.append('stop').attr('offset', '0%').attr('stop-color', '#4f6573');
    waterGrad.append('stop').attr('offset', '100%').attr('stop-color', '#1f2c34');

    // Subterranean strata pattern — diagonal hatching
    const stratPat = defs.append('pattern')
      .attr('id', 'stratPat')
      .attr('patternUnits', 'userSpaceOnUse')
      .attr('width', 16).attr('height', 16)
      .attr('patternTransform', 'rotate(-12)');
    stratPat.append('rect').attr('width', 16).attr('height', 16).attr('fill', '#6b3f2c');
    stratPat.append('line').attr('x1', 0).attr('y1', 5).attr('x2', 16).attr('y2', 5)
      .attr('stroke', '#4a2a1c').attr('stroke-width', 0.6).attr('stroke-opacity', 0.5);
    stratPat.append('line').attr('x1', 0).attr('y1', 12).attr('x2', 16).attr('y2', 12)
      .attr('stroke', '#7c4f37').attr('stroke-width', 0.4).attr('stroke-opacity', 0.4);

    // ---- Title ----
    svg.append('text')
      .attr('x', 24).attr('y', 26)
      .attr('font-family', serifFont).attr('font-size', 16).attr('font-style', 'italic')
      .attr('fill', c.purpleD).attr('letter-spacing', '0.16em')
      .text(lang === 'zh' ? '地球的剖面 · 1904 ↔ 2026' : 'Section through the Earth · 1904 ↔ 2026');
    svg.append('text')
      .attr('x', W - 24).attr('y', 26)
      .attr('text-anchor', 'end')
      .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text(lang === 'zh' ? '六层 · 六组咽喉点' : 'six layers · six chokepoint sets');

    // ---- Band geometry ----
    const padTop = 42;
    const padBot = 14;
    const labelColW = 165;     // left column for layer name + depth
    const panelStartX = labelColW + 24;
    const totalH = H - padTop - padBot;
    const bandH = totalH / LAYERS.length;

    // Compute band y-rects up front so panels can use them.
    const bands = LAYERS.map((L, i) => ({
      ...L,
      y: padTop + i * bandH,
      h: bandH
    }));

    // ---- Draw each band's background + label ----
    // Each band gets a section-style fill: the orbit gets a star
    // field, atmosphere a vertical haze gradient, sea floor a water
    // column gradient, subterranean a diagonal strata pattern. The
    // result reads as a slice through the Earth, not as a stacked bar
    // chart.
    bands.forEach((b, i) => {
      const fill = b.id === 'atmo'  ? 'url(#atmoGrad)'
                : b.id === 'floor' ? 'url(#waterGrad)'
                : b.id === 'sub'   ? 'url(#stratPat)'
                : b.fill;
      svg.append('rect')
        .attr('x', 0).attr('y', b.y)
        .attr('width', W).attr('height', b.h)
        .attr('fill', fill).attr('fill-opacity', i === 4 ? 1 : 0.95);

      // Layer-specific texture overlays
      if (b.id === 'orbit') {
        // Star field — deterministic pseudo-random so it doesn't
        // shimmer on re-renders.
        let seed = 1234;
        const rnd = () => { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };
        for (let k = 0; k < 140; k++) {
          const sx = rnd() * W;
          const sy = b.y + rnd() * b.h;
          const sr = 0.3 + rnd() * 1.0;
          svg.append('circle').attr('cx', sx).attr('cy', sy).attr('r', sr)
            .attr('fill', '#fff8e5').attr('fill-opacity', 0.35 + rnd() * 0.5);
        }
      }
      if (b.id === 'floor') {
        // Faint vertical "water column" reeds across the band
        for (let k = 0; k < 28; k++) {
          const wx = 4 + k * (W / 28);
          svg.append('line')
            .attr('x1', wx).attr('y1', b.y + 4)
            .attr('x2', wx).attr('y2', b.y + b.h - 4)
            .attr('stroke', '#fff8e5').attr('stroke-opacity', 0.04).attr('stroke-width', 0.6);
        }
      }

      // Hairline divider
      svg.append('line')
        .attr('x1', 0).attr('y1', b.y).attr('x2', W).attr('y2', b.y)
        .attr('stroke', '#000').attr('stroke-opacity', 0.10).attr('stroke-width', 0.5);

      // Layer name (left)
      svg.append('text')
        .attr('x', 24).attr('y', b.y + 22)
        .attr('font-family', serifFont).attr('font-size', 17).attr('font-weight', 500)
        .attr('fill', b.text)
        .text(b.label[lang]);

      // Depth/altitude tag
      svg.append('text')
        .attr('x', 24).attr('y', b.y + 38)
        .attr('font-family', sansFont).attr('font-size', 10)
        .attr('fill', b.text).attr('fill-opacity', 0.7)
        .attr('letter-spacing', '0.04em')
        .text(b.depth[lang]);
    });

    // ---- Strong "sea level" horizon line ----
    // Sits between the sea-surface band and the sea-floor band so the
    // diagram reads as a clear above/below split. Without it the six
    // bands look like a stacked bar chart, not a section.
    const seaLevelY = bands[3].y;   // top of sea-floor band == 0 m
    svg.append('line')
      .attr('x1', 0).attr('y1', seaLevelY).attr('x2', W).attr('y2', seaLevelY)
      .attr('stroke', '#fff8e5').attr('stroke-opacity', 0.85).attr('stroke-width', 1.5);
    svg.append('line')
      .attr('x1', 0).attr('y1', seaLevelY).attr('x2', W).attr('y2', seaLevelY)
      .attr('stroke', '#0a1428').attr('stroke-opacity', 0.55).attr('stroke-width', 1.5)
      .attr('stroke-dasharray', '6 4');
    svg.append('text')
      .attr('x', W - 16).attr('y', seaLevelY - 5)
      .attr('text-anchor', 'end')
      .attr('font-family', serifFont).attr('font-size', 10).attr('font-style', 'italic')
      .attr('fill', '#fff8e5').attr('fill-opacity', 0.95)
      .attr('letter-spacing', '0.08em')
      .text(lang === 'zh' ? '——海平面 0 m——' : '— sea level · 0 m —');

    // ---- Layer 1: Orbit — small constellation sphere + bars ----
    const orbit = bands[0];
    drawOrbitPanel(svg, panelStartX, orbit.y, W - panelStartX - 12, orbit.h, lang, sansFont, serifFont);

    // ---- Layer 2: Atmosphere — drone/missile event marks ----
    const atmo = bands[1];
    drawAtmospherePanel(svg, panelStartX, atmo.y, W - panelStartX - 12, atmo.h, lang, sansFont, serifFont);

    // ---- Layer 3: Sea surface — three routes (Suez/Cape/NSR) ----
    const sea = bands[2];
    drawSeaSurfacePanel(svg, panelStartX, sea.y, W - panelStartX - 12, sea.h, lang, sansFont, serifFont);

    // ---- Layer 4: Sea floor — four cable-cut events ----
    const floor = bands[3];
    drawSeafloorPanel(svg, panelStartX, floor.y, W - panelStartX - 12, floor.h, lang, sansFont, serifFont);

    // ---- Layer 5: Land — Mackinder ghost + modern pivots ----
    const land = bands[4];
    drawLandPanel(svg, panelStartX, land.y, W - panelStartX - 12, land.h, lang, sansFont, serifFont);

    // ---- Layer 6: Subterranean — mineral concentration bars ----
    const sub = bands[5];
    drawSubPanel(svg, panelStartX, sub.y, W - panelStartX - 12, sub.h, lang, sansFont, serifFont);

    // ---- Footer credit / date ----
    svg.append('text')
      .attr('x', W - 12).attr('y', H - 4)
      .attr('text-anchor', 'end')
      .attr('font-family', serifFont).attr('font-size', 9).attr('font-style', 'italic')
      .attr('fill', c.inkFaint)
      .text(lang === 'zh'
        ? 'Mackinder 1904 · Elden 2013 · Farrell & Newman 2023'
        : 'after Mackinder 1904 · Elden 2013 · Farrell & Newman 2023');
  }

  // ---------------- Layer panels ----------------

  function drawOrbitPanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Small Earth + concentric LEO/MEO/GEO arcs with satellites as dots
    const cx = x + 70, cy = y + h / 2, r = Math.min(h * 0.35, 26);
    const sky = '#0c1b3a';
    // background patch (subtle vignette darker than the band)
    svg.append('circle').attr('cx', cx).attr('cy', cy).attr('r', r * 3.6)
      .attr('fill', sky).attr('opacity', 0.18);
    // Earth
    svg.append('circle').attr('cx', cx).attr('cy', cy).attr('r', r)
      .attr('fill', '#3a5c8a').attr('stroke', '#fff8e5').attr('stroke-opacity', 0.4)
      .attr('stroke-width', 0.5);
    // LEO arc (Starlink) — many small dots
    [r * 1.45, r * 1.78, r * 2.15].forEach((rr, ringIdx) => {
      svg.append('circle').attr('cx', cx).attr('cy', cy).attr('r', rr)
        .attr('fill', 'none').attr('stroke', '#fff8e5').attr('stroke-opacity', 0.18)
        .attr('stroke-dasharray', '1.5 3').attr('stroke-width', 0.6);
      const dotCount = ringIdx === 0 ? 22 : ringIdx === 1 ? 14 : 8;
      for (let k = 0; k < dotCount; k++) {
        const a = (k / dotCount) * Math.PI * 2 + ringIdx * 0.4;
        svg.append('circle')
          .attr('cx', cx + rr * Math.cos(a))
          .attr('cy', cy + rr * Math.sin(a))
          .attr('r', ringIdx === 0 ? 0.9 : 1.2)
          .attr('fill', '#ffe7a3').attr('fill-opacity', 0.85);
      }
    });

    // Right side: vertical bars showing constellation sizes (log scale)
    const barX = x + 165;
    const barTopY = y + 14;
    const barH = h - 28;
    const data = [
      { n: 9357,  label: 'Starlink',  fill: '#e7d49a' },
      { n: 650,   label: 'OneWeb',    fill: '#b1a982' },
      { n: 200,   label: 'Kuiper',    fill: '#8a8268' },
      { n: 15000, label: lang === 'zh' ? '中国目标' : 'CN target', fill: CN_TONE, dashed: true }
    ];
    const maxN = 15000;
    const yScale = d3.scaleLog().domain([10, maxN]).range([barH, 0]);
    const barW = 18;
    const gap = 14;
    data.forEach((d, i) => {
      const bx = barX + i * (barW + gap);
      const topY = barTopY + yScale(d.n);
      svg.append('rect')
        .attr('x', bx).attr('y', topY).attr('width', barW).attr('height', barTopY + barH - topY)
        .attr('fill', d.fill).attr('fill-opacity', d.dashed ? 0.45 : 0.95)
        .attr('stroke', d.dashed ? CN_TONE : 'none')
        .attr('stroke-dasharray', d.dashed ? '3 3' : null)
        .attr('stroke-width', d.dashed ? 1 : 0);
      svg.append('text')
        .attr('x', bx + barW / 2).attr('y', topY - 4)
        .attr('text-anchor', 'middle').attr('font-family', sansFont)
        .attr('font-size', 9).attr('fill', '#fff8e5').attr('fill-opacity', 0.95)
        .text(d.n.toLocaleString());
      svg.append('text')
        .attr('x', bx + barW / 2).attr('y', barTopY + barH + 11)
        .attr('text-anchor', 'middle').attr('font-family', sansFont)
        .attr('font-size', 9).attr('fill', '#fff8e5').attr('fill-opacity', 0.65)
        .text(d.label);
    });

    // Right-most stat callout: Crimea-Starlink anecdote
    const annoX = x + barX + 4 * (barW + gap) + 30;
    svg.append('text').attr('x', annoX).attr('y', y + h * 0.42)
      .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
      .attr('fill', '#fff8e5').attr('fill-opacity', 0.95)
      .text(lang === 'zh' ? '"私人 CEO 一念之差…"' : '"one CEO\'s decision…"');
    svg.append('text').attr('x', annoX).attr('y', y + h * 0.62)
      .attr('font-family', sansFont).attr('font-size', 9).attr('fill', '#fff8e5').attr('fill-opacity', 0.7)
      .text(lang === 'zh' ? '克里米亚 2022' : 'Crimea, 2022');
  }

  function drawAtmospherePanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Sparse event marks for drone/missile theatres
    const events = [
      { en: 'Red Sea drones',     zh: '红海无人机',     n: 190 },
      { en: 'Taiwan Strait flyovers', zh: '台海越线', n: 6000 },
      { en: 'Ukraine drone swarms', zh: '乌克兰蜂群', n: 'daily' }
    ];
    const cellW = (w - 30) / events.length;
    events.forEach((e, i) => {
      const ex = x + 6 + i * cellW;
      const ey = y + h / 2;
      // dotted plume
      for (let k = 0; k < 18; k++) {
        svg.append('circle')
          .attr('cx', ex + (k % 6) * 6 + Math.random() * 3)
          .attr('cy', ey - 18 + Math.floor(k / 6) * 8 + Math.random() * 3)
          .attr('r', 1.1)
          .attr('fill', c.purpleD).attr('fill-opacity', 0.4);
      }
      // label
      svg.append('text').attr('x', ex + 50).attr('y', ey - 4)
        .attr('font-family', sansFont).attr('font-size', 11).attr('font-weight', 600)
        .attr('fill', c.ink)
        .text(e[lang]);
      svg.append('text').attr('x', ex + 50).attr('y', ey + 10)
        .attr('font-family', sansFont).attr('font-size', 9.5)
        .attr('fill', c.inkSoft).attr('font-style', 'italic')
        .text(typeof e.n === 'number' ? `${e.n}+ ${lang === 'zh' ? '次' : 'incidents'}` : (lang === 'zh' ? '每日' : 'daily'));
    });
  }

  function drawSeaSurfacePanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Three routes side by side: Suez (red, broken), Cape (active),
    // Northern Sea Route (active arctic).
    const routes = [
      {
        id: 'suez',
        name: lang === 'zh' ? '苏伊士' : 'Suez',
        sub: lang === 'zh' ? '−58% 通过量' : '−58% transits',
        color: c.purpleD,
        broken: true
      },
      {
        id: 'cape',
        name: lang === 'zh' ? '好望角绕道' : 'Cape re-route',
        sub: lang === 'zh' ? '+11,000 海里' : '+11,000 nm',
        color: c.inkSoft,
        broken: false
      },
      {
        id: 'nsr',
        name: lang === 'zh' ? '北方海航线' : 'NSR',
        sub: lang === 'zh' ? '37.9 Mt（2024）' : '37.9 Mt (2024)',
        color: '#5d6e8a',
        broken: false
      }
    ];
    const cellW = w / 3;
    routes.forEach((r, i) => {
      const cx = x + i * cellW + cellW / 2;
      const lineY = y + h * 0.4;
      // little route line motif
      const x0 = cx - 50, x1 = cx + 50;
      svg.append('path')
        .attr('d', `M ${x0} ${lineY} Q ${cx} ${lineY - 14} ${x1} ${lineY}`)
        .attr('fill', 'none')
        .attr('stroke', r.color).attr('stroke-width', 2)
        .attr('stroke-dasharray', r.broken ? '2 4' : null);
      if (r.broken) {
        svg.append('text').attr('x', cx).attr('y', lineY + 4)
          .attr('text-anchor', 'middle')
          .attr('font-size', 14).attr('fill', c.purpleD)
          .text('×');
      }
      svg.append('text').attr('x', cx).attr('y', lineY + 22)
        .attr('text-anchor', 'middle')
        .attr('font-family', sansFont).attr('font-size', 11).attr('font-weight', 600)
        .attr('fill', '#fff')
        .text(r.name);
      svg.append('text').attr('x', cx).attr('y', lineY + 36)
        .attr('text-anchor', 'middle')
        .attr('font-family', sansFont).attr('font-size', 9.5).attr('font-style', 'italic')
        .attr('fill', '#fff').attr('fill-opacity', 0.8)
        .text(r.sub);
    });
  }

  function drawSeafloorPanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Cable lines + 4 incident pins clustered in the Baltic region of
    // the band, plus a side caption of the 95% data figure.
    const lineY = y + h * 0.55;
    // many faint cables across width
    for (let k = 0; k < 14; k++) {
      const yy = y + 12 + k * ((h - 24) / 13);
      svg.append('line')
        .attr('x1', x + 4).attr('y1', yy).attr('x2', x + w * 0.55).attr('y2', yy)
        .attr('stroke', '#cdd2c8').attr('stroke-opacity', 0.18).attr('stroke-width', 0.8);
    }
    // cluster of 4 cut events
    const incidents = [
      { name: 'Newnew Polar Bear', date: '2023-10' },
      { name: 'Yi Peng 3',         date: '2024-11' },
      { name: 'Yi Peng 3 (2)',     date: '2024-11' },
      { name: 'Eagle S',           date: '2024-12' }
    ];
    const startX = x + 30;
    incidents.forEach((it, i) => {
      const ix = startX + i * 70;
      const iy = lineY;
      svg.append('circle')
        .attr('cx', ix).attr('cy', iy).attr('r', 11)
        .attr('fill', '#c44a3a').attr('fill-opacity', 0.25);
      svg.append('circle')
        .attr('cx', ix).attr('cy', iy).attr('r', 4.5)
        .attr('fill', '#c44a3a');
      svg.append('text').attr('x', ix).attr('y', iy - 15)
        .attr('text-anchor', 'middle')
        .attr('font-family', sansFont).attr('font-size', 9).attr('fill', '#fff8e5')
        .text(it.date);
      svg.append('text').attr('x', ix).attr('y', iy + 25)
        .attr('text-anchor', 'middle')
        .attr('font-family', sansFont).attr('font-size', 8.5).attr('fill', '#fff8e5').attr('fill-opacity', 0.7)
        .text(it.name);
    });
    // Right caption: 95% data figure
    const capX = x + w * 0.66;
    svg.append('text').attr('x', capX).attr('y', y + h * 0.32)
      .attr('font-family', serifFont).attr('font-size', 22).attr('font-weight', 500)
      .attr('fill', '#fff8e5')
      .text('~ 95%');
    svg.append('text').attr('x', capX).attr('y', y + h * 0.55)
      .attr('font-family', sansFont).attr('font-size', 10).attr('fill', '#fff8e5').attr('fill-opacity', 0.85)
      .text(lang === 'zh' ? '跨洲数据走海底光缆' : 'inter-continental data on cables');
    svg.append('text').attr('x', capX).attr('y', y + h * 0.74)
      .attr('font-family', sansFont).attr('font-size', 9).attr('fill', '#fff8e5').attr('fill-opacity', 0.6)
      .attr('font-style', 'italic')
      .text(lang === 'zh' ? '4 起波罗的海事件 · 2024' : '4 Baltic incidents · 2024');
  }

  function drawLandPanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // The land band is the visual centrepiece. We draw a faint
    // equirectangular world hint behind the data, then overlay
    // Mackinder's 1904 Pivot Area as a light grey palimpsest, and
    // finally pin the modern chokepoints (Taiwan, Loudoun, ASML).
    const padX = 8, padY = 8;
    const innerW = w - padX * 2;
    const innerH = h - padY * 2;
    const x0 = x + padX, y0 = y + padY;

    // Equirectangular projection: lon ∈ [-180, 180] → x, lat ∈ [-60, 75] → y
    const proj = (lon, lat) => {
      const lonN = (lon + 180) / 360;
      const latN = 1 - (lat + 60) / 135;
      return [x0 + lonN * innerW, y0 + latN * innerH];
    };

    // Faint horizontal bands as lat lines
    [-30, 0, 30, 60].forEach(lat => {
      const [, py] = proj(0, lat);
      svg.append('line')
        .attr('x1', x0).attr('y1', py).attr('x2', x0 + innerW).attr('y2', py)
        .attr('stroke', c.inkFaint).attr('stroke-opacity', 0.18).attr('stroke-width', 0.5)
        .attr('stroke-dasharray', '2 4');
    });

    // Mackinder's Pivot — palimpsest fill + dashed outline
    const pivotPath = 'M ' + PIVOT_LONLAT.map(([ln, lt]) => proj(ln, lt).join(',')).join(' L ') + ' Z';
    svg.append('path').attr('d', pivotPath)
      .attr('fill', c.inkSoft).attr('fill-opacity', 0.10)
      .attr('stroke', c.inkSoft).attr('stroke-opacity', 0.55)
      .attr('stroke-dasharray', '4 3').attr('stroke-width', 0.9);
    // Pivot label, italic, centered on the polygon
    const pivotCenter = proj(95, 56);
    svg.append('text').attr('x', pivotCenter[0]).attr('y', pivotCenter[1])
      .attr('text-anchor', 'middle')
      .attr('font-family', serifFont).attr('font-size', 11).attr('font-style', 'italic')
      .attr('fill', c.inkSoft).attr('fill-opacity', 0.85)
      .text(lang === 'zh' ? 'Mackinder 1904 「Pivot」' : 'Mackinder 1904 "Pivot Area"');

    // Modern pivots — small terracotta dots
    const pivots = [
      { lon: 121.0,  lat: 23.7,  label: 'Taiwan · TSMC' },
      { lon: -77.55, lat: 39.05, label: 'Loudoun, VA' },
      { lon: 5.41,   lat: 51.43, label: 'Veldhoven · ASML' },
      { lon: 110.0,  lat: 41.0,  label: lang === 'zh' ? '内蒙古' : 'Inner Mongolia' },
      { lon: -98.7,  lat: 32.45, label: 'Abilene · Stargate' },
      { lon: -90.05, lat: 35.15, label: 'Memphis · Colossus' }
    ];
    pivots.forEach(p => {
      const [px, py] = proj(p.lon, p.lat);
      svg.append('circle').attr('cx', px).attr('cy', py).attr('r', 6)
        .attr('fill', '#c44a3a').attr('fill-opacity', 0.30);
      svg.append('circle').attr('cx', px).attr('cy', py).attr('r', 2.6)
        .attr('fill', '#8a3e2e');
      svg.append('text').attr('x', px + 7).attr('y', py + 3)
        .attr('font-family', sansFont).attr('font-size', 9).attr('fill', c.ink)
        .attr('paint-order', 'stroke')
        .attr('stroke', 'rgba(245,239,226,0.92)').attr('stroke-width', 2.2)
        .attr('stroke-linejoin', 'round')
        .text(p.label);
    });
  }

  function drawSubPanel(svg, x, y, w, h, lang, sansFont, serifFont) {
    // Horizontal stacked bars for top-3 refining concentration of
    // each critical mineral. Country colour map approximates the data.
    const data = [
      { mineral: lang === 'zh' ? '镓 (refined)'      : 'Gallium (refined)',  CN: 98 },
      { mineral: lang === 'zh' ? '石墨 (refined)'    : 'Graphite (refined)', CN: 77 },
      { mineral: lang === 'zh' ? '稀土 (refined)'    : 'Rare earths (ref.)', CN: 69 },
      { mineral: lang === 'zh' ? '钴 (mined)'        : 'Cobalt (mined)',      DRC: 74 },
      { mineral: lang === 'zh' ? '镍 (mined)'        : 'Nickel (mined)',      ID: 50 }
    ];
    const padX = 6, padY = 8;
    const labelW = 130;
    const barLeft = x + padX + labelW;
    const barRight = x + w - padX - 10;
    const barW = barRight - barLeft;
    const rowH = (h - padY * 2) / data.length;

    data.forEach((d, i) => {
      const ry = y + padY + i * rowH + rowH * 0.18;
      const rh = rowH * 0.55;

      // Background bar (the "rest of the world")
      svg.append('rect').attr('x', barLeft).attr('y', ry)
        .attr('width', barW).attr('height', rh)
        .attr('fill', '#fff').attr('fill-opacity', 0.18);

      // Dominant share
      const v = d.CN || d.DRC || d.ID;
      const dom = d.CN ? '#e0a36a' : (d.DRC ? '#d4815e' : '#b9774a');
      svg.append('rect').attr('x', barLeft).attr('y', ry)
        .attr('width', barW * (v / 100)).attr('height', rh)
        .attr('fill', dom).attr('fill-opacity', 0.95);

      // Mineral label
      svg.append('text').attr('x', x + padX).attr('y', ry + rh / 2 + 4)
        .attr('font-family', sansFont).attr('font-size', 10).attr('font-weight', 500)
        .attr('fill', '#fff8e5')
        .text(d.mineral);

      // Country code label inside bar
      const countryCode = d.CN ? (lang === 'zh' ? '中国' : 'China')
                       : d.DRC ? (lang === 'zh' ? '刚果(金)' : 'DRC')
                       : 'Indonesia';
      svg.append('text').attr('x', barLeft + 6).attr('y', ry + rh / 2 + 4)
        .attr('font-family', sansFont).attr('font-size', 10).attr('font-weight', 600)
        .attr('fill', '#3a2118')
        .text(`${countryCode} ${v}%`);
    });
  }
</script>
