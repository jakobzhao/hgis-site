---
import BaseLayout from '../layouts/BaseLayout.astro';

const themes = [
  {
    slug: 'humanistic',
    title: 'Humanistic GIS',
    desc: 'Rethinking GIS as a medium for poetic dwelling on the digital earth — joining critical theory, care ethics, and cartographic practice. We study the social implications of emerging GIS technologies and develop methods that keep human meaning, memory, and ambiguity at the center.',
    keywords: ['critical GIS', 'care ethics', 'digital geohumanities', 'place'],
  },
  {
    slug: 'fake',
    title: 'Fake Geographies',
    desc: 'How do deepfake satellite imagery, location spoofing, and synthetic places challenge what we mean by spatial truth? The lab investigates the technical, ethical, and epistemological consequences of geospatial misinformation in a post-truth world.',
    keywords: ['deepfake geography', 'location spoofing', 'post-truth', 'misinformation'],
  },
  {
    slug: 'geoai',
    title: 'Geospatial AI &amp; Spatial Data Science',
    desc: 'GeoAI uncertainty, ethics, and the limits of automation. We build and critique large-scale spatial models — from Earth embeddings to neural sensing of emotion — and ask what placelessness, bias, and reflexivity mean for the next generation of geographic intelligence.',
    keywords: ['GeoAI', 'spatial data science', 'ethics', 'reflexivity'],
  },
];

// Penrose triangle paths from the official lab logo
// (Logo/logo-uw-long.svg). Three impossible bars, one per research theme.
const logoPaths = {
  humanistic: 'M299.2,565.6L175,791.6l22.8,41l103-186.7l57.5,105.9h45.5L299.2,565.6z',
  geoai:      'M300.8,645.9l22.7,41.8l-58.4,103.9l205.9,0.1l-21.7,42l-251.5-1.2L300.8,645.9z',
  fake:       'M299.2,565.6l104.5,186.1l-116.2,0.1l-22.3,39.8l205.8,0L345.5,565.5L299.2,565.6z',
};
const logoViewBox = '160 555 325 290';


const grants = [
  { years: '2020—24', title: 'Examining Shifting Geographies of Historically Underrepresented Groups', sponsor: 'NSF Human-Environment and Geographical Sciences (1951072)', amount: '$395,839', role: 'Co-PI' },
  { years: '2019—21', title: 'Coastal Hazard Planning in Time', sponsor: 'NSF Coastlines and People EAGER (1940024)', amount: '$297,288', role: 'Co-PI' },
  { years: '2024', title: 'GeoAI for Social Sciences and Humanities', sponsor: 'UW Data Science Minor Grant', amount: '$12,800', role: 'PI' },
  { years: '2023', title: 'Critical and Creative (Un)Mapping of the Capitol Hill Organized Protest', sponsor: 'UW Humanities Data Science Summer Institute', amount: '~$22,000', role: 'Co-PI' },
  { years: '2022', title: 'Detecting Deepfaked Satellite Imagery with Machine Learning', sponsor: 'Samsung / Joule', amount: '$64,970', role: 'PI' },
  { years: '2022', title: 'Better Methods to Enumerate Individuals Experiencing Homelessness', sponsor: 'UW Population Health Initiative', amount: '$106,822', role: 'Co-PI' },
  { years: '2022', title: 'Web Programming for GIS Applications', sponsor: 'UW Data Science Minor Grant', amount: '$20,000', role: 'PI' },
  { years: '2021—22', title: 'Improving Enumeration of Homelessness Using Cell Phone Location Data', sponsor: 'Urban@UW Research Spark', amount: '$19,299', role: 'Co-PI' },
  { years: '2020—21', title: 'CORAL Study (PETAL Network)', sponsor: 'NIH NHLBI (3U01HL123009-06S2)', amount: '$69,173', role: 'Site PI' },
  { years: '2020', title: 'COVID-19 Smart Dashboard for Risk to Washington Workers', sponsor: 'UW Population Health Initiative', amount: '$19,537', role: 'PI' },
  { years: '2018—19', title: 'The Global Refugee Atlas', sponsor: 'National Geographic (NGS-51699S-18)', amount: '$68,383', role: 'PI' },
  { years: '2018—19', title: 'Fanno Creek Watershed Geovisualization', sponsor: 'Clean Water Service', amount: '$50,000', role: 'PI' },
  { years: '2015—16', title: 'Rajawali Fellowship', sponsor: "Harvard Kennedy School", amount: '$50,000', role: 'PI' },
];
---
<BaseLayout
  title="Research"
  description="Research themes of the Humanistic GIS Lab: humanistic GIS, fake geographies, GeoAI ethics, and spatial data science. Selected NSF / NIH / National Geographic-funded projects."
>
  <section class="container section">
    <span class="eyebrow">Research</span>
    <h1>Themes &amp; methods</h1>

    <figure class="penrose" aria-label="Penrose triangle — the lab's logo, with each side standing for one of the three research themes">
      <svg viewBox={logoViewBox} xmlns="http://www.w3.org/2000/svg" role="img">
        <path class="bar bar-humanistic" data-theme="humanistic" pathLength="100" d={logoPaths.humanistic} />
        <path class="bar bar-geoai"      data-theme="geoai"      pathLength="100" d={logoPaths.geoai} />
        <path class="bar bar-fake"       data-theme="fake"       pathLength="100" d={logoPaths.fake} />
      </svg>
      <figcaption>
        <span class="dot dot-humanistic"></span> Humanistic GIS
        <span class="sep" aria-hidden="true">·</span>
        <span class="dot dot-fake"></span> Fake Geographies
        <span class="sep" aria-hidden="true">·</span>
        <span class="dot dot-geoai"></span> GeoAI
      </figcaption>
    </figure>

    <p class="lede dropcap">We study how places carry meaning, memory, and power — and we build new tools to represent that meaning cartographically.</p>

    <div class="theme-grid">
      {themes.map(t => (
        <article class="theme" data-theme={t.slug}>
          <h3 set:html={t.title}></h3>
          <p>{t.desc}</p>
          <ul class="kw">{t.keywords.map(k => <li>{k}</li>)}</ul>
        </article>
      ))}
    </div>

    <h2 class="grants-heading">Selected funded research</h2>
    <p class="lede small">A partial list of awarded grants supporting work in the lab. The full record is in the <a href="/cv/">CV</a>.</p>
    <table class="grants">
      <thead>
        <tr><th>Years</th><th>Project</th><th>Sponsor</th><th>Amount</th><th>Role</th></tr>
      </thead>
      <tbody>
        {grants.map(g => (
          <tr>
            <td class="years">{g.years}</td>
            <td><strong>{g.title}</strong></td>
            <td>{g.sponsor}</td>
            <td class="amt">{g.amount}</td>
            <td>{g.role}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>

<style>
  .lede { font-size: 1.15rem; color: var(--ink-soft); max-width: 65ch; }
  .lede.small { font-size: 1rem; }
  .theme-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    margin-top: 2rem;
  }
  .theme {
    padding: 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--bg-card);
  }
  .theme h3 { margin-top: 0; color: var(--uw-purple); }
  .kw {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .kw li {
    font-size: 0.78rem;
    background: var(--rule-soft);
    color: var(--uw-purple);
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
  }
  .grants-heading {
    margin-top: 3rem;
    color: var(--uw-purple);
    font-size: 1.5rem;
  }
  table.grants {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.2rem;
    font-size: 0.92rem;
  }
  table.grants th {
    text-align: left;
    color: var(--ink-faint);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    padding: 0.5rem 0.5rem;
    border-bottom: 2px solid var(--uw-purple);
  }
  table.grants td {
    padding: 0.7rem 0.5rem;
    border-bottom: 1px dotted var(--rule-soft);
    vertical-align: top;
  }
  td.years, td.amt {
    font-variant-numeric: tabular-nums;
    color: var(--uw-gold);
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    table.grants thead { display: none; }
    table.grants tr {
      display: grid;
      grid-template-columns: 1fr;
      padding: 0.7rem 0;
      border-bottom: 1px solid var(--rule);
    }
    table.grants td { padding: 0.15rem 0; border-bottom: 0; }
    table.grants td::before {
      content: attr(data-label);
      color: var(--ink-faint);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      display: block;
    }
  }

  /* Penrose triangle — three phases:
     1. Entry: each bar's outline strokes in, then fill fades in
     2. Idle (after .is-running): SVG wobbles ±2deg + a highlight chases
        through the three bars in cyclic order (Mobius flow)
     3. Hover: wobble pauses, chase speeds up to 4s/cycle */
  .penrose {
    margin: 1.5rem 0 1.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    --c-humanistic: var(--uw-purple);
    --c-geoai: var(--uw-gold);
    --c-fake: var(--mist);
    --c-fake-stroke: var(--ink-faint);
  }
  .penrose svg {
    width: 240px;
    height: auto;
    overflow: visible;
    transform-origin: center center;
  }
  .penrose .bar {
    /* phase 1 base: invisible fill, dasharray ready for stroke-draw */
    fill-opacity: 0;
    stroke-width: 1.6;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: bar-enter 1.4s cubic-bezier(0.5, 0, 0.2, 1) forwards;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }
  .bar-humanistic { fill: var(--c-humanistic); stroke: var(--c-humanistic); animation-delay: 0.1s; }
  .bar-geoai      { fill: var(--c-geoai);      stroke: var(--c-geoai);      animation-delay: 0.55s; }
  .bar-fake       { fill: var(--c-fake);       stroke: var(--c-fake-stroke); animation-delay: 1.0s; }

  /* Entry: 0-55% strokes the outline; 55-100% the stroke fades and the
     fill comes in. Final state is fill-only (stroke-opacity 0). */
  @keyframes bar-enter {
    0%   { stroke-dashoffset: 100; fill-opacity: 0; stroke-opacity: 1; }
    55%  { stroke-dashoffset: 0;   fill-opacity: 0; stroke-opacity: 1; }
    100% { stroke-dashoffset: 0;   fill-opacity: 1; stroke-opacity: 0; }
  }

  /* Phase 2: idle. JS adds .is-running ~2.6s after entry begins. */
  .penrose.is-running svg {
    animation: penrose-wobble 12s ease-in-out infinite;
  }
  .penrose.is-running .bar {
    /* lock final state of phase 1 + start the chase */
    fill-opacity: 1;
    stroke-opacity: 0;
    animation: bar-flow 10s ease-in-out infinite;
  }
  .penrose.is-running .bar-humanistic { animation-delay: 0s; }
  .penrose.is-running .bar-geoai      { animation-delay: -6.667s; }
  .penrose.is-running .bar-fake       { animation-delay: -3.333s; }

  @keyframes penrose-wobble {
    0%, 100% { transform: rotate(-2deg); }
    50%      { transform: rotate(2deg);  }
  }
  /* Each bar gets brighter + slightly larger for ~12% of the cycle.
     With three bars staggered by 1/3 of a cycle, the bright spot
     visibly travels around the loop. */
  @keyframes bar-flow {
    0%, 88%, 100% {
      filter: brightness(1) saturate(1);
      transform: translate(0, 0);
    }
    6% {
      filter: brightness(1.18) saturate(1.18) drop-shadow(0 1px 6px rgba(50, 42, 38, 0.18));
      transform: translate(0, -1px);
    }
    14% {
      filter: brightness(1) saturate(1);
      transform: translate(0, 0);
    }
  }

  /* Hover anywhere on the figure: pause wobble, speed up the chase */
  .penrose:hover svg { animation-play-state: paused; }
  .penrose.is-running:hover .bar { animation-duration: 4s; }

  /* Per-bar hover (and JS-driven .is-active for theme-card sync):
     dim siblings, light up the focused one immediately */
  .penrose .bar { cursor: pointer; }
  .penrose:hover .bar { opacity: 0.5; }
  .penrose .bar.is-active,
  .penrose .bar:hover {
    opacity: 1;
    filter: brightness(1.12) drop-shadow(0 2px 6px rgba(50, 42, 38, 0.2));
  }

  @media (prefers-reduced-motion: reduce) {
    .penrose .bar {
      animation: none;
      fill-opacity: 1;
      stroke-opacity: 0;
      stroke-dashoffset: 0;
    }
    .penrose.is-running svg { animation: none; }
    .penrose.is-running .bar { animation: none; }
  }

  .penrose figcaption {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem 0.7rem;
    align-items: center;
  }
  .penrose .dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    margin-right: 4px;
    vertical-align: -1px;
  }
  .dot-humanistic { background: var(--c-humanistic); }
  .dot-fake       { background: var(--c-fake); border: 1px solid var(--rule); }
  .dot-geoai      { background: var(--c-geoai); }
  .penrose .sep   { color: var(--rule); }
  .penrose figcaption {
    --c-humanistic: var(--uw-purple);
    --c-geoai: var(--uw-gold);
    --c-fake: var(--mist);
  }

  /* highlight a theme card when its bar is hovered (and vice versa) */
  .theme.is-mapped {
    border-color: var(--uw-gold);
    background: var(--bg-card);
    box-shadow: 0 4px 14px rgba(50, 42, 38, 0.06);
  }

</style>

<script is:inline>
  (function () {
    const figure = document.querySelector('.penrose');
    const svg = document.querySelector('.penrose svg');
    const bars = document.querySelectorAll('.penrose .bar');
    const themeCards = document.querySelectorAll('.theme[data-theme]');
    // Phase 2: kick into idle (wobble + flow chase) after the entry
    // animation finishes for the last bar (delay 1.0s + duration 1.4s).
    if (figure) {
      setTimeout(() => figure.classList.add('is-running'), 2500);
    }
    function setActive(slug, on) {
      bars.forEach(b => {
        if (b.dataset.theme === slug) b.classList.toggle('is-active', on);
      });
      themeCards.forEach(t => {
        if (t.dataset.theme === slug) t.classList.toggle('is-mapped', on);
      });
    }
    if (svg) {
      svg.addEventListener('pointerover', (e) => {
        const target = e.target.closest && e.target.closest('[data-theme]');
        if (!target) return;
        const from = e.relatedTarget && e.relatedTarget.closest
          ? e.relatedTarget.closest('[data-theme]') : null;
        if (from && from.dataset.theme === target.dataset.theme) return;
        setActive(target.dataset.theme, true);
      });
      svg.addEventListener('pointerout', (e) => {
        const target = e.target.closest && e.target.closest('[data-theme]');
        if (!target) return;
        const to = e.relatedTarget && e.relatedTarget.closest
          ? e.relatedTarget.closest('[data-theme]') : null;
        if (to && to.dataset.theme === target.dataset.theme) return;
        setActive(target.dataset.theme, false);
      });
    }
    themeCards.forEach(t => {
      t.addEventListener('pointerenter', () => setActive(t.dataset.theme, true));
      t.addEventListener('pointerleave', () => setActive(t.dataset.theme, false));
    });
  })();
</script>
