---
<BaseLayout
  title="Publications"
  description="Peer-reviewed journal articles and book chapters from the Humanistic GIS Lab on humanistic GIS, deepfake geography, GeoAI, neural sensing, and qualitative spatial methods."
>
  <section class="container section">
    <span class="eyebrow">Publications</span>
    <h1>Selected work</h1>
    <p class="lede">Peer-reviewed journal articles and book chapters from the lab. Conference proceedings, Chinese-language venues, and earlier work are catalogued internally and available on request.</p>

    {pubs.map(group => (
      <section class="year-group">
        <h2>{group.year}</h2>
        <ol class="pub-list">
          {group.items.map(p => (
            <li>
              <span class="authors" set:html={p.authors}></span>.
              "<strong>{p.title}</strong>". <em set:html={p.venue}></em>.
              {p.kind === 'chapter' && <span class="kind">[chapter]</span>}
              {p.doi && <a class="doi" href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener">[DOI]</a>}
            </li>
          ))}
        </ol>
      </section>
    ))}
  </section>
</BaseLayout>

<style>
  .lede { font-size: 1.1rem; color: var(--ink-soft); max-width: 65ch; }
  .year-group { margin-top: 2rem; }
  .year-group h2 {
    font-size: 1.3rem;
    color: var(--uw-purple);
    border-bottom: 2px solid var(--uw-purple);
    padding-bottom: 0.3rem;
    display: inline-block;
  }
  .pub-list { padding-left: 1.2rem; }
  .pub-list li { margin: 0.9rem 0; line-height: 1.55; font-size: 0.96rem; }
  .doi {
    font-size: 0.85rem;
    margin-left: 0.4rem;
    color: var(--uw-gold);
  }
  .kind {
    font-size: 0.75rem;
    color: var(--ink-faint);
    margin-left: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
