---
import BaseLayout from './BaseLayout.astro';
import { UI, entries, type Entry } from '../data/friday-harbor';

interface Props {
  entry: Entry;
}
const { entry } = Astro.props;
const dt = new Date(entry.date + 'T00:00:00');
const dateLong = {
  en: dt.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }),
  zh: dt.toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }),
};
// Issue number = chronological position in the registry (oldest = 001).
// Computed from a date-sorted copy so the registry array order doesn't
// have to be perfectly maintained, and so the dates can be rearranged
// without renumbering by hand.
const issueNo = (() => {
  const ascByDate = [...entries].sort((a, b) => a.date.localeCompare(b.date));
  const idx = ascByDate.findIndex(e => e.slug === entry.slug);
  return String(idx + 1).padStart(3, '0');
})();
const year = entry.date.slice(0, 4);

// ---- Citation generation ----
// All formats are derived from the entry data, so adding a new piece
// doesn't require touching the layout — just register the entry.
const url = `https://hgis.uw.edu/friday-harbor/${entry.slug}/`;
const bibKey = entry.citeKey ?? (() => {
  // Fallback: {lastname}{year}{slug-first-word-after-date}.
  const tail = entry.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '').split('-')[0];
  const ln = (entry.author.split(' ').pop() ?? 'zhao').toLowerCase();
  return `${ln}${year}${tail}`;
})();
const monthShort = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'][dt.getMonth()];
const monthLong  = ['January','February','March','April','May','June','July','August','September','October','November','December'][dt.getMonth()];
const day = dt.getDate();
const issueNoInt = parseInt(issueNo, 10);
const cite = {
  // APA 7 — for an online column the closest canonical form is
  // periodical-with-article-number. We treat the issue number as the
  // article number (per APA's guidance for online-only articles).
  apa:
`Zhao, B. (${year}, ${monthLong} ${day}). ${entry.title.en}. Friday Harbor (HGIS Lab Column), Article ${issueNoInt}.
Humanistic GIS Lab, University of Washington. ${url}`,
  // Chicago notes-and-bibliography, online-magazine style.
  chicago:
`Zhao, Bo. "${entry.title.en}." Friday Harbor (HGIS Lab column), no. ${issueNo}, ${monthLong} ${day}, ${year}. ${url}`,
  bibtex:
`@misc{${bibKey},
  author       = {Bo Zhao},
  title        = {${entry.title.en}},
  howpublished = {Friday Harbor (HGIS Lab Column), Article ${issueNoInt}},
  institution  = {Humanistic GIS Lab, University of Washington},
  year         = {${year}},
  month        = ${monthShort},
  url          = {${url}}
}`,
  // RIS — the lingua franca for Zotero / EndNote / Mendeley / Papers
  // import. TY: GEN keeps it agnostic; "T2" is the container series.
  ris:
`TY  - GEN
AU  - Zhao, Bo
TI  - ${entry.title.en}
T2  - Friday Harbor (HGIS Lab Column)
IS  - ${issueNoInt}
PY  - ${year}
DA  - ${entry.date}
PB  - Humanistic GIS Lab, University of Washington
UR  - ${url}
ER  - `,
  gbt:
`赵博. ${entry.title.zh}[EB/OL]. Friday Harbor (HGIS 实验室专栏), 第 ${issueNo} 期, ${entry.date}. ${url}`,
};

// ---- JSON-LD: Article schema per piece ----
// Each FH page is one self-contained article — schema.org/Article gives
// search engines + reference managers a clean record (author, date,
// keywords, canonical URL, description). One canonical headline per
// page; the Chinese version of the title lives inside the page DOM
// (same article, lang-toggled), so we don't double-list it here.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': url,
  url,
  headline: entry.title.en,
  description: entry.subtitle.en,
  datePublished: entry.date,
  dateModified: entry.date,
  isAccessibleForFree: true,
  keywords: [
    ...entry.techniques,
    'cartography',
    'humanistic GIS',
    'Friday Harbor',
  ].join(', '),
  author: {
    '@type': 'Person',
    name: entry.author,
    url: 'https://hgis.uw.edu/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Humanistic GIS Laboratory',
    url: 'https://hgis.uw.edu/',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hgis.uw.edu/hgis-logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  isPartOf: {
    '@type': 'CreativeWorkSeries',
    name: 'Friday Harbor',
    url: 'https://hgis.uw.edu/friday-harbor/',
  },
  // Place-of-interest carried as a contentLocation hint when the
  // article is anchored to a specific bbox (most are).
  ...(entry.thumb ? {
    contentLocation: {
      '@type': 'Place',
      name: entry.place.en,
      geo: {
        '@type': 'GeoShape',
        box: `${entry.thumb.bbox.south} ${entry.thumb.bbox.west} ${entry.thumb.bbox.north} ${entry.thumb.bbox.east}`,
      },
    },
  } : {}),
};
---
<BaseLayout
  title={`${entry.title.en} · Friday Harbor`}
  description={entry.subtitle.en}
  noindex={entry.published === false}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline>
    // Run synchronously, before any layout work, so the thumb-mode CSS
    // selectors (html[data-fh-thumb="1"] ...) match on first paint.
    // The original inline script at the bottom of this layout still
    // handles the language toggle; this only seeds the thumb flag.
    (function () {
      try {
        var p = new URLSearchParams(location.search).get('thumb');
        if (!p) return;
        document.documentElement.setAttribute('data-fh-thumb', '1');
        // Brute-force the stage to viewport size after the page has
        // hydrated. CSS-only !important overrides lose to aspect-ratio
        // negotiation in some browsers, so we just write inline styles.
        function fitStage() {
          var el = document.getElementById('stage');
          if (!el) return;
          el.style.width = window.innerWidth + 'px';
          el.style.height = window.innerHeight + 'px';
          el.style.aspectRatio = 'auto';
          el.style.maxWidth = 'none';
          // Trigger any per-article re-render listener that watches for
          // resize events (cloud / mirror / hormuz all do this).
          window.dispatchEvent(new Event('resize'));
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', fitStage);
        } else {
          fitStage();
        }
        // Also run after a tick in case the figure script mounts late.
        setTimeout(fitStage, 200);
        setTimeout(fitStage, 1200);
      } catch (e) {}
    })();
  </script>
  <div class="fh-root" data-lang="en">
    <article class="fh-entry">
      {entry.published === false && (
        <aside class="fh-draft-banner" role="note">
          <strong>
            <span data-lang="en">DRAFT</span>
            <span data-lang="zh">草稿</span>
          </strong>
          <span data-lang="en">This entry is not yet published. It is hidden from the column index and from search engines.</span>
          <span data-lang="zh">本篇尚未发布——已从专栏索引与搜索引擎中隐藏。</span>
        </aside>
      )}
      <header class="fh-masthead">
        <a href="/friday-harbor/" class="fh-rubric">
          <em><span data-lang="en">{UI.rubric.en}</span><span data-lang="zh">{UI.rubric.zh}</span></em>
        </a>
        <div class="fh-meta">
          <span>№ {issueNo}</span>
          <span data-lang="en">{dateLong.en}</span>
          <span data-lang="zh">{dateLong.zh}</span>
          <span class="fh-place" data-lang="en">{entry.place.en}</span>
          <span class="fh-place" data-lang="zh">{entry.place.zh}</span>
          <div class="fh-lang-switch" role="group" aria-label="language">
            <button type="button" class="fh-lang-btn" data-lang-set="en" aria-label="English">EN</button>
            <button type="button" class="fh-lang-btn" data-lang-set="zh" aria-label="中文">中</button>
          </div>
        </div>
      </header>

      <h1 class="fh-title">
        <span data-lang="en">{entry.title.en}</span>
        <span data-lang="zh">{entry.title.zh}</span>
      </h1>
      <p class="fh-lede">
        <span data-lang="en">{entry.subtitle.en}</span>
        <span data-lang="zh">{entry.subtitle.zh}</span>
      </p>
      <div class="fh-figure-wrap">
        <slot name="figure" />
      </div>

      <div class="fh-body">
        <section class="fh-col fh-notebook">
          <div data-lang="en"><slot name="notebook-en" /></div>
          <div data-lang="zh"><slot name="notebook-zh" /></div>
        </section>
        <section class="fh-col fh-endnote">
          <h2><span data-lang="en">{UI.endnote.en}</span><span data-lang="zh">{UI.endnote.zh}</span></h2>
          <div data-lang="en"><slot name="provenance-en" /></div>
          <div data-lang="zh"><slot name="provenance-zh" /></div>
        </section>
        <section class="fh-col fh-cite">
          <h2><span data-lang="en">{UI.howToCite.en}</span><span data-lang="zh">{UI.howToCite.zh}</span></h2>
          <div class="fh-cite-widget">
            <div class="fh-cite-tabs" role="tablist">
              <button class="fh-cite-tab is-active" type="button" role="tab" data-fmt="apa" aria-selected="true">APA</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="chicago" aria-selected="false">Chicago</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="bibtex" aria-selected="false">BibTeX</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="ris" aria-selected="false">RIS</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="gbt" aria-selected="false">GB/T 7714</button>
              <button class="fh-cite-copy" type="button" aria-label="copy citation"
                ><span data-lang="en">{UI.citeCopy.en}</span><span data-lang="zh">{UI.citeCopy.zh}</span></button>
            </div>
            <pre class="fh-citation is-active" data-fmt="apa">{cite.apa}</pre>
            <pre class="fh-citation" data-fmt="chicago" hidden>{cite.chicago}</pre>
            <pre class="fh-citation" data-fmt="bibtex" hidden>{cite.bibtex}</pre>
            <pre class="fh-citation" data-fmt="ris" hidden>{cite.ris}</pre>
            <pre class="fh-citation" data-fmt="gbt" hidden>{cite.gbt}</pre>
          </div>
        </section>
      </div>

      <section class="fh-share" aria-label="share this entry">
        <div class="fh-share-row">
          <span class="fh-share-label">
            <span data-lang="en">{UI.shareEN.en}</span><span data-lang="zh">{UI.shareEN.zh}</span>
          </span>
          <a class="fh-share-btn fh-share-native" data-share="native" href="#" hidden
            ><span data-lang="en">{UI.shareNative.en}</span><span data-lang="zh">{UI.shareNative.zh}</span></a>
          <a class="fh-share-btn" data-share="x"        href="#" rel="noopener">X</a>
          <a class="fh-share-btn" data-share="bluesky"  href="#" rel="noopener">Bluesky</a>
          <a class="fh-share-btn" data-share="linkedin" href="#" rel="noopener">LinkedIn</a>
          <a class="fh-share-btn" data-share="facebook" href="#" rel="noopener">Facebook</a>
          <a class="fh-share-btn" data-share="email"    href="#"
            ><span data-lang="en">{UI.shareEmail.en}</span><span data-lang="zh">{UI.shareEmail.zh}</span></a>
        </div>
        <div class="fh-share-row fh-share-cn">
          <span class="fh-share-label">
            <span data-lang="en">{UI.shareZH.en}</span><span data-lang="zh">{UI.shareZH.zh}</span>
          </span>
          <a class="fh-share-btn" data-share="weibo" href="#" rel="noopener"
            ><span data-lang="en">{UI.shareWeibo.en}</span><span data-lang="zh">{UI.shareWeibo.zh}</span></a>
          <a class="fh-share-btn" data-share="wechat" href="#"
            ><span data-lang="en">{UI.shareWechat.en}</span><span data-lang="zh">{UI.shareWechat.zh}</span></a>
          <a class="fh-share-btn" data-share="xhs" href="#"
            ><span data-lang="en">{UI.shareXhs.en}</span><span data-lang="zh">{UI.shareXhs.zh}</span></a>
          <a class="fh-share-btn" data-share="douban" href="#" rel="noopener"
            ><span data-lang="en">{UI.shareDouban.en}</span><span data-lang="zh">{UI.shareDouban.zh}</span></a>
          <a class="fh-share-btn fh-share-copy" data-share="copy" href="#"
            ><span data-lang="en">{UI.shareCopy.en}</span><span data-lang="zh">{UI.shareCopy.zh}</span></a>
        </div>

        <!-- toast for transient share feedback (XHS / errors / etc.) -->
        <div class="fh-toast" role="status" aria-live="polite"></div>

        <!-- WeChat QR popover (hidden by default) -->
        <div class="fh-wechat" id="fh-wechat" hidden>
          <button class="fh-wechat-x" type="button" aria-label="close">×</button>
          <img class="fh-wechat-qr" alt="WeChat QR" />
          <p class="fh-wechat-tip">
            <span data-lang="en">{UI.wechatTip.en}</span><span data-lang="zh">{UI.wechatTip.zh}</span>
          </p>
          <div class="fh-wechat-urlrow">
            <code class="fh-wechat-url"></code>
            <button class="fh-wechat-copy" type="button"
              ><span data-lang="en">{UI.wechatCopy.en}</span><span data-lang="zh">{UI.wechatCopy.zh}</span></button>
          </div>
        </div>
      </section>

      <section class="fh-comments" aria-label="comments">
        <!--
          Giscus thread mount point. The script is added by the inline
          loader at the bottom of this layout once the page is parsed —
          we have to inject it programmatically so that the language
          attribute can track the EN/中 toggle without a page reload.
          The giscus iframe's own "0 comments — powered by giscus"
          header is the only label readers see; we don't double it
          up with a redundant section heading.
        -->
        <div class="fh-giscus" id="fh-giscus" aria-live="polite"></div>
      </section>

      <footer class="fh-foot">
        <a href="/friday-harbor/">
          <span data-lang="en">{UI.back.en}</span><span data-lang="zh">{UI.back.zh}</span>
        </a>
        <span>
          <em>{entry.author}</em>,
          <span data-lang="en"> {UI.byline.en}</span><span data-lang="zh"> {UI.byline.zh}</span>
        </span>
      </footer>
    </article>

    {/* Singleton expand-to-fullscreen overlay. Lives outside the article
        so its position:fixed doesn't get clipped by an ancestor with
        transform/filter. The script below moves the stage in/out on
        open/close — only one entry's stage exists per page anyway. */}
    <div class="fh-overlay" hidden aria-hidden="true">
      <button class="fh-overlay-close" type="button" aria-label="Close">×</button>
      <div class="fh-overlay-hint" aria-hidden="true">
        <span data-lang="en">scroll · pinch to zoom · ESC to close</span>
        <span data-lang="zh">滑动 · 双指缩放 · ESC 关闭</span>
      </div>
      <div class="fh-overlay-inner"></div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .fh-root[data-lang="en"] [data-lang="zh"] { display: none !important; }
  .fh-root[data-lang="zh"] [data-lang="en"] { display: none !important; }

  /* ---- Thumb capture mode -----------------------------------------
     When the page is loaded with ?thumb=1, an inline script flips the
     <html> element to data-fh-thumb="1". Everything but the figure
     stage is hidden, and the stage is sized to fill the viewport
     (5:3 ratio, matching the index card thumbnail box). A headless
     Chrome capture at 1400×840 then produces a thumbnail with no
     manual cropping. Captions, stat strips, and body all stay in the
     DOM at display:none so the figure script still has elements to
     query. */
  html[data-fh-thumb="1"],
  html[data-fh-thumb="1"] body {
    background: var(--bg-card, #f5efe2) !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
  }
  /* Hide the site shell + any iframes (e.g. Giscus comments) + the
     Astro dev toolbar (a floating <astro-dev-toolbar> web component
     that shows up on every dev-server page and otherwise leaks into
     the bottom of the thumbnail). */
  html[data-fh-thumb="1"] .site-header,
  html[data-fh-thumb="1"] .site-footer,
  html[data-fh-thumb="1"] iframe,
  html[data-fh-thumb="1"] .fh-comments,
  html[data-fh-thumb="1"] .fh-giscus,
  html[data-fh-thumb="1"] .giscus,
  html[data-fh-thumb="1"] .giscus-frame,
  html[data-fh-thumb="1"] astro-dev-toolbar,
  html[data-fh-thumb="1"] astro-dev-overlay { display: none !important; visibility: hidden !important; }
  /* Wildcard: hide everything inside .fh-entry except the figure wrap.
     This catches share rows, comments, footer, toast, wechat popover,
     etc. without having to enumerate them. */
  html[data-fh-thumb="1"] .fh-entry > *:not(.fh-figure-wrap) { display: none !important; visibility: hidden !important; }
  /* Hide caption / stat strips that sit inside the figure itself. */
  html[data-fh-thumb="1"] .fh-figure-wrap > figure > figcaption,
  html[data-fh-thumb="1"] .fh-figure-wrap > figure > aside { display: none !important; }
  /* Reset entry container so the figure can flush against the viewport. */
  html[data-fh-thumb="1"] main,
  html[data-fh-thumb="1"] .fh-root,
  html[data-fh-thumb="1"] .fh-entry,
  html[data-fh-thumb="1"] .fh-figure-wrap { margin: 0 !important; padding: 0 !important; max-width: none !important; }
  html[data-fh-thumb="1"] .fh-figure-wrap > figure { margin: 0 !important; padding: 0 !important; }
  /* The actual stage is the first child <div> of the figure. Force it
     to fill the viewport — the per-article aspect-ratio rules use the
     class .*-stage, so we override on that class via attribute match. */
  html[data-fh-thumb="1"] .fh-figure-wrap > figure > div[id="stage"] {
    width: 100vw !important;
    height: 100vh !important;
    aspect-ratio: auto !important;
    max-width: none !important;
    border: 0 !important;
    border-radius: 0 !important;
  }
  .fh-root[data-lang="zh"] {
    /* Body/serif fallback in Chinese: Noto Serif SC at light weight reads
       like a literary column, not an academic journal. */
    --serif: "Cormorant Garamond", "Noto Serif SC", "Songti SC", "STSong", Georgia, serif;
    /* Display register for prominent Chinese text — titles, ledes,
       section heads. Kaiti's calligraphic slant gives the column a
       personal editorial voice (like a 三联 / 读书 column header)
       rather than the institutional register Songti reads as. */
    --zh-display: "Kaiti SC", "STKaiti", "Kaiti", KaiTi, "Noto Serif SC", serif;
  }
  /* Apply the column register to all prominent Chinese text. */
  .fh-root[data-lang="zh"] .fh-title,
  .fh-root[data-lang="zh"] .fh-lede,
  .fh-root[data-lang="zh"] .fh-col h2,
  .fh-root[data-lang="zh"] .fh-rubric em {
    font-family: var(--zh-display);
    font-style: normal;       /* Kaiti has its own slant; faux-italic looks wrong */
    letter-spacing: 0.02em;
  }
  /* Chinese body & captions: Noto Serif SC light weight, slightly more
     line-height than Latin so the column breathes. */
  .fh-root[data-lang="zh"] .fh-col :global(p),
  .fh-root[data-lang="zh"] .fh-col :global(li) {
    font-family: "Noto Serif SC", "Songti SC", "STSong", serif;
    font-weight: 300;
    line-height: 1.78;
    letter-spacing: 0.01em;
  }
  /* Every entry's figcaption shares the body's reading measure, so the
     prose under the figure aligns visually with the lede above and the
     notebook/endnote/citation below. The figure itself stays wide. */
  .fh-root .fh-figure-wrap figcaption {
    max-width: 760px;
  }

  /* ---- Figure watermark ---------------------------------------------
     Appended into #stage by the inline script below, so every Friday
     Harbor figure carries an HGIS Lab · Friday Harbor mark in the
     bottom-right. Living inside the stage means it travels into thumb
     captures (which keep the stage and drop everything else) — exactly
     where attribution matters most: shared screenshots. */
  .fh-figure-wrap div[id="stage"] { position: relative; }
  .fh-watermark {
    position: absolute;
    right: 10px;
    bottom: 10px;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px 5px 9px;
    border-radius: 999px;
    background: rgba(245, 239, 226, 0.86);
    border: 1px solid rgba(74, 47, 130, 0.18);
    color: var(--ink);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    line-height: 1;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    /* Brand colours scoped here so they don't leak into per-entry stages. */
    --c-humanistic: #4A2F82;
    --c-geoai: #B5A57B;
    --c-fake: #D9D9D9;
  }
  .fh-watermark:hover {
    opacity: 1;
    background: rgba(245, 239, 226, 0.96);
    border-color: var(--uw-purple);
  }
  .fh-wm-logo { width: 14px; height: 14px; flex-shrink: 0; }
  .fh-wm-bar-humanistic { fill: var(--c-humanistic); }
  .fh-wm-bar-geoai      { fill: var(--c-geoai); }
  .fh-wm-bar-fake       { fill: var(--c-fake); }
  .fh-wm-lab {
    font-family: "Cormorant Garamond", "Apple Garamond", Georgia, serif;
    font-weight: 500;
    color: var(--ink);
  }
  .fh-wm-sep { opacity: 0.4; color: var(--ink); }
  .fh-wm-fh {
    font-family: "Cormorant Garamond", "Apple Garamond", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    color: var(--uw-purple);
  }
  /* Bump the mark slightly in thumb mode so it reads at a glance in the
     1400×840 social-card crop. The thumb-mode global rules above don't
     hide it (it's a child of #stage, not figcaption / aside), so we
     just need to scale it up — not unhide. */
  html[data-fh-thumb="1"] .fh-watermark {
    font-size: 0.86rem;
    padding: 7px 14px 7px 12px;
    gap: 8px;
    right: 14px;
    bottom: 14px;
  }
  html[data-fh-thumb="1"] .fh-wm-logo { width: 18px; height: 18px; }

  /* ---- Expand-to-fullscreen ----------------------------------------
     Opt-in per entry by adding `data-fh-expandable` to the figure tag.
     The button is injected by the same script that mounts the
     watermark, on the top-right of the stage. Click → moves the stage
     into the overlay below; the entry's d3 redraw runs on the
     dispatched resize event, so labels lay out for the larger canvas
     instead of being shrunk to mobile width. */
  .fh-expand-btn {
    position: absolute;
    top: 10px; right: 10px;
    z-index: 5;
    width: 30px; height: 30px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(74, 47, 130, 0.18);
    background: rgba(245, 239, 226, 0.86);
    color: var(--ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    transition: opacity 0.2s, background 0.2s, border-color 0.2s, color 0.2s;
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    font: inherit;
  }
  .fh-expand-btn:hover {
    opacity: 1;
    background: rgba(245, 239, 226, 0.96);
    border-color: var(--uw-purple);
    color: var(--uw-purple);
  }
  .fh-expand-btn svg { width: 14px; height: 14px; pointer-events: none; }
  /* Hidden in thumb-capture mode so social-card thumbnails stay clean. */
  html[data-fh-thumb="1"] .fh-expand-btn { display: none !important; }

  /* Fullscreen overlay (singleton per page). Hosts the stage when
     expanded. Min-width forces a wider canvas on phones so labels can
     space out — the overlay itself scrolls horizontally to reveal it,
     and pinch-zoom on the page works on top for further zoom. */
  body.fh-overlay-on { overflow: hidden; }
  .fh-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(28, 22, 18, 0.82);
    overflow: auto;
    -webkit-overflow-scrolling: touch;
  }
  .fh-overlay[hidden] { display: none; }
  .fh-overlay-inner {
    display: grid;
