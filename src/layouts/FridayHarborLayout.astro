---
import BaseLayout from './BaseLayout.astro';
import { UI, entries, type Entry } from '../data/friday-harbor';

interface Props {
  entry: Entry;
}
const { entry } = Astro.props;
const dt = new Date(entry.date + 'T00:00:00');
const dateLong = {
  en: dt.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }),
  zh: dt.toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }),
};
// Issue number = chronological position in the registry (oldest = 001).
// Computed from a date-sorted copy so the registry array order doesn't
// have to be perfectly maintained, and so the dates can be rearranged
// without renumbering by hand.
const issueNo = (() => {
  const ascByDate = [...entries].sort((a, b) => a.date.localeCompare(b.date));
  const idx = ascByDate.findIndex(e => e.slug === entry.slug);
  return String(idx + 1).padStart(3, '0');
})();
const year = entry.date.slice(0, 4);

// ---- Citation generation ----
// All formats are derived from the entry data, so adding a new piece
// doesn't require touching the layout — just register the entry.
const url = `https://hgis.uw.edu/friday-harbor/${entry.slug}/`;
const bibKey = entry.citeKey ?? (() => {
  // Fallback: {lastname}{year}{slug-first-word-after-date}.
  const tail = entry.slug.replace(/^\d{4}-\d{2}-\d{2}-/, '').split('-')[0];
  const ln = (entry.author.split(' ').pop() ?? 'zhao').toLowerCase();
  return `${ln}${year}${tail}`;
})();
const monthShort = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'][dt.getMonth()];
const monthLong  = ['January','February','March','April','May','June','July','August','September','October','November','December'][dt.getMonth()];
const day = dt.getDate();
const issueNoInt = parseInt(issueNo, 10);
const cite = {
  // APA 7 — for an online column the closest canonical form is
  // periodical-with-article-number. We treat the issue number as the
  // article number (per APA's guidance for online-only articles).
  apa:
`Zhao, B. (${year}, ${monthLong} ${day}). ${entry.title.en}. Friday Harbor (HGIS Lab Column), Article ${issueNoInt}.
Humanistic GIS Lab, University of Washington. ${url}`,
  // Chicago notes-and-bibliography, online-magazine style.
  chicago:
`Zhao, Bo. "${entry.title.en}." Friday Harbor (HGIS Lab column), no. ${issueNo}, ${monthLong} ${day}, ${year}. ${url}`,
  bibtex:
`@misc{${bibKey},
  author       = {Bo Zhao},
  title        = {${entry.title.en}},
  howpublished = {Friday Harbor (HGIS Lab Column), Article ${issueNoInt}},
  institution  = {Humanistic GIS Lab, University of Washington},
  year         = {${year}},
  month        = ${monthShort},
  url          = {${url}}
}`,
  // RIS — the lingua franca for Zotero / EndNote / Mendeley / Papers
  // import. TY: GEN keeps it agnostic; "T2" is the container series.
  ris:
`TY  - GEN
AU  - Zhao, Bo
TI  - ${entry.title.en}
T2  - Friday Harbor (HGIS Lab Column)
IS  - ${issueNoInt}
PY  - ${year}
DA  - ${entry.date}
PB  - Humanistic GIS Lab, University of Washington
UR  - ${url}
ER  - `,
  gbt:
`赵博. ${entry.title.zh}[EB/OL]. Friday Harbor (HGIS 实验室专栏), 第 ${issueNo} 期, ${entry.date}. ${url}`,
};
---
<BaseLayout title={`${entry.title.en} · Friday Harbor`} description={entry.subtitle.en}>
  <div class="fh-root" data-lang="en">
    <article class="fh-entry">
      <header class="fh-masthead">
        <a href="/friday-harbor/" class="fh-rubric">
          <em><span data-lang="en">{UI.rubric.en}</span><span data-lang="zh">{UI.rubric.zh}</span></em>
        </a>
        <div class="fh-meta">
          <span>№ {issueNo}</span>
          <span data-lang="en">{dateLong.en}</span>
          <span data-lang="zh">{dateLong.zh}</span>
          <span class="fh-place" data-lang="en">{entry.place.en}</span>
          <span class="fh-place" data-lang="zh">{entry.place.zh}</span>
          <button class="fh-lang-toggle" type="button" aria-label="switch language">
            <span data-lang="en">中文</span><span data-lang="zh">EN</span>
          </button>
        </div>
      </header>

      <h1 class="fh-title">
        <span data-lang="en">{entry.title.en}</span>
        <span data-lang="zh">{entry.title.zh}</span>
      </h1>
      <p class="fh-lede">
        <span data-lang="en">{entry.subtitle.en}</span>
        <span data-lang="zh">{entry.subtitle.zh}</span>
      </p>
      <div class="fh-figure-wrap">
        <slot name="figure" />
      </div>

      <div class="fh-body">
        <section class="fh-col fh-notebook">
          <div data-lang="en"><slot name="notebook-en" /></div>
          <div data-lang="zh"><slot name="notebook-zh" /></div>
        </section>
        <section class="fh-col fh-endnote">
          <h2><span data-lang="en">{UI.endnote.en}</span><span data-lang="zh">{UI.endnote.zh}</span></h2>
          <div data-lang="en"><slot name="provenance-en" /></div>
          <div data-lang="zh"><slot name="provenance-zh" /></div>
        </section>
        <section class="fh-col fh-cite">
          <h2><span data-lang="en">{UI.howToCite.en}</span><span data-lang="zh">{UI.howToCite.zh}</span></h2>
          <div class="fh-cite-widget">
            <div class="fh-cite-tabs" role="tablist">
              <button class="fh-cite-tab is-active" type="button" role="tab" data-fmt="apa" aria-selected="true">APA</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="chicago" aria-selected="false">Chicago</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="bibtex" aria-selected="false">BibTeX</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="ris" aria-selected="false">RIS</button>
              <button class="fh-cite-tab" type="button" role="tab" data-fmt="gbt" aria-selected="false">GB/T 7714</button>
              <button class="fh-cite-copy" type="button" aria-label="copy citation"
                ><span data-lang="en">{UI.citeCopy.en}</span><span data-lang="zh">{UI.citeCopy.zh}</span></button>
            </div>
            <pre class="fh-citation is-active" data-fmt="apa">{cite.apa}</pre>
            <pre class="fh-citation" data-fmt="chicago" hidden>{cite.chicago}</pre>
            <pre class="fh-citation" data-fmt="bibtex" hidden>{cite.bibtex}</pre>
            <pre class="fh-citation" data-fmt="ris" hidden>{cite.ris}</pre>
            <pre class="fh-citation" data-fmt="gbt" hidden>{cite.gbt}</pre>
          </div>
        </section>
      </div>

      <section class="fh-share" aria-label="share this entry">
        <div class="fh-share-row">
          <span class="fh-share-label">
            <span data-lang="en">{UI.shareEN.en}</span><span data-lang="zh">{UI.shareEN.zh}</span>
          </span>
          <a class="fh-share-btn fh-share-native" data-share="native" href="#" hidden
            ><span data-lang="en">{UI.shareNative.en}</span><span data-lang="zh">{UI.shareNative.zh}</span></a>
          <a class="fh-share-btn" data-share="x"        href="#" rel="noopener">X</a>
          <a class="fh-share-btn" data-share="bluesky"  href="#" rel="noopener">Bluesky</a>
          <a class="fh-share-btn" data-share="linkedin" href="#" rel="noopener">LinkedIn</a>
          <a class="fh-share-btn" data-share="facebook" href="#" rel="noopener">Facebook</a>
          <a class="fh-share-btn" data-share="email"    href="#"
            ><span data-lang="en">{UI.shareEmail.en}</span><span data-lang="zh">{UI.shareEmail.zh}</span></a>
        </div>
        <div class="fh-share-row fh-share-cn">
          <span class="fh-share-label">
            <span data-lang="en">{UI.shareZH.en}</span><span data-lang="zh">{UI.shareZH.zh}</span>
          </span>
          <a class="fh-share-btn" data-share="weibo" href="#" rel="noopener"
            ><span data-lang="en">{UI.shareWeibo.en}</span><span data-lang="zh">{UI.shareWeibo.zh}</span></a>
          <a class="fh-share-btn" data-share="wechat" href="#"
            ><span data-lang="en">{UI.shareWechat.en}</span><span data-lang="zh">{UI.shareWechat.zh}</span></a>
          <a class="fh-share-btn" data-share="xhs" href="#"
            ><span data-lang="en">{UI.shareXhs.en}</span><span data-lang="zh">{UI.shareXhs.zh}</span></a>
          <a class="fh-share-btn" data-share="douban" href="#" rel="noopener"
            ><span data-lang="en">{UI.shareDouban.en}</span><span data-lang="zh">{UI.shareDouban.zh}</span></a>
          <a class="fh-share-btn fh-share-copy" data-share="copy" href="#"
            ><span data-lang="en">{UI.shareCopy.en}</span><span data-lang="zh">{UI.shareCopy.zh}</span></a>
        </div>

        <!-- toast for transient share feedback (XHS / errors / etc.) -->
        <div class="fh-toast" role="status" aria-live="polite"></div>

        <!-- WeChat QR popover (hidden by default) -->
        <div class="fh-wechat" id="fh-wechat" hidden>
          <button class="fh-wechat-x" type="button" aria-label="close">×</button>
          <img class="fh-wechat-qr" alt="WeChat QR" />
          <p class="fh-wechat-tip">
            <span data-lang="en">{UI.wechatTip.en}</span><span data-lang="zh">{UI.wechatTip.zh}</span>
          </p>
          <div class="fh-wechat-urlrow">
            <code class="fh-wechat-url"></code>
            <button class="fh-wechat-copy" type="button"
              ><span data-lang="en">{UI.wechatCopy.en}</span><span data-lang="zh">{UI.wechatCopy.zh}</span></button>
          </div>
        </div>
      </section>

      <footer class="fh-foot">
        <a href="/friday-harbor/">
          <span data-lang="en">{UI.back.en}</span><span data-lang="zh">{UI.back.zh}</span>
        </a>
        <span>
          <em>{entry.author}</em>,
          <span data-lang="en"> {UI.byline.en}</span><span data-lang="zh"> {UI.byline.zh}</span>
        </span>
      </footer>
    </article>
  </div>
</BaseLayout>

<style is:global>
  .fh-root[data-lang="en"] [data-lang="zh"] { display: none !important; }
  .fh-root[data-lang="zh"] [data-lang="en"] { display: none !important; }
  .fh-root[data-lang="zh"] {
    /* Body/serif fallback in Chinese: Noto Serif SC at light weight reads
       like a literary column, not an academic journal. */
    --serif: "Cormorant Garamond", "Noto Serif SC", "Songti SC", "STSong", Georgia, serif;
    /* Display register for prominent Chinese text — titles, ledes,
       section heads. Kaiti's calligraphic slant gives the column a
       personal editorial voice (like a 三联 / 读书 column header)
       rather than the institutional register Songti reads as. */
    --zh-display: "Kaiti SC", "STKaiti", "Kaiti", KaiTi, "Noto Serif SC", serif;
  }
  /* Apply the column register to all prominent Chinese text. */
  .fh-root[data-lang="zh"] .fh-title,
  .fh-root[data-lang="zh"] .fh-lede,
  .fh-root[data-lang="zh"] .fh-col h2,
  .fh-root[data-lang="zh"] .fh-rubric em {
    font-family: var(--zh-display);
    font-style: normal;       /* Kaiti has its own slant; faux-italic looks wrong */
    letter-spacing: 0.02em;
  }
  /* Chinese body & captions: Noto Serif SC light weight, slightly more
     line-height than Latin so the column breathes. */
  .fh-root[data-lang="zh"] .fh-col :global(p),
  .fh-root[data-lang="zh"] .fh-col :global(li) {
    font-family: "Noto Serif SC", "Songti SC", "STSong", serif;
    font-weight: 300;
    line-height: 1.78;
    letter-spacing: 0.01em;
  }
  /* Every entry's figcaption shares the body's reading measure, so the
     prose under the figure aligns visually with the lede above and the
     notebook/endnote/citation below. The figure itself stays wide. */
  .fh-root .fh-figure-wrap figcaption {
    max-width: 760px;
  }
</style>

<style>
  .fh-entry {
    /* One reading measure for all body-prose blocks: lede, notebook,
       endnote, citation, and figcaption. The figure itself can break
       out wider — it's the visual element. */
    --fh-measure: 760px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.75rem 5rem;
    color: var(--ink);
  }
  .fh-masthead {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0.4rem 0 0.5rem;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .fh-rubric {
    display: flex; flex-direction: column; line-height: 1.05;
    color: var(--ink); border-bottom: 0;
  }
  .fh-rubric:hover { border-bottom: 0; }
  .fh-rubric em {
    font-family: "Cormorant Garamond", "Apple Garamond", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    font-size: 1.6rem;
    letter-spacing: -0.005em;
    color: var(--uw-purple);
  }
  /* Chinese rubric uses Kaiti — italic Songti is faux-italic and looks
     wrong; Kaiti's calligraphic slant gives the editorial inscription feel. */
  .fh-rubric em :global([data-lang="zh"]) {
    font-family: "Kaiti SC", "STKaiti", "Kaiti", KaiTi, "Noto Serif SC", serif;
    font-style: normal;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .fh-rubric small {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: 2px;
  }
  .fh-meta {
    display: flex; gap: 1.1rem; align-items: center;
    font-size: 0.75rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fh-place { color: var(--ink); font-style: italic; text-transform: none; letter-spacing: 0; }
  .fh-lang-toggle {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    font-family: inherit;
  }
  .fh-lang-toggle:hover {
    border-color: var(--uw-purple);
    color: var(--uw-purple);
  }

  .fh-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.012em;
    margin: 1.6rem 0 0.6rem;
  }
  .fh-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.18rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 1.6rem;
    max-width: var(--fh-measure);
  }
  .fh-figure-wrap {
    margin: 0 0 2rem;
    padding: 1.4rem 0 0;
    /* No border-top: tags above the map carry visual weight already.
       No border-bottom: the body section below has its own top rule —
       stacking two hairlines was redundant. */
  }

  .fh-body {
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
    border-top: 1px solid var(--rule);
    padding-top: 1.6rem;
    max-width: var(--fh-measure);
  }
  .fh-col h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: var(--uw-purple);
    margin: 0 0 0.7rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.4rem;
  }
  /* The notebook is the body; no heading needed. The first paragraph
     does the work a heading would have done. */
  .fh-notebook {
    font-size: 1rem;
    line-height: 1.65;
  }
  .fh-col :global(p) { font-size: 0.96rem; line-height: 1.65; margin: 0 0 0.85rem; }
  .fh-notebook :global(p) { font-size: 1rem; }
  .fh-col :global(ul) { font-size: 0.92rem; line-height: 1.6; padding-left: 1.1rem; margin: 0; }
  .fh-col :global(li) { margin-bottom: 0.5rem; }
  .fh-col :global(a)  { color: var(--uw-purple); border-bottom: 1px dotted var(--uw-purple); }

  /* Smart citation widget */
  .fh-cite-widget { position: relative; }
  .fh-cite-tabs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }
  .fh-cite-tab {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-soft, #6c6358);
    padding: 3px 11px;
    font-family: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .fh-cite-tab:hover {
    color: var(--uw-purple);
    border-color: var(--uw-purple);
  }
  .fh-cite-tab.is-active {
    color: #fff;
    background: var(--uw-purple);
    border-color: var(--uw-purple);
  }
  .fh-cite-copy {
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    padding: 3px 11px;
    font-family: inherit;
    font-size: 0.78rem;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .fh-cite-copy:hover {
    color: var(--uw-purple);
    border-color: var(--uw-purple);
  }
  .fh-cite-copy.is-flashed {
    background: var(--uw-purple);
    color: #fff;
    border-color: var(--uw-purple);
  }
  .fh-citation {
    background: var(--bg-card, #f6f3ed);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.8rem 0.9rem;
    font-size: 0.82rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--ink);
    margin: 0;
    font-family: inherit;
  }
  .fh-citation[data-fmt="bibtex"],
  .fh-citation[data-fmt="ris"] {
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.78rem;
  }
  .fh-citation:not(.is-active) { display: none; }

  .fh-foot {
    display: flex; justify-content: space-between;
    margin-top: 1.4rem; padding-top: 1rem;
    border-top: 1px solid var(--rule);
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
  .fh-foot a { color: var(--uw-purple); }

  /* share row */
  .fh-share {
    margin-top: 2.4rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--rule);
    position: relative;
  }
  .fh-share-row {
    display: flex; align-items: center; gap: 0.55rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    font-size: 0.84rem;
  }
  .fh-share-label {
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    text-transform: uppercase;
    margin-right: 0.4rem;
    min-width: 56px;
  }
  .fh-share-btn {
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 4px 12px;
    background: transparent;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .fh-share-btn:hover {
    border-color: var(--uw-purple);
    color: var(--uw-purple);
    border-bottom-color: var(--uw-purple);
  }
  .fh-share-btn.is-flashed {
    background: var(--uw-purple);
    color: #fff;
    border-color: var(--uw-purple);
  }
  /* Native Web Share button — leads the row when supported.
     The leading dot mimics a system-share glyph without an icon font. */
  .fh-share-native {
    background: var(--uw-purple);
    color: #fff;
    border-color: var(--uw-purple);
  }
  .fh-share-native:hover {
    color: #fff;
    background: #2c1f5b;
    border-color: #2c1f5b;
  }
  .fh-share-native::before {
    content: "↗";
    margin-right: 4px;
    font-size: 0.78em;
  }
  .fh-toast {
    position: absolute;
    left: 50%;
    bottom: -3.2rem;
    transform: translate(-50%, 6px);
    background: var(--ink, #1a1a1a);
    color: #fff;
    padding: 8px 14px;
    border-radius: 6px;
    font-size: 0.78rem;
    line-height: 1.35;
    max-width: min(420px, 86vw);
    text-align: center;
    box-shadow: 0 6px 20px rgba(0,0,0,0.18);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 14;
  }
  .fh-toast.is-on {
    opacity: 0.96;
    transform: translate(-50%, 0);
  }
  .fh-wechat {
    position: absolute;
    right: 0; top: 100%;
    margin-top: 8px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 14px 16px 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    width: 280px;
    z-index: 12;
  }
  .fh-wechat-x {
    position: absolute; right: 6px; top: 4px;
    background: transparent; border: 0; font-size: 18px; cursor: pointer;
    color: var(--ink-faint); line-height: 1;
  }
  .fh-wechat-qr {
    display: block; margin: 0 auto 8px;
    width: 200px; height: 200px;
    border: 1px solid var(--rule);
    background: #fff;
  }
  .fh-wechat-tip {
    margin: 0 0 6px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }
  .fh-wechat-urlrow {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .fh-wechat-url {
    flex: 1;
    display: block;
    font-size: 0.72rem;
    color: var(--ink-faint);
    word-break: break-all;
    line-height: 1.35;
  }
  .fh-wechat-copy {
    flex: 0 0 auto;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 0.72rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.18s ease;
  }
  .fh-wechat-copy:hover {
    border-color: var(--uw-purple);
    color: var(--uw-purple);
  }
  .fh-wechat-copy.is-flashed {
    background: var(--uw-purple);
    color: #fff;
    border-color: var(--uw-purple);
  }

  @media (max-width: 880px) {
    .fh-body { grid-template-columns: 1fr; gap: 1.4rem; }
  }
</style>

<script is:inline>
  (function () {
    const root = document.querySelector('.fh-root');
    if (!root) return;
    let lang = 'en';
    try { lang = localStorage.getItem('fh-lang') || 'en'; } catch (e) {}
    if (lang !== 'en' && lang !== 'zh') lang = 'en';
    root.setAttribute('data-lang', lang);
    const btn = root.querySelector('.fh-lang-toggle');
    if (btn) btn.addEventListener('click', () => {
      const next = root.getAttribute('data-lang') === 'en' ? 'zh' : 'en';
      root.setAttribute('data-lang', next);
      try { localStorage.setItem('fh-lang', next); } catch (e) {}
    });

    // ----- share row -----
    const url = location.href;
    const titleEl = root.querySelector('.fh-title');
    const ledeEl  = root.querySelector('.fh-lede');

    function curLang() {
      return root.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
    }
    function pickLangText(el, lang) {
      if (!el) return '';
      const span = el.querySelector('[data-lang="' + lang + '"]');
      return (span ? span.textContent : (el.textContent || '')).trim();
    }
    function shareTitle() {
      return pickLangText(titleEl, curLang()) || document.title;
    }
    function shareLede() {
      return pickLangText(ledeEl, curLang());
    }
    function tip(key) {
      const en = { copied: 'Link copied', xhs: 'Link copied — open Xiaohongshu and paste it.' };
      const zh = { copied: '链接已复制', xhs: '链接已复制 —— 回到小红书 App 内粘贴即可。' };
      return (curLang() === 'zh' ? zh : en)[key];
    }

    function buildTargets() {
      const title  = shareTitle();
      const lede   = shareLede();
      const t      = encodeURIComponent(title);
      const u      = encodeURIComponent(url);
      const teaser = encodeURIComponent(lede ? title + ' — ' + lede : title);
      const body   = encodeURIComponent((lede ? lede + '\n\n' : '') + url);
      return {
        x:        'https://x.com/intent/post?text=' + teaser + '&url=' + u,
        bluesky:  'https://bsky.app/intent/compose?text=' + teaser + '%20' + u,
        linkedin: 'https://www.linkedin.com/sharing/share-offsite/?url=' + u,
        facebook: 'https://www.facebook.com/sharer/sharer.php?u=' + u,
        email:    'mailto:?subject=' + t + '&body=' + body,
        weibo:    'https://service.weibo.com/share/share.php?url=' + u + '&title=' + t,
        douban:   'https://www.douban.com/share/service?href=' + u + '&name=' + t,
      };
    }

    const toast = root.querySelector('.fh-toast');
    let toastTimer = 0;
    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('is-on');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('is-on'), 2600);
    }

    function flash(btn, msg) {
      btn.classList.add('is-flashed');
      const orig = btn.innerHTML;
      btn.textContent = msg || tip('copied');
      setTimeout(() => { btn.classList.remove('is-flashed'); btn.innerHTML = orig; }, 1600);
    }

    function copyLink() {
      return new Promise((resolve) => {
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(resolve, resolve);
        } else {
          const ta = document.createElement('textarea');
          ta.value = url; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          resolve();
        }
      });
    }

    const wechat = root.querySelector('#fh-wechat');
    function openWechat() {
      if (!wechat) return;
      wechat.querySelector('.fh-wechat-qr').src =
        'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(url);
      wechat.querySelector('.fh-wechat-url').textContent = url;
      wechat.hidden = false;
    }
    function closeWechat() { if (wechat) wechat.hidden = true; }
    if (wechat) {
      wechat.querySelector('.fh-wechat-x').addEventListener('click', closeWechat);
      const wechatCopy = wechat.querySelector('.fh-wechat-copy');
      if (wechatCopy) wechatCopy.addEventListener('click', () => {
        copyLink().then(() => flash(wechatCopy));
      });
    }
    document.addEventListener('click', (e) => {
      if (wechat && !wechat.hidden && !wechat.contains(e.target)
          && !e.target.closest('[data-share="wechat"]')) closeWechat();
    });

    // Native Web Share API — only revealed when supported (mobile, Safari, Chrome).
    // When available it gives the user every share target their device knows about.
    const nativeBtn = root.querySelector('[data-share="native"]');
    if (nativeBtn && typeof navigator.share === 'function') {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        navigator.share({
          title: shareTitle(),
          text:  shareLede() || shareTitle(),
          url:   url,
        }).catch(() => { /* user cancelled or unsupported scheme — ignore */ });
      });
    }

    root.querySelectorAll('[data-share]').forEach(b => {
      const k = b.getAttribute('data-share');
      if (k === 'native') return; // handled above
      b.addEventListener('click', (e) => {
        e.preventDefault();
        if (k === 'copy') {
          copyLink().then(() => flash(b));
          return;
        }
        if (k === 'xhs') {
          copyLink().then(() => { flash(b); showToast(tip('xhs')); });
          return;
        }
        if (k === 'wechat') { openWechat(); return; }
        const href = buildTargets()[k];
        if (!href) return;
        if (k === 'email') location.href = href;
        else window.open(href, '_blank', 'noopener,width=640,height=560');
      });
    });

    // ----- citation widget -----
    const widget = root.querySelector('.fh-cite-widget');
    if (widget) {
      const tabs = widget.querySelectorAll('.fh-cite-tab');
      const blocks = widget.querySelectorAll('.fh-citation');
      const copyBtn = widget.querySelector('.fh-cite-copy');
      const select = (fmt) => {
        tabs.forEach(t => {
          const on = t.getAttribute('data-fmt') === fmt;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        blocks.forEach(b => {
          const on = b.getAttribute('data-fmt') === fmt;
          b.classList.toggle('is-active', on);
          if (on) b.removeAttribute('hidden');
          else b.setAttribute('hidden', '');
        });
      };
      tabs.forEach(t => t.addEventListener('click', () => select(t.getAttribute('data-fmt'))));
      if (copyBtn) copyBtn.addEventListener('click', () => {
        const active = widget.querySelector('.fh-citation.is-active');
        if (!active) return;
        const text = active.textContent || '';
        const orig = copyBtn.innerHTML;
        const done = () => {
          copyBtn.classList.add('is-flashed');
          const lang = root.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
          copyBtn.textContent = lang === 'zh' ? '已复制' : 'Copied';
          setTimeout(() => {
            copyBtn.classList.remove('is-flashed');
            copyBtn.innerHTML = orig;
          }, 1500);
        };
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(done, done);
        } else {
          const ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          done();
        }
      });
      // Default tab: ZH UI lands on GB/T, EN UI on APA.
      const initLang = root.getAttribute('data-lang') === 'zh' ? 'gbt' : 'apa';
      select(initLang);
    }
  })();
</script>
