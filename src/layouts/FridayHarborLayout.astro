<script is:inline>
  (function () {
    const root = document.querySelector('.fh-root');
    if (!root) return;
    // Thumb-capture mode: when the page is loaded with ?thumb=1 (or
    // ?thumb=zh for the Chinese variant), flip a flag on <html> so the
    // CSS in the layout's <style is:global> block can hide everything
    // except the figure stage. Used by scripts/snapshot-thumbs.sh to
    // produce homepage-card thumbnails without manual cropping.
    try {
      const params = new URLSearchParams(location.search);
      const thumb = params.get('thumb');
      if (thumb) {
        document.documentElement.setAttribute('data-fh-thumb', '1');
        // Force a specific language for the snapshot if requested.
        if (thumb === 'zh' || thumb === 'en') {
          root.setAttribute('data-lang', thumb);
          try { localStorage.setItem('fh-lang', thumb); } catch (e) {}
          // Skip the rest of language-init below to avoid clobbering it.
          return;
        }
      }
    } catch (e) { /* URLSearchParams missing in ancient browsers */ }
    let lang = 'en';
    try { lang = localStorage.getItem('fh-lang') || 'en'; } catch (e) {}
    if (lang !== 'en' && lang !== 'zh') lang = 'en';
    root.setAttribute('data-lang', lang);
    // Segmented EN / 中 switch — clicking a button sets the language
    // explicitly (no toggle ambiguity). Active state painted on each
    // change so the highlighted pill always tracks the current lang.
    const langBtns = root.querySelectorAll('.fh-lang-btn');
    function paintLangBtns() {
      const cur = root.getAttribute('data-lang') || 'en';
      langBtns.forEach(b => {
        const on = b.getAttribute('data-lang-set') === cur;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }
    langBtns.forEach(b => b.addEventListener('click', () => {
      const next = b.getAttribute('data-lang-set') || 'en';
      if (root.getAttribute('data-lang') === next) return;
      root.setAttribute('data-lang', next);
      try { localStorage.setItem('fh-lang', next); } catch (e) {}
      paintLangBtns();
      reloadGiscus();
    }));
    paintLangBtns();

    // ----- figure watermark + (opt-in) expand-to-fullscreen -----
    // Inject an HGIS Lab · Friday Harbor mark into the bottom-right of
    // every entry's stage, plus an expand button at top-right when the
    // figure carries data-fh-expandable. Centralized so a new article
    // only needs the markup attribute to enable both.
    //
    // Most entries call `stage.innerHTML = ''` on resize / language
    // change to redraw, which would wipe the children — a single
    // MutationObserver re-attaches both elements when they go missing.
    (function injectStageChrome() {
      const stage = document.getElementById('stage');
      if (!stage) return;
      const figure = stage.closest('figure');
      const overlay = document.querySelector('.fh-overlay');
      const overlayInner = overlay && overlay.querySelector('.fh-overlay-inner');
      const overlayClose = overlay && overlay.querySelector('.fh-overlay-close');
      const expandable = !!(figure && figure.hasAttribute('data-fh-expandable') && overlay && overlayInner);

      let wm = null;
      let btn = null;
      let stageHomeParent = null;
      let stageHomeNext = null;

      function buildWatermark() {
        const a = document.createElement('a');
        a.className = 'fh-watermark';
        a.href = '/friday-harbor/';
        a.setAttribute('aria-label', 'HGIS Lab · Friday Harbor');
        a.innerHTML = [
          '<svg class="fh-wm-logo" viewBox="160 555 325 290" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">',
            '<path class="fh-wm-bar fh-wm-bar-humanistic" d="M299.2,565.6L175,791.6l22.8,41l103-186.7l57.5,105.9h45.5L299.2,565.6z"/>',
            '<path class="fh-wm-bar fh-wm-bar-geoai" d="M300.8,645.9l22.7,41.8l-58.4,103.9l205.9,0.1l-21.7,42l-251.5-1.2L300.8,645.9z"/>',
            '<path class="fh-wm-bar fh-wm-bar-fake" d="M299.2,565.6l104.5,186.1l-116.2,0.1l-22.3,39.8l205.8,0L345.5,565.5L299.2,565.6z"/>',
          '</svg>',
          '<span class="fh-wm-lab">HGIS Lab</span>',
          '<span class="fh-wm-sep" aria-hidden="true">·</span>',
          '<em class="fh-wm-fh">',
            '<span data-lang="en">Friday Harbor</span>',
            '<span data-lang="zh">周五港</span>',
          '</em>',
        ].join('');
        ['mousedown', 'pointerdown', 'click', 'touchstart'].forEach(evt =>
          a.addEventListener(evt, e => e.stopPropagation()));
        return a;
      }
      function buildExpandBtn() {
        const b = document.createElement('button');
        b.className = 'fh-expand-btn';
        b.type = 'button';
        b.setAttribute('aria-label', 'Expand figure');
        // Four corner brackets — universal "expand" glyph, no icon font.
        b.innerHTML =
          '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" '
          + 'stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">'
          +   '<polyline points="2,6 2,2 6,2"/>'
          +   '<polyline points="14,6 14,2 10,2"/>'
          +   '<polyline points="14,10 14,14 10,14"/>'
          +   '<polyline points="2,10 2,14 6,14"/>'
          + '</svg>';
        ['mousedown', 'pointerdown', 'touchstart'].forEach(evt =>
          b.addEventListener(evt, e => e.stopPropagation()));
        b.addEventListener('click', e => {
          e.stopPropagation();
          e.preventDefault();
          openOverlay();
        });
        return b;
      }
      function ensure() {
        if (!stage.querySelector('.fh-watermark')) {
          if (!wm) wm = buildWatermark();
          stage.appendChild(wm);
        }
        if (expandable && !stage.querySelector('.fh-expand-btn')) {
          if (!btn) btn = buildExpandBtn();
          stage.appendChild(btn);
        }
      }

      function openOverlay() {
        if (!overlay || overlay.hidden === false) return;
        stageHomeParent = stage.parentElement;
        stageHomeNext = stage.nextElementSibling;
        overlayInner.appendChild(stage);
        overlay.hidden = false;
        overlay.setAttribute('aria-hidden', 'false');
        document.body.classList.add('fh-overlay-on');
        // d3 scripts re-render on resize; trigger one so the figure
        // re-lays out for the larger canvas.
        window.dispatchEvent(new Event('resize'));
      }
      function closeOverlay() {
        if (!overlay || overlay.hidden) return;
        if (stageHomeParent) {
          if (stageHomeNext && stageHomeNext.parentElement === stageHomeParent) {
            stageHomeParent.insertBefore(stage, stageHomeNext);
          } else {
            stageHomeParent.appendChild(stage);
          }
        }
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('fh-overlay-on');
        window.dispatchEvent(new Event('resize'));
      }
      if (expandable) {
        overlayClose.addEventListener('click', closeOverlay);
        overlay.addEventListener('click', (e) => {
          // Backdrop click closes; clicks landing on the inner area
          // (where the stage lives) don't bubble up to overlay.
          if (e.target === overlay) closeOverlay();
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
        });
      }

      ensure();
      const mo = new MutationObserver(ensure);
      mo.observe(stage, { childList: true });
    })();

    // ----- giscus comments (GitHub Discussions) ------------------------
    // Configuration is defined as constants the user can flip after
    // running giscus.app's wizard once. Until the repo IDs are filled
    // in, the script silently no-ops so deploys don't break.
    const GISCUS = {
      repo:       'jakobzhao/hgis-site',
      repoId:     'R_kgDOSMIehg',
      category:   'Comments',
      categoryId: 'DIC_kwDOSMIehs4C7wE-',
      // Custom theme: a Morandi-palette CSS file in /public/. Must be
      // served from the same host the page is served from (giscus
      // injects it into its iframe via <link>; no CORS step needed).
      themeUrl:   'https://hgis.uw.edu/giscus-morandi.css',
    };
    const giscusMount = document.getElementById('fh-giscus');
    function giscusLang() {
      return root.getAttribute('data-lang') === 'zh' ? 'zh-CN' : 'en';
    }
    function loadGiscus() {
      if (!giscusMount) return;
      if (GISCUS.repoId.startsWith('REPLACE_') || GISCUS.categoryId.startsWith('REPLACE_')) {
        // Placeholder mode — leave the help text up, don't try to mount.
        return;
      }
      // Wipe any prior frame (called on language switch)
      giscusMount.innerHTML = '';
      const s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      s.async = true;
      s.crossOrigin = 'anonymous';
      const attrs = {
        'data-repo': GISCUS.repo,
        'data-repo-id': GISCUS.repoId,
        'data-category': GISCUS.category,
        'data-category-id': GISCUS.categoryId,
        'data-mapping': 'pathname',
        'data-strict': '0',
        'data-reactions-enabled': '1',
        'data-emit-metadata': '0',
        'data-input-position': 'bottom',
        // Custom Morandi theme — see /public/giscus-morandi.css.
        'data-theme': GISCUS.themeUrl,
        'data-lang': giscusLang(),
        'data-loading': 'lazy',
      };
      Object.keys(attrs).forEach(k => s.setAttribute(k, attrs[k]));
      giscusMount.appendChild(s);
    }
    function reloadGiscus() {
      // The mounted iframe accepts setConfig messages without a full
      // remount, but it's only modestly more efficient and adds risk
      // when the script has hot-reload variants. Full remount is the
      // safe path for a low-traffic column.
      loadGiscus();
    }
    loadGiscus();

    // ----- share row -----
    const url = location.href;
    const titleEl = root.querySelector('.fh-title');
    const ledeEl  = root.querySelector('.fh-lede');

    function curLang() {
      return root.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
    }
    function pickLangText(el, lang) {
      if (!el) return '';
      const span = el.querySelector('[data-lang="' + lang + '"]');
      return (span ? span.textContent : (el.textContent || '')).trim();
    }
    function shareTitle() {
      return pickLangText(titleEl, curLang()) || document.title;
    }
    function shareLede() {
      return pickLangText(ledeEl, curLang());
    }
    function tip(key) {
      const en = { copied: 'Link copied', xhs: 'Link copied — open Xiaohongshu and paste it.' };
      const zh = { copied: '链接已复制', xhs: '链接已复制 —— 回到小红书 App 内粘贴即可。' };
      return (curLang() === 'zh' ? zh : en)[key];
    }

    function buildTargets() {
      const title  = shareTitle();
      const lede   = shareLede();
      const t      = encodeURIComponent(title);
      const u      = encodeURIComponent(url);
      const teaser = encodeURIComponent(lede ? title + ' — ' + lede : title);
      const body   = encodeURIComponent((lede ? lede + '\n\n' : '') + url);
      return {
        x:        'https://x.com/intent/post?text=' + teaser + '&url=' + u,
        bluesky:  'https://bsky.app/intent/compose?text=' + teaser + '%20' + u,
        linkedin: 'https://www.linkedin.com/sharing/share-offsite/?url=' + u,
        facebook: 'https://www.facebook.com/sharer/sharer.php?u=' + u,
        email:    'mailto:?subject=' + t + '&body=' + body,
        weibo:    'https://service.weibo.com/share/share.php?url=' + u + '&title=' + t,
        douban:   'https://www.douban.com/share/service?href=' + u + '&name=' + t,
      };
    }

    const toast = root.querySelector('.fh-toast');
    let toastTimer = 0;
    function showToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('is-on');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('is-on'), 2600);
    }

    function flash(btn, msg) {
      btn.classList.add('is-flashed');
      const orig = btn.innerHTML;
      btn.textContent = msg || tip('copied');
      setTimeout(() => { btn.classList.remove('is-flashed'); btn.innerHTML = orig; }, 1600);
    }

    function copyLink() {
      return new Promise((resolve) => {
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(resolve, resolve);
        } else {
          const ta = document.createElement('textarea');
          ta.value = url; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          resolve();
        }
      });
    }

    const wechat = root.querySelector('#fh-wechat');
    function openWechat() {
      if (!wechat) return;
      wechat.querySelector('.fh-wechat-qr').src =
        'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(url);
      wechat.querySelector('.fh-wechat-url').textContent = url;
      wechat.hidden = false;
    }
    function closeWechat() { if (wechat) wechat.hidden = true; }
    if (wechat) {
      wechat.querySelector('.fh-wechat-x').addEventListener('click', closeWechat);
      const wechatCopy = wechat.querySelector('.fh-wechat-copy');
      if (wechatCopy) wechatCopy.addEventListener('click', () => {
        copyLink().then(() => flash(wechatCopy));
      });
    }
    document.addEventListener('click', (e) => {
      if (wechat && !wechat.hidden && !wechat.contains(e.target)
          && !e.target.closest('[data-share="wechat"]')) closeWechat();
    });

    // Native Web Share API — only revealed when supported (mobile, Safari, Chrome).
    // When available it gives the user every share target their device knows about.
    const nativeBtn = root.querySelector('[data-share="native"]');
    if (nativeBtn && typeof navigator.share === 'function') {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        navigator.share({
          title: shareTitle(),
          text:  shareLede() || shareTitle(),
          url:   url,
        }).catch(() => { /* user cancelled or unsupported scheme — ignore */ });
      });
    }

    root.querySelectorAll('[data-share]').forEach(b => {
      const k = b.getAttribute('data-share');
      if (k === 'native') return; // handled above
      b.addEventListener('click', (e) => {
        e.preventDefault();
        if (k === 'copy') {
          copyLink().then(() => flash(b));
          return;
        }
        if (k === 'xhs') {
          copyLink().then(() => { flash(b); showToast(tip('xhs')); });
          return;
        }
        if (k === 'wechat') { openWechat(); return; }
        const href = buildTargets()[k];
        if (!href) return;
        if (k === 'email') location.href = href;
        else window.open(href, '_blank', 'noopener,width=640,height=560');
      });
    });

    // ----- citation widget -----
    const widget = root.querySelector('.fh-cite-widget');
    if (widget) {
      const tabs = widget.querySelectorAll('.fh-cite-tab');
      const blocks = widget.querySelectorAll('.fh-citation');
      const copyBtn = widget.querySelector('.fh-cite-copy');
      const select = (fmt) => {
        tabs.forEach(t => {
          const on = t.getAttribute('data-fmt') === fmt;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        blocks.forEach(b => {
          const on = b.getAttribute('data-fmt') === fmt;
          b.classList.toggle('is-active', on);
          if (on) b.removeAttribute('hidden');
          else b.setAttribute('hidden', '');
        });
      };
      tabs.forEach(t => t.addEventListener('click', () => select(t.getAttribute('data-fmt'))));
      if (copyBtn) copyBtn.addEventListener('click', () => {
        const active = widget.querySelector('.fh-citation.is-active');
        if (!active) return;
        const text = active.textContent || '';
        const orig = copyBtn.innerHTML;
        const done = () => {
          copyBtn.classList.add('is-flashed');
          const lang = root.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
          copyBtn.textContent = lang === 'zh' ? '已复制' : 'Copied';
          setTimeout(() => {
            copyBtn.classList.remove('is-flashed');
            copyBtn.innerHTML = orig;
          }, 1500);
        };
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(done, done);
        } else {
          const ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); } catch (e) {}
          document.body.removeChild(ta);
          done();
        }
      });
      // Default tab: ZH UI lands on GB/T, EN UI on APA.
      const initLang = root.getAttribute('data-lang') === 'zh' ? 'gbt' : 'apa';
      select(initLang);
    }
  })();
</script>
